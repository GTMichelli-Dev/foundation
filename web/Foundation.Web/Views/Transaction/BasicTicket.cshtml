@inject Foundation.Web.Services.AppSetupCache SetupCache
@{
    ViewData["Title"] = "Basic Ticket";
    var cachedSetup = SetupCache.Get();
    var slots = ViewBag.FieldSlots as List<Foundation.Web.Models.FieldSlot> ?? new List<Foundation.Web.Models.FieldSlot>();
    ViewData["SlotTransaction"] = null;
}

<h3>Basic Ticket</h3>
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form asp-action="BasicTicket" method="post">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Ticket Number</label>
                        <input type="text" class="form-control" value="@ViewBag.NextTicket" readonly />
                    </div>

                    <partial name="_ScalePicker" />
                    <input type="hidden" name="scaleUsed" id="scaleUsed" value="" />

                    <div class="mb-3">
                        <label class="form-label">Weight (lb)</label>
                        <div class="input-group">
                            <input type="number" name="InWeight" id="basicWeightInput" class="form-control" value="@ViewBag.CurrentWeight" required />
                            <button type="button" class="btn btn-primary" id="basicGetWeightBtn">Get Weight</button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Date/Time</label>
                        <input type="datetime-local" name="DateIn" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>

                    @foreach (var slot in slots)
                    {
                        <partial name="_TicketFieldSlot" model="slot" />
                    }

                    <div class="mt-4">
                        <button type="submit" class="btn btn-warning btn-lg me-2">Save Basic Ticket</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-lg">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Add Truck Modal -->
<div class="modal fade" id="addTruckModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Truck</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Carrier</label>
                    <input type="text" id="modalCarrier" class="form-control" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">Truck ID</label>
                    <input type="text" id="modalTruckId" class="form-control" maxlength="50" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTruckBtn">Add Truck</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        // --- Scale selection: refresh the weight from the chosen scale and
        // record its name on the ticket. Typing a weight by hand clears the
        // scale name (it wasn't a scale reading).
        function refreshBasicWeight() {
            var s = window.bwScale ? bwScale() : { id: null, name: '' };
            var url = '/api/scale/weight' + (s.id ? '?scale=' + encodeURIComponent(s.id) : '');
            $.getJSON(url, function (data) {
                if (!data.error) {
                    $('#basicWeightInput').val(data.weight);
                    $('#scaleUsed').val(s.name);
                }
            });
        }
        $('#basicGetWeightBtn').on('click', refreshBasicWeight);
        $('#scaleSelect').on('change', refreshBasicWeight);
        $('#basicWeightInput').on('input', function () { $('#scaleUsed').val(''); });
        // The server prefilled the weight from the default scale; stamp the
        // selected scale's name (and re-read if a different scale is stored).
        refreshBasicWeight();

        var customerSelect = $('select[name="Customer"]');
        var carrierSelect = $('select[name="Carrier"]');
        var truckSelect = $('#truckSelect');
        var addTruckBtn = $('#addTruckBtn');

        customerSelect.on('change', function () {
            if (!carrierSelect.val() && $(this).val()) {
                carrierSelect.val($(this).val());
                carrierSelect.trigger('change');
            }
        });

        function loadTrucks(carrier, selectTruckId) {
            if (!carrier) {
                truckSelect.html('<option value="">-- Select Carrier First --</option>').prop('disabled', true);
                addTruckBtn.prop('disabled', true);
                return;
            }
            $.getJSON('/api/masterdata/trucks/' + encodeURIComponent(carrier), function (trucks) {
                truckSelect.html('<option value="">-- Select --</option>');
                trucks.forEach(function (t) {
                    truckSelect.append($('<option>').val(t.truckId).text(t.truckId));
                });
                truckSelect.prop('disabled', false);
                addTruckBtn.prop('disabled', false);
                if (selectTruckId) truckSelect.val(selectTruckId);
            });
        }

        carrierSelect.on('change', function () { loadTrucks($(this).val()); });

        addTruckBtn.on('click', function () {
            $('#modalCarrier').val(carrierSelect.val());
            $('#modalTruckId').val('');
            new bootstrap.Modal('#addTruckModal').show();
            setTimeout(function () { $('#modalTruckId').focus(); }, 500);
        });

        $('#saveTruckBtn').on('click', function () {
            var carrier = $('#modalCarrier').val();
            var truckId = $('#modalTruckId').val().trim();
            if (!truckId) return;
            $.ajax({
                url: '/api/masterdata/trucks',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ truckId: truckId, carrierName: carrier }),
                success: function () {
                    bootstrap.Modal.getInstance('#addTruckModal').hide();
                    loadTrucks(carrier, truckId);
                }
            });
        });

        $('#modalTruckId').on('keypress', function (e) {
            if (e.which === 13) { e.preventDefault(); $('#saveTruckBtn').click(); }
        });
    });
</script>
}
