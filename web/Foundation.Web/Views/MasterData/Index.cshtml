@{
    ViewData["Title"] = "Edit Tables";
    var kioskCount = (int)ViewBag.KioskCount;
    var showKiosk = kioskCount > 0;
    var useQuickBooks = (bool)ViewBag.UseQuickBooks;
    var useRetainedTare = (bool)(ViewBag.UseRetainedTare ?? false);
    var customFieldLists = ViewBag.CustomFieldLists as List<Foundation.Web.Models.CustomField>
        ?? new List<Foundation.Web.Models.CustomField>();
}

<style>
    /* Customers grid Carrier column — keep "Carrier" badge and "Add to
       Carriers" button at the same width so the column reads cleanly. */
    .btn-carrier-cell {
        width: 140px;
        text-align: center;
    }

    /* Style DevExtreme batch-edit Delete / Undelete links as Bootstrap
       buttons. Delete is inverse-danger (solid red default, outline on
       hover); Undelete is outline-info. */
    .dx-datagrid .dx-link-delete,
    .dx-datagrid .dx-link-undelete {
        display: inline-block;
        padding: 0.2rem 0.55rem;
        font-size: 0.8125rem;
        line-height: 1.4;
        border-radius: 0.3rem;
        border: 1px solid transparent;
        text-decoration: none !important;
        font-weight: 500;
        transition: color .12s, background-color .12s, border-color .12s;
    }
    .dx-datagrid .dx-link-delete {
        color: #dc3545;
        background: transparent;
        border-color: #dc3545;
    }
    .dx-datagrid .dx-link-delete:hover {
        color: #fff;
        background: #dc3545;
        border-color: #dc3545;
    }
    .dx-datagrid .dx-link-undelete {
        color: #0dcaf0;
        border-color: #0dcaf0;
        background: transparent;
    }
    .dx-datagrid .dx-link-undelete:hover {
        color: #000;
        background: #0dcaf0;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">Edit Tables</h3>
    <div>
        <span id="qbSyncStatus" class="me-2 text-muted small"></span>
        @if (useQuickBooks)
        {
            <button id="btnQBSync" class="btn btn-success btn-sm" onclick="triggerQBSync()" style="display:none;">
                <i class="fa fa-download"></i> Sync from QuickBooks
            </button>
        }
    </div>
</div>

@if (useQuickBooks)
{
    <div id="qbStatusBanner" class="alert alert-warning py-1 mb-2 d-flex align-items-center" role="alert">
        <div><i class="fa fa-spinner fa-spin"></i> Checking QuickBooks connection...</div>
    </div>
}

<ul class="nav nav-tabs" id="masterDataTabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#customersTab">Customers</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#carriersTab">Carriers & Trucks</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#locationsTab">Locations</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#destinationsTab">Destinations</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#commoditiesTab">Commodities</button>
    </li>
    @foreach (var cf in customFieldLists)
    {
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#cfListTab_@cf.Id">@cf.Name</button>
        </li>
    }
</ul>

<div class="tab-content mt-3">
    <div class="tab-pane fade show active" id="customersTab">
        <div id="customersGrid"></div>
    </div>
    <div class="tab-pane fade" id="carriersTab">
        <div id="carriersGrid"></div>
    </div>
    <div class="tab-pane fade" id="locationsTab">
        <div id="locationsGrid"></div>
    </div>
    <div class="tab-pane fade" id="destinationsTab">
        <div id="destinationsGrid"></div>
    </div>
    <div class="tab-pane fade" id="commoditiesTab">
        <div id="commoditiesGrid"></div>
    </div>
    @foreach (var cf in customFieldLists)
    {
        <div class="tab-pane fade" id="cfListTab_@cf.Id">
            <p class="small text-muted mb-2">
                Dropdown choices for the <strong>@cf.Name</strong> custom field
                (Setup &rarr; Fields). Drag rows to reorder. Values already saved
                on tickets are kept even if removed here.
            </p>
            <div id="cfListGrid_@cf.Id" class="cf-list-grid" data-field-id="@cf.Id" style="max-width: 480px;"></div>
        </div>
    }
</div>

<!-- Unsaved-changes confirmation when leaving the page -->
<div class="modal fade" id="mdLeaveConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Unsaved changes</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                You have unsaved changes. Continue without saving?
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Stay</button>
                <button type="button" class="btn btn-danger btn-sm" id="mdLeaveConfirmBtn">Continue</button>
            </div>
        </div>
    </div>
</div>

<!-- QB-sync confirmation when there are unsaved batch edits in any grid -->
<div class="modal fade" id="mdSyncConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Unsaved changes</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                You have unsaved edits in one or more grids. Syncing from QuickBooks
                will refresh the grids and discard those staged edits. Save them
                first if you want to keep them.
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="mdSyncDiscardBtn">Discard &amp; Sync</button>
                <button type="button" class="btn btn-primary btn-sm" id="mdSyncSaveBtn">Save &amp; Sync</button>
            </div>
        </div>
    </div>
</div>

<!-- Clear-tare confirmation modal (replaces window.confirm) -->
<div class="modal fade" id="clearTareModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Clear Retained Tare</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body small">
                Clear retained tare for <strong id="clearTareTruckLabel"></strong>?
                The next weigh-in for this truck will run a normal two-pass cycle to capture a fresh tare.
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger btn-sm" id="clearTareConfirmBtn">Clear</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Bootstrap-modal replacement for the native confirm() dialog used by the
    // truck grid's Clear-Tare button. State is held on the modal element via
    // jQuery .data() so the click handler can read which truck to clear.
    function promptClearTare(rowData, gridComponent) {
        var $modal = $('#clearTareModal');
        $('#clearTareTruckLabel').text(rowData.truckId);
        $modal.data('clearTareRowId', rowData.id);
        $modal.data('clearTareGrid', gridComponent);
        new bootstrap.Modal($modal[0]).show();
    }
    $(function () {
        $('#clearTareConfirmBtn').on('click', function () {
            var $modal = $('#clearTareModal');
            var id = $modal.data('clearTareRowId');
            var grid = $modal.data('clearTareGrid');
            if (id == null) return;
            $.ajax({
                url: '/api/retainedtares/' + id + '/clear',
                method: 'POST'
            }).done(function () {
                bootstrap.Modal.getInstance($modal[0]).hide();
                if (grid && grid.refresh) grid.refresh();
            });
        });
    });

    // Refresh the parent Carriers grid after a truck add / remove so the
    // "# Trucks" column stays accurate without a manual page reload.
    function refreshCarriersGrid() {
        var grid = $('#carriersGrid').dxDataGrid('instance');
        if (grid) grid.refresh();
    }

    // Toolbar item that toggles a grid between paged (default 20/page) and
    // unpaged ("Show All"). When unpaged, the header-checkbox toggle in
    // boolToggleHeaderCol affects every row in the data source, since
    // getVisibleRows() then returns the full set.
    var SHOW_ALL_PAGE_SIZE = 100000;
    function attachShowAllButton(prepareEvent) {
        prepareEvent.toolbarOptions.items.unshift({
            location: 'after',
            widget: 'dxButton',
            options: {
                text: 'Show All',
                hint: 'Disable pagination so header checkboxes affect every row',
                onClick: function (btnEvent) {
                    var grid = prepareEvent.component;
                    var size = grid.option('paging.pageSize');
                    var showingAll = !size || size >= SHOW_ALL_PAGE_SIZE;
                    if (showingAll) {
                        grid.option('paging.pageSize', 20);
                        btnEvent.component.option('text', 'Show All');
                    } else {
                        grid.option('paging.pageSize', SHOW_ALL_PAGE_SIZE);
                        btnEvent.component.option('text', 'Paginate');
                    }
                }
            }
        });
    }

    /// Boolean column with a header checkbox that toggles every visible row.
    /// Stages the changes via grid.cellValue() so they go through the same
    /// batch-edit pipeline as per-row edits — operator clicks Save in the
    /// grid toolbar to commit, matching the per-row behavior. minWidth keeps
    /// the column from shrinking below 200px even when stateStoring restores
    /// a smaller manual width from a previous session.
    /// `endpoint` is currently unused (kept for forward compatibility with
    /// the /api/masterdata/{table}/bulk-set server endpoint).
    function boolToggleHeaderCol(dataField, caption, endpoint, width) {
        var col = {
            dataField: dataField,
            caption: caption,
            dataType: 'boolean',
            width: width || 200,
            minWidth: 200,
            headerCellTemplate: function (container, options) {
                var $wrap = $('<div>').css({
                    display: 'flex',
                    'align-items': 'center',
                    'justify-content': 'center',
                    gap: '8px',
                    'white-space': 'nowrap'
                });
                $('<span>').text(caption).appendTo($wrap);
                $('<input type="checkbox" class="form-check-input">')
                    .attr('title', 'Toggle every row — then click Save to commit')
                    .css({ cursor: 'pointer', margin: 0 })
                    .on('click', function (e) {
                        e.stopPropagation();
                        var checked = this.checked;
                        var grid = options.component;
                        var rows = grid.getVisibleRows();
                        rows.forEach(function (r) {
                            if (r.rowType !== 'data') return;
                            // Kiosk-header toggle: only flip rows where Active
                            // is true when turning ON, so the invariant
                            // (kiosk implies active) holds. Turning OFF is
                            // always safe.
                            if (dataField === 'useAtKiosk' && checked
                                && r.data && !r.data.active) {
                                return;
                            }
                            grid.cellValue(r.rowIndex, dataField, checked);
                        });
                        // Intentionally do NOT call grid.saveEditData() —
                        // operator clicks Save in the edit toolbar to commit,
                        // for consistency with how row edits work.
                    })
                    .appendTo($wrap);
                $wrap.appendTo(container);
            }
        };

        // Invariant: kiosk implies active. When Active is unchecked on a row,
        // clear UseAtKiosk on the same row so the staged edit matches the
        // server-side rule applied in UpdateCustomer/UpdateCarrier/etc.
        if (dataField === 'active') {
            col.setCellValue = function (newData, value, currentRowData) {
                newData.active = value;
                if (!value) newData.useAtKiosk = false;
            };
        }
        return col;
    }

    // Disable the kiosk cell editor on rows where Active is false. Combined
    // with the Active column's setCellValue cascade, this enforces the
    // "kiosk implies active" invariant in the UI before the operator saves.
    function disableKioskOnInactiveRow(e) {
        if (e.dataField === 'useAtKiosk' && e.parentType === 'dataRow') {
            var rowData = e.row && e.row.data;
            if (rowData && rowData.active === false) {
                e.editorOptions.disabled = true;
                e.editorOptions.value = false;
            }
        }
    }

    $(function () {
        var showKiosk = @(showKiosk ? "true" : "false");
        var useQuickBooks = @(useQuickBooks ? "true" : "false");
        var useRetainedTare = @(useRetainedTare ? "true" : "false");

        function createIdStore(endpoint) {
            return new DevExpress.data.CustomStore({
                key: 'id',
                load: function () {
                    return $.getJSON('/api/masterdata/' + endpoint);
                },
                insert: function (values) {
                    return $.ajax({
                        url: '/api/masterdata/' + endpoint,
                        method: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(values)
                    });
                },
                update: function (key, values) {
                    values.id = key;
                    return $.ajax({
                        url: '/api/masterdata/' + endpoint,
                        method: 'PUT',
                        contentType: 'application/json',
                        data: JSON.stringify(values)
                    });
                },
                remove: function (key) {
                    return $.ajax({
                        url: '/api/masterdata/' + endpoint + '/' + key,
                        method: 'DELETE'
                    });
                }
            });
        }

        function initNameActiveGrid(selector, endpoint, nameField, nameCaption, qbManaged, addCarrierAction) {
            var lockName = useQuickBooks && qbManaged;
            var cols = [
                { dataField: 'id', caption: 'ID', width: 60, allowEditing: false },
                { dataField: nameField, caption: nameCaption, sortOrder: 'asc', allowEditing: !lockName, validationRules: lockName ? [] : [{ type: 'required' }] },
                boolToggleHeaderCol('active', 'Active', endpoint, 200)
            ];
            if (showKiosk) {
                cols.push(boolToggleHeaderCol('useAtKiosk', 'Use At Kiosk', endpoint, 200));
            }
            if (addCarrierAction) {
                cols.push({
                    caption: 'Carrier',
                    width: 160,
                    allowEditing: false,
                    cellTemplate: function (container, options) {
                        var data = options.data || {};
                        if (data.isCarrier) {
                            // Same outline-button shape AND width as Add to
                            // Carriers so the column reads cleanly.
                            $('<button type="button" class="btn btn-sm btn-outline-secondary btn-carrier-cell" disabled>Carrier</button>')
                                .appendTo(container);
                        } else if (data.id) {
                            $('<button type="button" class="btn btn-sm btn-outline-primary btn-carrier-cell">Add to Carriers</button>')
                                .on('click', function () {
                                    var $btn = $(this).prop('disabled', true).text('Adding…');
                                    $.ajax({
                                        url: '/api/masterdata/customers/' + data.id + '/promote-to-carrier',
                                        method: 'POST'
                                    }).done(function () {
                                        $(selector).dxDataGrid('instance').refresh();
                                        var carriersGrid = $('#carriersGrid').dxDataGrid('instance');
                                        if (carriersGrid) carriersGrid.refresh();
                                    }).fail(function () {
                                        $btn.prop('disabled', false).text('Add to Carriers');
                                    });
                                })
                                .appendTo(container);
                        }
                    }
                });
            }

            $(selector).dxDataGrid({
                hoverStateEnabled: true,
                dataSource: createIdStore(endpoint),
                showBorders: true,
                filterRow: { visible: true },
                headerFilter: { visible: true },
                allowColumnReordering: true,
                allowColumnResizing: true,
                columnChooser: { enabled: true, mode: 'select' },
                stateStoring: {
                    enabled: true,
                    type: 'localStorage',
                    // v2 suffix — abandons pre-v1.3.44 saved column widths so
                    // the new 200px Active/Kiosk defaults take effect. Future
                    // manual resizes are saved under this key as before.
                    storageKey: 'masterData_v2_' + endpoint
                },
                editing: {
                    mode: 'batch',
                    allowAdding: !lockName,
                    allowUpdating: true,
                    allowDeleting: !lockName,
                    useIcons: false
                },
                onToolbarPreparing: attachShowAllButton,
                onEditorPreparing: disableKioskOnInactiveRow,
                columns: cols
            });
        }

        initNameActiveGrid('#customersGrid', 'customers', 'customerName', 'Customer Name', true, true);
        initNameActiveGrid('#locationsGrid', 'locations', 'locationName', 'Location Name', false);
        initNameActiveGrid('#destinationsGrid', 'destinations', 'destinationName', 'Destination Name', false);
        initNameActiveGrid('#commoditiesGrid', 'commodities', 'commodityName', 'Commodity Name', true);

        // Dropdown-value grids for list-backed custom fields (one tab each).
        // The choices are a small ordered list, so edits save immediately
        // (cell mode) and drag-reorder PUTs the full list.
        $('.cf-list-grid').each(function () {
            var fieldId = $(this).data('field-id');
            var apiBase = '/api/customfields/' + fieldId + '/values';

            function editValue(oldValue, newValue) {
                return $.ajax({
                    url: apiBase,
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ oldValue: oldValue, newValue: newValue })
                });
            }

            $(this).dxDataGrid({
                hoverStateEnabled: true,
                showBorders: true,
                dataSource: new DevExpress.data.CustomStore({
                    key: 'value',
                    load: function () { return $.getJSON(apiBase); },
                    insert: function (values) { return editValue(null, values.value); },
                    update: function (key, values) { return editValue(key, values.value); },
                    remove: function (key) { return editValue(key, null); }
                }),
                editing: {
                    mode: 'cell',
                    allowAdding: true,
                    allowUpdating: true,
                    allowDeleting: true,
                    useIcons: false
                },
                rowDragging: {
                    allowReordering: true,
                    onReorder: function (e) {
                        var grid = e.component;
                        var values = grid.getVisibleRows().map(function (r) { return r.data.value; });
                        values.splice(e.fromIndex, 1);
                        values.splice(e.toIndex, 0, e.itemData.value);
                        $.ajax({
                            url: apiBase,
                            method: 'PUT',
                            contentType: 'application/json',
                            data: JSON.stringify(values)
                        }).done(function () { grid.refresh(); });
                    }
                },
                sorting: { mode: 'none' }, // list order = dropdown order
                columns: [{
                    dataField: 'value',
                    caption: 'Value',
                    validationRules: [{ type: 'required' }, { type: 'stringLength', max: 200 }]
                }]
            });
        });

        // Carriers grid with trucks sub-grid (master-detail)
        var customerSuggestions = [];
        $.getJSON('/api/masterdata/customers-not-carriers').done(function (data) {
            customerSuggestions = data;
        });

        var carrierCols = [
            { dataField: 'id', caption: 'ID', width: 60, allowEditing: false },
            {
                dataField: 'carrierName', caption: 'Carrier Name', sortOrder: 'asc', validationRules: [{ type: 'required' }],
                editCellTemplate: function (cellElement, cellInfo) {
                    if (cellInfo.row.isNewRow) {
                        $('<div>').dxAutocomplete({
                            dataSource: customerSuggestions,
                            value: cellInfo.value || '',
                            minSearchLength: 0,
                            showDropDownButton: true,
                            onValueChanged: function (e) {
                                cellInfo.setValue(e.value);
                            }
                        }).appendTo(cellElement);
                    } else {
                        $('<div>').dxTextBox({
                            value: cellInfo.value || '',
                            onValueChanged: function (e) {
                                cellInfo.setValue(e.value);
                            }
                        }).appendTo(cellElement);
                    }
                }
            },
            {
                dataField: 'truckCount',
                caption: '# Trucks',
                dataType: 'number',
                width: 100,
                allowEditing: false,
                alignment: 'center',
                cellTemplate: function (container, options) {
                    var n = options.value || 0;
                    container.text(n);
                    if (n === 0) {
                        // Pink the whole cell so zero-truck carriers stand out
                        // — those carriers can't pass the kiosk no-trucks check.
                        container.css({ background: '#ffd1dc', color: '#8a0033', 'font-weight': '600' });
                    }
                }
            },
            boolToggleHeaderCol('active', 'Active', 'carriers', 200)
        ];
        if (showKiosk) {
            carrierCols.push(boolToggleHeaderCol('useAtKiosk', 'Use At Kiosk', 'carriers', 200));
        }

        var carrierStore = createIdStore('carriers');

        $('#carriersGrid').dxDataGrid({
            hoverStateEnabled: true,
            dataSource: carrierStore,
            showBorders: true,
            filterRow: { visible: true },
            headerFilter: { visible: true },
            allowColumnReordering: true,
            allowColumnResizing: true,
            columnChooser: { enabled: true, mode: 'select' },
            stateStoring: {
                enabled: true,
                type: 'localStorage',
                storageKey: 'masterData_v3_carriers'
            },
            editing: {
                mode: 'batch',
                allowAdding: true,
                allowUpdating: true,
                allowDeleting: true,
                useIcons: false
            },
            onToolbarPreparing: attachShowAllButton,
            onEditorPreparing: disableKioskOnInactiveRow,
            columns: carrierCols,
            onInitNewRow: function () {
                $.getJSON('/api/masterdata/customers-not-carriers').done(function (data) {
                    customerSuggestions = data;
                });
            },
            masterDetail: {
                enabled: true,
                template: function (container, options) {
                    var carrierData = options.data;
                    var carrierName = carrierData.carrierName;

                    var truckCols = [
                        { dataField: 'id', caption: 'ID', width: 60, allowEditing: false },
                        { dataField: 'truckId', caption: 'Truck ID', sortOrder: 'asc', validationRules: [{ type: 'required' }] },
                        { dataField: 'description', caption: 'Description' },
                        { dataField: 'notes', caption: 'Notes' }
                    ];
                    if (showKiosk) {
                        truckCols.push({ dataField: 'useAtKiosk', caption: 'Use At Kiosk', dataType: 'boolean', width: 130 });
                    }
                    if (useRetainedTare) {
                        truckCols.push({
                            dataField: 'retainedTare',
                            caption: 'Retained Tare (lb)',
                            dataType: 'number',
                            format: { type: 'fixedPoint', precision: 0 },
                            width: 150,
                            // Editable inline. Type a value or clear the cell to
                            // wipe the stored tare. Server stamps the
                            // retainedTareUpdated column on save.
                            editorOptions: { min: 0, step: 1 }
                        });
                        truckCols.push({
                            dataField: 'retainedTareUpdated',
                            caption: 'Tare Updated',
                            dataType: 'datetime',
                            format: 'MM/dd/yyyy hh:mm a',
                            width: 160,
                            allowEditing: false
                        });
                        truckCols.push({
                            type: 'buttons',
                            caption: 'Clear',
                            width: 90,
                            buttons: [{
                                hint: 'Clear retained tare',
                                text: 'Clear',
                                cssClass: 'text-danger fw-bold',
                                // Always visible so the column header is consistent;
                                // disabled when there's nothing to clear.
                                disabled: function (e) {
                                    return !e.row || !e.row.data || e.row.data.retainedTare == null;
                                },
                                onClick: function (e) {
                                    var rowData = e.row && e.row.data;
                                    if (!rowData || rowData.retainedTare == null) return;
                                    promptClearTare(rowData, e.component);
                                }
                            }]
                        });
                    }

                    $('<div>').dxDataGrid({
                        hoverStateEnabled: true,
                        dataSource: new DevExpress.data.CustomStore({
                            key: 'id',
                            load: function () {
                                return $.getJSON('/api/masterdata/trucks/' + encodeURIComponent(carrierName));
                            },
                            insert: function (values) {
                                values.carrierName = carrierName;
                                return $.ajax({
                                    url: '/api/masterdata/trucks',
                                    method: 'POST',
                                    contentType: 'application/json',
                                    data: JSON.stringify(values)
                                }).done(refreshCarriersGrid);
                            },
                            update: function (key, values) {
                                values.id = key;
                                values.carrierName = carrierName;
                                return $.ajax({
                                    url: '/api/masterdata/trucks',
                                    method: 'PUT',
                                    contentType: 'application/json',
                                    data: JSON.stringify(values)
                                });
                            },
                            remove: function (key) {
                                return $.ajax({
                                    url: '/api/masterdata/trucks/' + key,
                                    method: 'DELETE'
                                }).done(refreshCarriersGrid);
                            }
                        }),
                        showBorders: true,
                        columnAutoWidth: true,
                        editing: {
                            mode: 'batch',
                            allowAdding: true,
                            allowUpdating: true,
                            allowDeleting: true,
                            useIcons: false
                        },
                        columns: truckCols
                    }).appendTo(container);
                }
            }
        });

        // ===== Unsaved-changes guard =====
        // Any of the master-data grids has uncommitted batch edits if its
        // hasEditData() returns true. When the operator clicks an in-app
        // link or tries to close the tab with pending edits, surface a
        // Bootstrap modal (in-app navigation) or the browser's native
        // beforeunload prompt (tab close / hard navigation).
        var mdIsLeaving = false;
        function mdAnyGridDirty() {
            var grids = ['#customersGrid', '#carriersGrid', '#locationsGrid',
                         '#destinationsGrid', '#commoditiesGrid'];
            for (var i = 0; i < grids.length; i++) {
                var inst = $(grids[i]).dxDataGrid('instance');
                if (inst && typeof inst.hasEditData === 'function' && inst.hasEditData()) {
                    return true;
                }
            }
            return false;
        }
        // Exposed for the QB-sync confirmation flow defined in the IIFE below.
        window.mdAnyGridDirty = mdAnyGridDirty;

        $(window).on('beforeunload', function () {
            if (mdAnyGridDirty() && !mdIsLeaving) return 'You have unsaved changes.';
        });

        var mdPendingHref = null;
        var mdPendingTabBtn = null;
        var mdSuppressTabGuard = false;

        // In-app navigation (regular <a>, e.g. "Back to Setup"). Bootstrap
        // tab switches are handled separately via show.bs.tab below.
        $('a').on('click', function (e) {
            if (!mdAnyGridDirty() || mdIsLeaving) return;
            if ($(this).attr('data-bs-toggle') === 'tab') return;
            var href = $(this).attr('href');
            if (!href || href.indexOf('#') === 0) return;
            e.preventDefault();
            mdPendingHref = href;
            mdPendingTabBtn = null;
            new bootstrap.Modal('#mdLeaveConfirmModal').show();
        });

        // Tab switching inside the page also prompts when there are pending
        // edits — otherwise the operator could shuttle between tabs and
        // forget the staged work.
        $('[data-bs-toggle="tab"]').on('show.bs.tab', function (e) {
            if (mdSuppressTabGuard) return;
            if (!mdAnyGridDirty()) return;
            e.preventDefault();
            mdPendingTabBtn = e.target;
            mdPendingHref = null;
            new bootstrap.Modal('#mdLeaveConfirmModal').show();
        });

        $('#mdLeaveConfirmBtn').on('click', function () {
            bootstrap.Modal.getInstance(document.getElementById('mdLeaveConfirmModal')).hide();
            if (mdPendingTabBtn) {
                // Tab switch: tell the show.bs.tab handler to skip its guard
                // for this one programmatic call so we don't loop.
                var btn = mdPendingTabBtn;
                mdPendingTabBtn = null;
                mdSuppressTabGuard = true;
                try { new bootstrap.Tab(btn).show(); }
                finally { mdSuppressTabGuard = false; }
                return;
            }
            if (mdPendingHref) {
                mdIsLeaving = true; // suppresses beforeunload on the upcoming nav
                window.location.href = mdPendingHref;
            }
        });
    });
</script>
<script src="~/js/signalr/signalr.min.js"></script>
<script>
    // --- QuickBooks Sync via SignalR (loaded after signalr.min.js) ---
    (function () {
        var syncConnection = new signalR.HubConnectionBuilder()
            .withUrl("/scaleHub")
            .withAutomaticReconnect()
            .build();

        syncConnection.on("QBSyncStatus", function (message) {
            $('#qbSyncStatus').text(message);
        });

        syncConnection.on("QBSyncComplete", function (summary) {
            $('#qbSyncStatus').text(summary);
            $('#btnQBSync').prop('disabled', false).html('<i class="fa fa-download"></i> Sync from QuickBooks');
            var grids = ['#customersGrid', '#carriersGrid', '#locationsGrid', '#destinationsGrid', '#commoditiesGrid'];
            grids.forEach(function (sel) {
                var instance = $(sel).dxDataGrid('instance');
                if (instance) instance.refresh();
            });
        });

        syncConnection.on("QBNotRunning", function (message) {
            $('#qbSyncStatus').text('');
            $('#btnQBSync').prop('disabled', false).html('<i class="fa fa-download"></i> Sync from QuickBooks');
            var html = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                '<i class="fa fa-exclamation-triangle"></i> ' + message +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
            if (!$('#qb-alert-container').length) $('body').prepend('<div id="qb-alert-container" style="position:fixed;top:10px;right:10px;z-index:9999;max-width:500px;"></div>');
            $('#qb-alert-container').html(html);
        });

        function updateQBBanner(connected) {
            var banner = document.getElementById('qbStatusBanner');
            var btn = document.getElementById('btnQBSync');
            if (banner) {
                if (connected) {
                    banner.style.cssText = 'background-color:#d1e7dd !important;border-color:#badbcc !important;color:#0f5132 !important;padding:6px 16px !important;margin-bottom:8px !important;border-radius:6px !important;display:flex !important;align-items:center !important;';
                    banner.innerHTML = '<div><i class="fa fa-check-circle"></i> <strong>QuickBooks Connected</strong> — Customer and Commodity names are managed by QuickBooks. Use the <strong>Sync from QuickBooks</strong> button to update.</div>';
                } else {
                    banner.style.cssText = 'background-color:#f8d7da !important;border-color:#f5c2c7 !important;color:#842029 !important;padding:6px 16px !important;margin-bottom:8px !important;border-radius:6px !important;display:flex !important;align-items:center !important;';
                    banner.innerHTML = '<div><i class="fa fa-times-circle"></i> <strong>QuickBooks Not Connected</strong> — Please start the QBSyncService and try again.</div>';
                }
            }
            if (btn) btn.style.display = connected ? '' : 'none';
        }

        syncConnection.on("QBServiceStatusChanged", function (connected) {
            updateQBBanner(connected);
        });

        syncConnection.start().then(function () {
            return syncConnection.invoke("CheckQBServiceConnected");
        }).then(function (connected) {
            updateQBBanner(connected);
        }).catch(function (err) {
            console.error("SignalR connect error:", err);
            updateQBBanner(false);
        });

        // Actual sync invocation, called either directly (no pending edits)
        // or after the operator confirms discarding staged edits in the modal.
        function doQBSync() {
            syncConnection.invoke("CheckQBServiceConnected").then(function (connected) {
                if (!connected) {
                    var html = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                        '<i class="fa fa-exclamation-triangle"></i> QuickBooks Sync Service is not connected. Please start the QBSyncService and try again.' +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>';
                    if (!$('#qb-alert-container').length) $('body').prepend('<div id="qb-alert-container" style="position:fixed;top:10px;right:10px;z-index:9999;max-width:500px;"></div>');
                    $('#qb-alert-container').html(html);
                    return;
                }
                $('#btnQBSync').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Syncing...');
                $('#qbSyncStatus').text('Requesting sync...');
                syncConnection.invoke("TriggerQBSync").catch(function (err) {
                    $('#qbSyncStatus').text('Error: ' + err);
                    $('#btnQBSync').prop('disabled', false).html('<i class="fa fa-download"></i> Sync from QuickBooks');
                });
            }).catch(function (err) {
                $('#qbSyncStatus').text('Error checking service: ' + err);
            });
        }

        window.triggerQBSync = function () {
            // Sync refreshes every grid on completion, which silently drops
            // any uncommitted batch edits. Warn first so the operator can
            // save before continuing.
            if (typeof window.mdAnyGridDirty === 'function' && window.mdAnyGridDirty()) {
                new bootstrap.Modal('#mdSyncConfirmModal').show();
                return;
            }
            doQBSync();
        };

        var MD_GRID_SELECTORS = ['#customersGrid', '#carriersGrid', '#locationsGrid',
                                 '#destinationsGrid', '#commoditiesGrid'];

        $(function () {
            $('#mdSyncDiscardBtn').on('click', function () {
                bootstrap.Modal.getInstance(document.getElementById('mdSyncConfirmModal')).hide();
                // Cancel staged edits across every grid so the upcoming refresh
                // doesn't race against in-flight batch edits.
                MD_GRID_SELECTORS.forEach(function (sel) {
                    var inst = $(sel).dxDataGrid('instance');
                    if (inst && typeof inst.cancelEditData === 'function') inst.cancelEditData();
                });
                doQBSync();
            });

            // Save staged edits across every dirty grid, then proceed to sync.
            // saveEditData() returns a jQuery Deferred; $.when waits for all
            // grids in parallel so we only kick off the sync once every batch
            // round-trips successfully. Any save failure aborts the sync so
            // the operator can fix the offending row.
            $('#mdSyncSaveBtn').on('click', function () {
                var $btn = $(this).prop('disabled', true).text('Saving…');
                var saves = [];
                MD_GRID_SELECTORS.forEach(function (sel) {
                    var inst = $(sel).dxDataGrid('instance');
                    if (inst && typeof inst.hasEditData === 'function' && inst.hasEditData()) {
                        saves.push(inst.saveEditData());
                    }
                });
                $.when.apply($, saves).then(function () {
                    // Some grids may still be dirty if a row failed validation
                    // — bail out and let the operator address the inline error.
                    if (window.mdAnyGridDirty && window.mdAnyGridDirty()) {
                        $btn.prop('disabled', false).text('Save & Sync');
                        return;
                    }
                    bootstrap.Modal.getInstance(document.getElementById('mdSyncConfirmModal')).hide();
                    $btn.prop('disabled', false).text('Save & Sync');
                    doQBSync();
                }, function () {
                    $btn.prop('disabled', false).text('Save & Sync');
                });
            });
        });
    })();
</script>
}
