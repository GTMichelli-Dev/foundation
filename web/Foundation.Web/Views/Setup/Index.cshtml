@model Foundation.Web.Models.AppSetup
@{
    ViewData["Title"] = "Setup";
}

<h3 class="mb-2">Setup</h3>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-1 mb-2" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Auto-save status (Setup saves on every change; no Save button) -->
<div id="saveStatus" class="position-fixed bottom-0 end-0 me-3 mb-3 px-3 py-1 rounded small shadow-sm"
     style="display:none; z-index:1080; background: var(--bw-surface-alt); color: var(--bw-text);"></div>

<form asp-action="Index" method="post" enctype="multipart/form-data" id="setupForm">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" name="activeTab" id="activeTabField" value="@(TempData["ActiveTab"] ?? "tabCompany")" />

    <ul class="nav nav-tabs" id="setupTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabCompany" type="button">Company &amp; Ticket</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabSystem" type="button">System</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabFields" type="button">Fields</button>
        </li>
        <li class="nav-item" id="tabKioskPromptsNav" style="display: @(Model.KioskCount > 0 ? "block" : "none");">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabKioskPrompts" type="button">Kiosk Prompts</button>
        </li>
        <li class="nav-item" id="tabSecurityNav" style="display: @(Model.UseLogin ? "block" : "none");">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabSecurity" type="button">Users &amp; Security</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabDesigners" type="button">Ticket Designers</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabApi" type="button">API</button>
        </li>
        @if (ViewBag.ShowResetDatabase == true)
        {
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabDatabase" type="button">Database</button>
            </li>
        }
    </ul>

    <div class="tab-content mt-3">
        <!-- TAB: Company & Ticket -->
        <div class="tab-pane fade show active" id="tabCompany">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Company Info (Ticket Headers)</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="mb-2">
                                <label asp-for="Header1" class="form-label mb-0 small"></label>
                                <input asp-for="Header1" class="form-control form-control-sm" />
                            </div>
                            <div class="mb-2">
                                <label asp-for="Header2" class="form-label mb-0 small"></label>
                                <input asp-for="Header2" class="form-control form-control-sm" />
                            </div>
                            <div class="mb-2">
                                <label asp-for="Header3" class="form-label mb-0 small"></label>
                                <input asp-for="Header3" class="form-control form-control-sm" />
                            </div>
                            <div class="mb-2">
                                <label asp-for="Header4" class="form-label mb-0 small"></label>
                                <input asp-for="Header4" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Ticket Settings</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2 mb-2">
                                <div class="col-12">
                                    <label asp-for="TicketNumber" class="form-label mb-0 small"></label>
                                    <input asp-for="TicketNumber" class="form-control form-control-sm" type="number" />
                                </div>
                                @* TicketsPerPage hidden from the UI but still posted so the existing value persists. *@
                                <input asp-for="TicketsPerPage" type="hidden" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: System -->
        <div class="tab-pane fade" id="tabSystem">
            <div class="row g-3">
                <div class="col-md-6">
                    <!-- System Settings -->
                    <div class="card mb-3">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>System</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label asp-for="DemoMode" class="form-label mb-0 small"></label>
                                    <select asp-for="DemoMode" class="form-select form-select-sm">
                                        <option value="false">Normal</option>
                                        <option value="true">Demo</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label asp-for="RecallLastValues" class="form-label mb-0 small"></label>
                                    <select asp-for="RecallLastValues" class="form-select form-select-sm">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label asp-for="UseLogin" class="form-label mb-0 small"></label>
                                    <select asp-for="UseLogin" class="form-select form-select-sm" id="UseLogin">
                                        <option value="false">No Login Required</option>
                                        <option value="true">Require Login</option>
                                    </select>
                                </div>
                                <div class="col-6" id="kioskCodeSection" style="display: @(Model.UseLogin ? "block" : "none");">
                                    <label asp-for="KioskCode" class="form-label mb-0 small"></label>
                                    <input asp-for="KioskCode" class="form-control form-control-sm" maxlength="20" />
                                </div>
                            </div>
                            <div class="mb-2">
                                <label asp-for="Theme" class="form-label mb-0 small"></label>
                                <select asp-for="Theme" class="form-select form-select-sm">
                                    <option value="default">Default (Blue)</option>
                                    <option value="dark">Dark Mode</option>
                                    <option value="earth">Earth (Brown, Black &amp; Green)</option>
                                </select>
                            </div>
                            <div class="mb-2">
                                <label asp-for="TimeZoneId" class="form-label mb-0 small"></label>
                                @{
                                    var commonTimeZones = new (string Id, string Label)[]
                                    {
                                        ("America/New_York",    "Eastern (New York)"),
                                        ("America/Chicago",     "Central (Chicago)"),
                                        ("America/Denver",      "Mountain (Denver)"),
                                        ("America/Phoenix",     "Mountain — Arizona (no DST)"),
                                        ("America/Los_Angeles", "Pacific (Los Angeles)"),
                                        ("America/Anchorage",   "Alaska (Anchorage)"),
                                        ("Pacific/Honolulu",    "Hawaii (Honolulu)"),
                                        ("America/Halifax",     "Atlantic (Halifax)"),
                                        ("America/Toronto",     "Eastern — Canada (Toronto)"),
                                        ("America/Mexico_City", "Central — Mexico (Mexico City)"),
                                        ("UTC",                 "UTC (Coordinated Universal Time)"),
                                        ("Europe/London",       "London (UK)"),
                                        ("Europe/Berlin",       "Berlin / Paris / Madrid"),
                                        ("Australia/Sydney",    "Sydney"),
                                    };
                                    var current = string.IsNullOrWhiteSpace(Model.TimeZoneId) ? "America/Chicago" : Model.TimeZoneId;
                                    var inList = commonTimeZones.Any(t => t.Id == current);
                                }
                                <select asp-for="TimeZoneId" class="form-select form-select-sm">
                                    @foreach (var tz in commonTimeZones)
                                    {
                                        <option value="@tz.Id" selected="@(current == tz.Id ? "selected" : null)">@tz.Label</option>
                                    }
                                    @if (!inList)
                                    {
                                        <option value="@current" selected="selected">@current (custom)</option>
                                    }
                                </select>
                                <div class="form-text small">Used for date pickers, completed-tickets grid, ticket prints. Pick a custom IANA ID by editing the database directly if your zone isn't listed.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Kiosk Options -->
                    <div class="card mb-3">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Kiosk</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label asp-for="KioskCount" class="form-label mb-0 small"></label>
                                    <select asp-for="KioskCount" class="form-select form-select-sm" id="KioskCount">
                                        <option value="0">No Kiosk</option>
                                        <option value="1">One Kiosk</option>
                                        <option value="2">In/Out Kiosk</option>
                                    </select>
                                </div>
                                <div class="col-6" id="kioskDarkModeSection" style="display: @(Model.KioskCount > 0 ? "block" : "none");">
                                    <label asp-for="KioskDarkMode" class="form-label mb-0 small"></label>
                                    <select asp-for="KioskDarkMode" class="form-select form-select-sm">
                                        <option value="true">Dark</option>
                                        <option value="false">Light</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Printing -->
                    <div class="card mb-3">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Printing</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label asp-for="RemotePrintMode" class="form-label mb-0 small"></label>
                                    <select asp-for="RemotePrintMode" class="form-select form-select-sm" id="RemotePrintMode">
                                        <option value="None">No Remote Printing</option>
                                        <option value="Scale">Scale Prints Ticket</option>
                                        <option value="RemotePrinter">Remote Printer (Pi)</option>
                                    </select>
                                </div>
                                <div class="col-3 d-flex align-items-end" id="printerManageSection" style="display: @(Model.RemotePrintMode == "RemotePrinter" ? "flex" : "none") !important;">
                                    <a href="/Printer" class="btn btn-outline-secondary btn-sm w-100">
                                        Printers
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card mb-3">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Icon</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <img id="iconPreview" src="/api/setup/icon" alt="Current Icon" style="height: 36px; width: 36px;" />
                                @if (Model.Icon != null)
                                {
                                    <label class="form-check-label small">
                                        <input type="checkbox" name="removeIcon" id="removeIconCb" value="true" class="form-check-input" />
                                        Remove
                                    </label>
                                }
                                else
                                {
                                    <span class="text-muted small">Default</span>
                                }
                            </div>
                            <input type="file" name="iconFile" id="iconFileInput" class="form-control form-control-sm" accept="image/*" />
                        </div>
                    </div>
                    <!-- Options (Cameras, QuickBooks, Scale) -->
                    <div class="card mb-3">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Options</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2 mb-2">
                                <div class="col-4">
                                    <label asp-for="SavePicture" class="form-label mb-0 small"></label>
                                    <select asp-for="SavePicture" class="form-select form-select-sm" id="SavePicture">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="col-2 d-flex align-items-end" id="cameraManageSection" style="display: @(Model.SavePicture ? "flex" : "none") !important;">
                                    <a href="/Camera" class="btn btn-outline-secondary btn-sm w-100">
                                        Cameras
                                    </a>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-4">
                                    <label asp-for="UseQuickBooks" class="form-label mb-0 small"></label>
                                    <select asp-for="UseQuickBooks" class="form-select form-select-sm" id="UseQuickBooks">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="col-2 d-flex align-items-end" id="qbCheckSection" style="display: @(Model.UseQuickBooks ? "flex" : "none") !important;">
                                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" id="btnCheckQBService" onclick="checkQBService()">
                                        Check
                                    </button>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-4">
                                    <label asp-for="ScaleId" class="form-label mb-0 small"></label>
                                    <select asp-for="ScaleId" class="form-select form-select-sm" id="ScaleId">
                                        <option value="">-- None --</option>
                                    </select>
                                </div>
                                <div class="col-2 d-flex align-items-end">
                                    <a href="/Scale" class="btn btn-outline-secondary btn-sm w-100">
                                        Scales
                                    </a>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-4">
                                    <label asp-for="UseRetainedTare" class="form-label mb-0 small"></label>
                                    <select asp-for="UseRetainedTare" class="form-select form-select-sm" id="UseRetainedTare">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="col-4" id="autoClearStaleSection" style="display: @(Model.UseRetainedTare ? "block" : "none");">
                                    <label asp-for="AutoClearStaleRetainedTare" class="form-label mb-0 small"></label>
                                    <select asp-for="AutoClearStaleRetainedTare" class="form-select form-select-sm">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>
                                <div class="col-2 d-flex align-items-end" id="retainedTareManageSection" style="display: @(Model.UseRetainedTare ? "flex" : "none") !important;">
                                    <a href="/MasterData" class="btn btn-outline-secondary btn-sm w-100" title="Manage on MasterData → Carriers &amp; Trucks">
                                        Manage
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Driver Signature -->
                    <div class="card mb-3">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Driver Signature</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="row g-2 mb-2">
                                <div class="col-6">
                                    <label asp-for="SignatureMode" class="form-label mb-0 small"></label>
                                    <select asp-for="SignatureMode" class="form-select form-select-sm" id="SignatureMode">
                                        <option value="None">Off</option>
                                        <option value="Operator">Operator Device (overlay)</option>
                                        <option value="RemotePad">Remote Signature Pad</option>
                                    </select>
                                </div>
                                <div class="col-3 signature-option" style="display: @(Model.SignatureMode != "None" ? "block" : "none");">
                                    <label asp-for="SignatureRequired" class="form-label mb-0 small"></label>
                                    <select asp-for="SignatureRequired" class="form-select form-select-sm">
                                        <option value="false">Optional</option>
                                        <option value="true">Required</option>
                                    </select>
                                </div>
                                <div class="col-3 signature-option" style="display: @(Model.SignatureMode != "None" ? "block" : "none");">
                                    <label asp-for="PrintSignatureOnTicket" class="form-label mb-0 small"></label>
                                    <select asp-for="PrintSignatureOnTicket" class="form-select form-select-sm">
                                        <option value="true">Yes</option>
                                        <option value="false">No</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row g-2 mb-1" id="signaturePadIdSection" style="display: @(Model.SignatureMode == "RemotePad" ? "flex" : "none");">
                                <div class="col-6">
                                    <label asp-for="SignaturePadId" class="form-label mb-0 small"></label>
                                    <input asp-for="SignaturePadId" class="form-control form-control-sm" placeholder="default" />
                                </div>
                                <div class="col-6 d-flex align-items-end">
                                    <span class="small text-muted">Open on the tablet:<br />
                                        <a id="signaturePadLink" href="#" target="_blank" rel="noopener"><code id="signaturePadUrl"></code></a>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: Fields -->
        <div class="tab-pane fade" id="tabFields">
            <div class="row g-3">
                <div class="col-lg-5 col-xl-4">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Standard Fields</strong>
                        </div>
                        <div class="card-body py-2">
                            <p class="small mb-2" style="color: var(--bw-text-muted);">
                                Hidden fields disappear from the weigh forms, grids, reports,
                                printed tickets, and kiosk prompts. Stored values are kept
                                but not shown. Weights, dates, and the ticket number are
                                always visible.
                            </p>
                            <table class="table table-sm align-middle mb-2">
                                <thead>
                                    <tr class="small text-muted"><th>Field</th><th style="width:38%;">Visibility</th><th style="width:22%;">Order</th></tr>
                                </thead>
                                <tbody>
                                    @{
                                        var visibilityRows = new (string Label, string Prop, bool Hidden, string OrderProp, int Order)[]
                                        {
                                            ("Customer", "HideCustomer", Model.HideCustomer, "FieldOrderCustomer", Model.FieldOrderCustomer),
                                            ("Carrier", "HideCarrier", Model.HideCarrier, "FieldOrderCarrier", Model.FieldOrderCarrier),
                                            ("Truck ID", "HideTruckId", Model.HideTruckId, "FieldOrderTruckId", Model.FieldOrderTruckId),
                                            ("Commodity", "HideCommodity", Model.HideCommodity, "FieldOrderCommodity", Model.FieldOrderCommodity),
                                            ("Location", "HideLocation", Model.HideLocation, "FieldOrderLocation", Model.FieldOrderLocation),
                                            ("Destination", "HideDestination", Model.HideDestination, "FieldOrderDestination", Model.FieldOrderDestination),
                                            ("Notes", "HideNotes", Model.HideNotes, "FieldOrderNotes", Model.FieldOrderNotes),
                                        };
                                    }
                                    @foreach (var (label, prop, hidden, orderProp, order) in visibilityRows)
                                    {
                                        <tr>
                                            <td class="fw-bold">@label</td>
                                            <td>
                                                <select name="@prop" id="@prop" class="form-select form-select-sm field-visibility">
                                                    <option value="false" selected="@(!hidden ? "selected" : null)">Visible</option>
                                                    <option value="true" selected="@(hidden ? "selected" : null)">Hidden</option>
                                                </select>
                                            </td>
                                            <td>
                                                <input type="number" name="@orderProp" id="@orderProp" value="@order" step="1"
                                                       class="form-control form-control-sm" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            <div class="form-text small">
                                Hiding <strong>Carrier</strong> also hides <strong>Truck ID</strong>
                                (trucks belong to carriers). While <strong>Retained Tare</strong>
                                is enabled, Carrier and Truck ID stay visible.
                                <strong>Order</strong> sorts fields on the weigh forms — standard
                                and custom fields share one scale, so a custom field can slot
                                between the built-ins. Printed-ticket layout is controlled by the
                                Ticket Designers.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 col-xl-6">
                    <div class="card">
                        <div class="card-header py-1 d-flex justify-content-between align-items-center" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Custom Fields</strong>
                            <button type="button" class="btn btn-outline-primary btn-sm py-0" id="addCustomFieldBtn">+ Add Field</button>
                        </div>
                        <div class="card-body py-2">
                            <p class="small mb-2" style="color: var(--bw-text-muted);">
                                Custom fields appear on the Weigh In / Weigh Out / Edit / Basic
                                Ticket forms, as grid columns, and on printed tickets. Dropdown
                                fields also get their own tab on Edit Tables. Order shares one
                                scale with the standard fields.
                            </p>
                            <table class="table table-sm align-middle mb-0" id="customFieldsTable">
                                <thead>
                                    <tr class="small text-muted">
                                        <th>Name</th><th>Type</th><th>Entry</th><th>On Ticket</th><th>Order</th><th>Active</th><th></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                            <div id="customFieldsEmpty" class="small text-muted" style="display:none;">No custom fields defined.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: Kiosk Prompts -->
        <div class="tab-pane fade" id="tabKioskPrompts">
            <div id="retainedTareRequiresPrompts" class="alert alert-info py-1 mb-2 small"
                 style="display: @(Model.UseRetainedTare ? "block" : "none");" role="alert">
                <i class="fa fa-circle-info"></i>
                <strong>Retained Tare requires</strong> the <em>Carrier</em> and <em>Truck&nbsp;ID</em>
                prompts to be enabled — they identify the truck so the stored tare can be
                recalled. Outbound prompts are disabled because the weigh-out is
                auto-completed via the recalled tare — they would never fire. Both rules
                stay in effect while Retained Tare is enabled in
                <strong>System &rarr; Options</strong>.
            </div>
            <div class="row">
                <div class="col-lg-7 col-xl-6">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Kiosk Prompts</strong>
                        </div>
                        <div class="card-body py-2">
                            @{
                                string Direction(bool inb, bool outb) =>
                                    inb ? "inbound" : (outb ? "outbound" : "neither");
                            }
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr class="small text-muted">
                                        <th>Prompt</th>
                                        <th class="text-center" style="width:50%;">When prompted</th>
                                        <th class="text-center">Allow Skip</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="fw-bold">
                                            Carrier
                                            <span id="PromptKioskCarrierLock" class="badge bg-info text-dark ms-1"
                                                  style="display: @(Model.UseRetainedTare ? "inline" : "none");"
                                                  title="Required while Retained Tare is enabled">required</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="kioskCarrierDir" id="carrierDirNone"
                                                       value="neither" @(!Model.PromptKioskCarrier ? "checked" : "") />
                                                <label class="form-check-label small" for="carrierDirNone">Neither</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="kioskCarrierDir" id="carrierDirInbound"
                                                       value="inbound" @(Model.PromptKioskCarrier ? "checked" : "") />
                                                <label class="form-check-label small" for="carrierDirInbound">Inbound</label>
                                            </div>
                                            <input type="hidden" asp-for="PromptKioskCarrier" id="PromptKioskCarrier" />
                                        </td>
                                        <td class="text-center">
                                            <input asp-for="AllowSkipCarrier" class="form-check-input" id="AllowSkipCarrier" />
                                        </td>
                                    </tr>
                                    <tr id="truckIdPromptSection" style="display: @(Model.PromptKioskCarrier ? "table-row" : "none");">
                                        <td class="fw-bold">
                                            Truck ID
                                            <span id="PromptKioskTruckIdLock" class="badge bg-info text-dark ms-1"
                                                  style="display: @(Model.UseRetainedTare ? "inline" : "none");"
                                                  title="Required while Retained Tare is enabled">required</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="kioskTruckDir" id="truckDirNone"
                                                       value="neither" @(!Model.PromptKioskTruckId ? "checked" : "") />
                                                <label class="form-check-label small" for="truckDirNone">Neither</label>
                                            </div>
                                            <div class="form-check form-check-inline">
                                                <input class="form-check-input" type="radio" name="kioskTruckDir" id="truckDirInbound"
                                                       value="inbound" @(Model.PromptKioskTruckId ? "checked" : "") />
                                                <label class="form-check-label small" for="truckDirInbound">Inbound</label>
                                            </div>
                                            <input type="hidden" asp-for="PromptKioskTruckId" id="PromptKioskTruckId" />
                                        </td>
                                        <td class="text-center">
                                            <input asp-for="AllowSkipTruckId" class="form-check-input" id="AllowSkipTruckId" />
                                        </td>
                                    </tr>
                                    @{
                                        var splitPrompts = new[]
                                        {
                                            ("Commodity", "kioskCommodityDir", "PromptKioskCommodityOnInbound", "PromptKioskCommodityOnOutbound", "AllowSkipCommodity",
                                                Direction(Model.PromptKioskCommodityOnInbound, Model.PromptKioskCommodityOnOutbound),
                                                Model.PromptKioskCommodityOnInbound, Model.PromptKioskCommodityOnOutbound, Model.AllowSkipCommodity),
                                            ("Customer", "kioskCustomerDir", "PromptKioskCustomerOnInbound", "PromptKioskCustomerOnOutbound", "AllowSkipCustomer",
                                                Direction(Model.PromptKioskCustomerOnInbound, Model.PromptKioskCustomerOnOutbound),
                                                Model.PromptKioskCustomerOnInbound, Model.PromptKioskCustomerOnOutbound, Model.AllowSkipCustomer),
                                            ("Location", "kioskLocationDir", "PromptKioskLocationOnInbound", "PromptKioskLocationOnOutbound", "AllowSkipLocation",
                                                Direction(Model.PromptKioskLocationOnInbound, Model.PromptKioskLocationOnOutbound),
                                                Model.PromptKioskLocationOnInbound, Model.PromptKioskLocationOnOutbound, Model.AllowSkipLocation),
                                            ("Destination", "kioskDestDir", "PromptKioskDestinationOnInbound", "PromptKioskDestinationOnOutbound", "AllowSkipDestination",
                                                Direction(Model.PromptKioskDestinationOnInbound, Model.PromptKioskDestinationOnOutbound),
                                                Model.PromptKioskDestinationOnInbound, Model.PromptKioskDestinationOnOutbound, Model.AllowSkipDestination),
                                        };
                                    }
                                    @foreach (var (label, group, inField, outField, skipField, currentDir, inVal, outVal, skipVal) in splitPrompts)
                                    {
                                        <tr>
                                            <td class="fw-bold">@label</td>
                                            <td class="text-center">
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="@group" id="@(group)None"
                                                           value="neither" @(currentDir == "neither" ? "checked" : "") />
                                                    <label class="form-check-label small" for="@(group)None">Neither</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="@group" id="@(group)Inbound"
                                                           value="inbound" @(currentDir == "inbound" ? "checked" : "") />
                                                    <label class="form-check-label small" for="@(group)Inbound">Inbound</label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="@group" id="@(group)Outbound"
                                                           value="outbound" @(currentDir == "outbound" ? "checked" : "") />
                                                    <label class="form-check-label small" for="@(group)Outbound">Outbound</label>
                                                </div>
                                                <input type="hidden" name="@inField" id="@inField" value="@inVal.ToString().ToLower()" />
                                                <input type="hidden" name="@outField" id="@outField" value="@outVal.ToString().ToLower()" />
                                            </td>
                                            <td class="text-center">
                                                <input type="checkbox" name="@skipField" id="@skipField" class="form-check-input" value="true" @(skipVal ? "checked" : "") />
                                                <input type="hidden" name="@skipField" value="false" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            <hr class="my-2" />
                            <div class="form-check">
                                <input asp-for="HideKioskOnScreenButtons" class="form-check-input" id="HideKioskOnScreenButtons" />
                                <label asp-for="HideKioskOnScreenButtons" class="form-check-label small"></label>
                                <div class="form-text small">
                                    Hides the numpad, Cancel, Skip, Select, and Done buttons on
                                    the kiosk. Operator drives with a physical keyboard or
                                    barcode scanner. The New Load / Enter Ticket buttons
                                    remain visible.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: Users & Security -->
        <div class="tab-pane fade" id="tabSecurity">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Users &amp; Security</strong>
                        </div>
                        <div class="card-body py-2">
                            <a asp-controller="Account" asp-action="Users" class="btn btn-outline-primary btn-sm w-100 mb-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="me-1">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                                </svg>
                                Manage Users
                            </a>
                            <div class="small" style="color: var(--bw-text-muted);">
                                <p class="mb-1"><strong>Kiosk PIN:</strong> <code id="kioskPinDisplay">@Model.KioskCode</code></p>
                                <p class="mb-1">When login is enabled, kiosks need the PIN to access the scale screen. Pass it as a URL parameter:</p>
                                <code class="d-block mb-1" style="font-size: 0.75rem; word-break: break-all;">https://your-server/Kiosk?pin=<span id="kioskPinUrl">@Model.KioskCode</span></code>
                                <p class="mb-0">The PIN is stored as a cookie after the first visit so subsequent requests don't need it.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: Ticket Designers -->
        <div class="tab-pane fade" id="tabDesigners">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Ticket Designers</strong>
                        </div>
                        <div class="card-body py-2">
                            <p class="small mb-2" style="color: var(--bw-text-muted);">Edit ticket layouts. Changes are saved and used when printing.</p>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <a asp-controller="Ticket" asp-action="Designer" asp-route-reportName="TicketReport"
                                   class="btn btn-outline-primary btn-sm d-flex align-items-center gap-1 flex-grow-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z" />
                                    </svg>
                                    <span class="fw-bold">Completed Ticket</span>
                                </a>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <a asp-controller="Ticket" asp-action="Designer" asp-route-reportName="KioskTicketReport"
                                   class="btn btn-outline-primary btn-sm d-flex align-items-center gap-1 flex-grow-1">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 14.625v5.25h6v-5.25h-6z" />
                                    </svg>
                                    <span class="fw-bold">Kiosk Inbound Ticket</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>Reset Ticket Layouts</strong>
                        </div>
                        <div class="card-body py-2">
                            <p class="small mb-2" style="color: var(--bw-text-muted);">Reset ticket layouts to default format. Customizations will be lost.</p>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-outline-danger btn-sm"
                                        onclick="showConfirmModal('Reset Completed Ticket', 'Reset Completed Ticket to default format?\n\nAny customizations will be lost.', 'resetTicketForm', 'btn-danger')">
                                    Reset Completed Ticket
                                </button>
                                <button type="button" class="btn btn-outline-danger btn-sm"
                                        onclick="showConfirmModal('Reset Kiosk Ticket', 'Reset Kiosk Inbound Ticket to default format?\n\nAny customizations will be lost.', 'resetKioskTicketForm', 'btn-danger')">
                                    Reset Kiosk Ticket
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: API -->
        <div class="tab-pane fade" id="tabApi">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                            <strong>API Documentation</strong>
                        </div>
                        <div class="card-body py-2">
                            <div class="mb-2">
                                <label asp-for="ApiDefinitionPin" class="form-label mb-0 small"></label>
                                <div class="d-flex gap-2 align-items-center">
                                    <input asp-for="ApiDefinitionPin" class="form-control form-control-sm" maxlength="20" id="ApiDefinitionPin" style="max-width: 200px;" />
                                    <a id="swaggerLink" href="/swagger?pin=@Model.ApiDefinitionPin" target="_blank" class="btn btn-outline-info btn-sm text-nowrap">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1">
                                            <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1 1 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4 4 0 0 1-.128-1.287z"/>
                                            <path d="M6.586 4.672A3 3 0 0 0 7.414 9.5l.775-.776a2 2 0 0 1-.896-3.346L9.12 3.55a2 2 0 1 1 2.83 2.83l-.793.792c.112.42.155.855.128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243z"/>
                                        </svg>
                                        Open Swagger
                                    </a>
                                </div>
                                <small class="text-muted">This PIN is required to access the Swagger API documentation page.</small>
                            </div>
                            <div class="small mt-2" style="color: var(--bw-text-muted);">
                                <p class="mb-1"><strong>Swagger URL:</strong></p>
                                <code class="d-block mb-1" style="font-size: 0.75rem; word-break: break-all;">https://your-server/swagger?pin=<span id="apiPinUrl">@Model.ApiDefinitionPin</span></code>
                                <p class="mb-0">The PIN is stored as a cookie after the first visit so subsequent requests don't need it.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TAB: Database -->
        @if (ViewBag.ShowResetDatabase == true)
        {
            <div class="tab-pane fade" id="tabDatabase">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
                                <strong>Database</strong>
                            </div>
                            <div class="card-body py-2">
                                <p class="small mb-2" style="color: var(--bw-text-muted);">Clear all data or reset with sample test data. Settings are preserved.</p>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-outline-warning btn-sm" onclick="showConfirmModal('Load Test Data', 'This will DELETE all existing data and load test data.', 'loadTestDataForm', 'btn-warning')">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="me-1">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                                        </svg>
                                        Load Test Data
                                    </button>
                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="showConfirmModal('Clear Database', 'This will DELETE all transactions, customers, carriers, commodities, locations, destinations, and trucks.\n\nThis cannot be undone.', 'clearDatabaseForm', 'btn-danger')">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="me-1">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                                        </svg>
                                        Clear Database
                                    </button>
                                </div>
                                <p class="small text-muted mt-2 mb-0">
                                    <em>Hide this section by setting <code>"ShowResetDatabase": false</code> in appsettings.json</em>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* No Save button — every change auto-saves (see the auto-save script). *@
</form>

<!-- Setup-wide notice modal (replaces native alert() calls) -->
<div class="modal fade" id="setupAlertModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Notice</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body small" id="setupAlertBody"></div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-primary btn-sm" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

<!-- Hidden forms for reset/database operations (outside main form) -->
<form asp-action="ResetTicket" method="post" id="resetTicketForm" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="reportName" value="TicketReport" />
</form>
<form asp-action="ResetTicket" method="post" id="resetKioskTicketForm" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="reportName" value="KioskTicketReport" />
</form>
<form asp-action="LoadTestData" method="post" id="loadTestDataForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>
<form asp-action="ClearDatabase" method="post" id="clearDatabaseForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="confirmModalTitle">Confirm Operation</h6>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-3" id="confirmModalBody"></div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm" id="confirmModalBtn" onclick="confirmModalSubmit()">Confirm</button>
            </div>
        </div>
    </div>
</div>

<!-- Custom Field editor modal (add + edit) -->
<div class="modal fade" id="customFieldModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="cfModalTitle">Add Custom Field</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-2">
                <div class="mb-2">
                    <label class="form-label mb-0 small">Field Name</label>
                    <input type="text" id="cfName" class="form-control form-control-sm" maxlength="50" />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <label class="form-label mb-0 small">Type</label>
                        <select id="cfType" class="form-select form-select-sm">
                            <option value="Text">Text</option>
                            <option value="Integer">Integer</option>
                            <option value="Real">Decimal</option>
                        </select>
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Entry</label>
                        <select id="cfRequired" class="form-select form-select-sm">
                            <option value="false">Optional</option>
                            <option value="true">Required</option>
                        </select>
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Sort Order</label>
                        <input type="number" id="cfSortOrder" class="form-control form-control-sm" value="0" step="1" />
                    </div>
                </div>
                <div class="mb-2" id="cfListSection" style="display:none;">
                    <label class="form-label mb-0 small">Dropdown values <span class="text-muted">(optional — one per line; leave empty for free text)</span></label>
                    <textarea id="cfListValues" class="form-control form-control-sm" rows="5"
                              placeholder="Value 1&#10;Value 2&#10;Value 3"></textarea>
                    <div class="form-text small">Add, change, delete, or reorder lines to manage the list. Values already saved on tickets are kept even if removed here.</div>
                </div>
                <div class="row g-2 mb-2" id="cfNumberSection" style="display:none;">
                    <div class="col-4">
                        <label class="form-label mb-0 small">Min <span class="text-muted">(optional)</span></label>
                        <input type="number" id="cfMinValue" class="form-control form-control-sm" step="any" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Max <span class="text-muted">(optional)</span></label>
                        <input type="number" id="cfMaxValue" class="form-control form-control-sm" step="any" />
                    </div>
                    <div class="col-4" id="cfPrecisionCol">
                        <label class="form-label mb-0 small">Decimals <span class="text-muted">(0–6)</span></label>
                        <input type="number" id="cfPrecision" class="form-control form-control-sm" min="0" max="6" step="1" />
                    </div>
                </div>
                <div class="d-flex gap-4 flex-wrap">
                    <div class="form-check">
                        <input type="checkbox" id="cfShowOnTicket" class="form-check-input" checked />
                        <label class="form-check-label small" for="cfShowOnTicket">Show on printed ticket</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" id="cfActive" class="form-check-input" checked />
                        <label class="form-check-label small" for="cfActive">Active</label>
                    </div>
                    <div class="form-check" title="Numbers and dropdown lists only — free text can't prompt at the kiosk">
                        <input type="checkbox" id="cfPromptAtKiosk" class="form-check-input" />
                        <label class="form-check-label small" for="cfPromptAtKiosk">Ask at kiosk (weigh-in)</label>
                    </div>
                </div>
                <div id="cfModalError" class="small text-danger mt-2" style="display:none;"></div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="cfSaveBtn">Save Field</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/signalr/signalr.min.js"></script>
<script>
    // --- Bootstrap notice helper (replaces window.alert for in-form messages) ---
    function showSetupAlert(message) {
        document.getElementById('setupAlertBody').textContent = message;
        var modalEl = document.getElementById('setupAlertModal');
        var modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
        modal.show();
    }

    // --- Tab persistence: remember which tab is active and re-activate after save ---
    (function () {
        // A ?tab= query wins (used by the theme-change reload); otherwise the
        // server-provided value (TempData after a classic post) or the default.
        var queryTab = new URLSearchParams(window.location.search).get('tab');
        if (queryTab && !/^[A-Za-z0-9_-]+$/.test(queryTab)) queryTab = null;
        if (queryTab && document.querySelector('[data-bs-target="#' + queryTab + '"]')) {
            document.getElementById('activeTabField').value = queryTab;
        }
        var initial = document.getElementById('activeTabField').value || 'tabCompany';
        var btn = document.querySelector('[data-bs-target="#' + initial + '"]');
        if (btn && !btn.classList.contains('active')) {
            new bootstrap.Tab(btn).show();
        }
        // When the user clicks a tab, record it so the form post carries it.
        document.querySelectorAll('[data-bs-toggle="tab"]').forEach(function (b) {
            b.addEventListener('shown.bs.tab', function (e) {
                var target = (e.target.getAttribute('data-bs-target') || '').replace('#', '');
                if (target) document.getElementById('activeTabField').value = target;
            });
        });
    })();

    // --- Auto-save: every change posts the whole form (no Save button) ---
    // Saves fire on 'change' (blur for text inputs, immediate for selects,
    // checkboxes, and radios) so a half-typed Ticket Number or PIN is never
    // saved mid-keystroke. A short debounce coalesces the cascades from the
    // rule-sync scripts (e.g. Retained Tare forcing several controls at once).
    var setupForm = document.getElementById('setupForm');
    var saveStatus = document.getElementById('saveStatus');
    var saveTimer = null;
    var savePending = false;
    var saveStatusTimer = null;
    // Theme only takes effect when the page re-renders, so a theme change
    // reloads the page after its save lands (back onto the same tab).
    var reloadAfterSave = false;

    function showSaveStatus(text, isError) {
        clearTimeout(saveStatusTimer);
        saveStatus.textContent = text;
        saveStatus.style.display = 'block';
        saveStatus.style.color = isError ? '#dc3545' : 'var(--bw-text)';
        if (!isError && text !== 'Saving…') {
            saveStatusTimer = setTimeout(function () { saveStatus.style.display = 'none'; }, 2000);
        }
    }

    function autoSave() {
        if (savePending) { scheduleAutoSave(); return; } // serialize overlapping saves
        savePending = true;
        showSaveStatus('Saving…', false);
        var hadIconFile = document.getElementById('iconFileInput').files.length > 0;
        var removeCbEl = document.getElementById('removeIconCb');
        fetch(setupForm.action || window.location.pathname, {
            method: 'POST',
            body: new FormData(setupForm),
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        }).then(function (r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            // Don't re-send one-shot icon operations on the next save.
            if (hadIconFile) document.getElementById('iconFileInput').value = '';
            if (removeCbEl && removeCbEl.checked) removeCbEl.checked = false;
            if (reloadAfterSave) {
                showSaveStatus('Saved — applying theme…', false);
                var tab = document.getElementById('activeTabField').value || 'tabCompany';
                window.location.replace(window.location.pathname + '?tab=' + encodeURIComponent(tab));
                return;
            }
            showSaveStatus('All changes saved ✓', false);
        }).catch(function () {
            showSaveStatus('Save failed — check connection and change a setting to retry', true);
        }).finally(function () {
            savePending = false;
        });
    }

    function scheduleAutoSave() {
        clearTimeout(saveTimer);
        saveTimer = setTimeout(autoSave, 400);
    }

    setupForm.addEventListener('change', function (e) {
        if (!e.target || !e.target.matches('input, select, textarea')) return;
        if (e.target.id === 'Theme') reloadAfterSave = true;
        scheduleAutoSave();
    });

    // --- Icon preview ---
    document.getElementById('iconFileInput').addEventListener('change', function (e) {
        var file = e.target.files[0];
        if (file) {
            var reader = new FileReader();
            reader.onload = function (ev) {
                document.getElementById('iconPreview').src = ev.target.result;
            };
            reader.readAsDataURL(file);
            var cb = document.getElementById('removeIconCb');
            if (cb) cb.checked = false;
        }
    });

    var removeCb = document.getElementById('removeIconCb');
    if (removeCb) {
        removeCb.addEventListener('change', function () {
            var preview = document.getElementById('iconPreview');
            if (this.checked) {
                preview.dataset.originalSrc = preview.src;
                preview.src = '/images/default-icon.svg';
            } else {
                preview.src = preview.dataset.originalSrc || '/api/setup/icon';
            }
        });
    }

    // --- QB Service Check ---
    document.getElementById('UseQuickBooks').addEventListener('change', function () {
        var el = document.getElementById('qbCheckSection');
        el.style.display = this.value === 'true' ? 'flex' : 'none';
    });

    document.getElementById('SavePicture').addEventListener('change', function () {
        var el = document.getElementById('cameraManageSection');
        el.style.display = this.value === 'true' ? 'flex' : 'none';
    });

    // --- Driver Signature options ---
    function syncSignatureSections() {
        var mode = document.getElementById('SignatureMode').value;
        document.querySelectorAll('.signature-option').forEach(function (el) {
            el.style.display = mode !== 'None' ? 'block' : 'none';
        });
        document.getElementById('signaturePadIdSection').style.display = mode === 'RemotePad' ? 'flex' : 'none';
        var padId = document.getElementById('SignaturePadId').value || 'default';
        var padUrl = window.location.origin + '/SignaturePad?pad-id=' + encodeURIComponent(padId);
        document.getElementById('signaturePadUrl').textContent = padUrl;
        document.getElementById('signaturePadLink').href = padUrl;
    }
    document.getElementById('SignatureMode').addEventListener('change', syncSignatureSections);
    document.getElementById('SignaturePadId').addEventListener('input', syncSignatureSections);
    syncSignatureSections();

    // --- Standard field visibility rules (mirror the server-side forcing) ---
    (function () {
        var carrier = document.getElementById('HideCarrier');
        var truck = document.getElementById('HideTruckId');
        var retained = document.getElementById('UseRetainedTare');

        function syncVisibilityRules() {
            var rtOn = retained && retained.value === 'true';
            if (rtOn) {
                carrier.value = 'false';
                truck.value = 'false';
            }
            carrier.disabled = rtOn;
            if (carrier.value === 'true') truck.value = 'true';
            truck.disabled = rtOn || carrier.value === 'true';
        }
        carrier.addEventListener('change', syncVisibilityRules);
        truck.addEventListener('change', syncVisibilityRules);
        if (retained) retained.addEventListener('change', syncVisibilityRules);
        syncVisibilityRules();
    })();

    // --- Custom Fields CRUD (saves immediately via /api/customfields) ---
    (function () {
        var editingId = null;
        var loadedFields = [];

        // Default a NEW field's order to the end of the shared scale: after
        // every existing custom field and after the standard fields' orders.
        function nextSortOrder() {
            var max = 0;
            loadedFields.forEach(function (f) { if (f.sortOrder > max) max = f.sortOrder; });
            document.querySelectorAll('input[name^="FieldOrder"]').forEach(function (el) {
                var v = parseInt(el.value) || 0;
                if (v > max) max = v;
            });
            return max + 10;
        }

        function esc(s) {
            return String(s ?? '').replace(/[&<>"']/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
            });
        }

        function typeLabel(f) {
            var t = f.fieldType === 'Real' ? 'Decimal' : f.fieldType;
            if (f.fieldType === 'Text' && f.listValues) t += ' (List)';
            return t;
        }

        // Show the dropdown-list editor for Text, the min/max (+ decimals for
        // Decimal) inputs for number types. The kiosk checkbox only applies to
        // constrained inputs: numbers, or Text with a non-empty dropdown list.
        function syncCfTypeSections() {
            var t = document.getElementById('cfType').value;
            document.getElementById('cfListSection').style.display = t === 'Text' ? 'block' : 'none';
            document.getElementById('cfNumberSection').style.display = t === 'Text' ? 'none' : 'flex';
            document.getElementById('cfPrecisionCol').style.display = t === 'Real' ? 'block' : 'none';
            var kiosk = document.getElementById('cfPromptAtKiosk');
            var eligible = t !== 'Text' || document.getElementById('cfListValues').value.trim() !== '';
            kiosk.disabled = !eligible;
            if (!eligible) kiosk.checked = false;
        }
        document.getElementById('cfType').addEventListener('change', syncCfTypeSections);
        document.getElementById('cfListValues').addEventListener('input', syncCfTypeSections);

        function loadCustomFields() {
            fetch('/api/customfields').then(function (r) { return r.json(); }).then(function (fields) {
                loadedFields = fields;
                var tbody = document.querySelector('#customFieldsTable tbody');
                tbody.innerHTML = '';
                document.getElementById('customFieldsEmpty').style.display = fields.length ? 'none' : 'block';
                fields.forEach(function (f) {
                    var tr = document.createElement('tr');
                    if (!f.active) tr.style.opacity = '0.5';
                    tr.innerHTML =
                        '<td class="fw-bold">' + esc(f.name) + '</td>' +
                        '<td>' + typeLabel(f) + '</td>' +
                        '<td>' + (f.required ? '<span class="badge bg-danger">Required</span>' : 'Optional') + '</td>' +
                        '<td>' + (f.showOnTicket ? 'Yes' : 'No') + '</td>' +
                        '<td>' + f.sortOrder + '</td>' +
                        '<td>' + (f.active ? 'Yes' : 'No') + '</td>' +
                        '<td class="text-end text-nowrap">' +
                        '<button type="button" class="btn btn-outline-secondary btn-sm py-0 me-1 cf-edit">Edit</button>' +
                        '<button type="button" class="btn btn-outline-danger btn-sm py-0 cf-delete">Delete</button></td>';
                    tr.querySelector('.cf-edit').addEventListener('click', function () { openModal(f); });
                    tr.querySelector('.cf-delete').addEventListener('click', function () { deleteField(f); });
                    tbody.appendChild(tr);
                });
            });
        }

        function openModal(field) {
            editingId = field ? field.id : null;
            document.getElementById('cfModalTitle').textContent = field ? 'Edit Custom Field' : 'Add Custom Field';
            document.getElementById('cfName').value = field ? field.name : '';
            document.getElementById('cfType').value = field ? field.fieldType : 'Text';
            document.getElementById('cfRequired').value = field && field.required ? 'true' : 'false';
            document.getElementById('cfSortOrder').value = field ? field.sortOrder : nextSortOrder();
            document.getElementById('cfShowOnTicket').checked = field ? field.showOnTicket : true;
            document.getElementById('cfActive').checked = field ? field.active : true;
            document.getElementById('cfListValues').value = field && field.listValues ? field.listValues : '';
            document.getElementById('cfMinValue').value = field && field.minValue != null ? field.minValue : '';
            document.getElementById('cfMaxValue').value = field && field.maxValue != null ? field.maxValue : '';
            document.getElementById('cfPrecision').value = field && field.precision != null ? field.precision : '';
            document.getElementById('cfPromptAtKiosk').checked = field ? !!field.promptAtKiosk : false;
            document.getElementById('cfModalError').style.display = 'none';
            syncCfTypeSections();
            new bootstrap.Modal('#customFieldModal').show();
        }

        function deleteField(f) {
            if (!confirm('Delete "' + f.name + '"? Values already saved on tickets will be removed. ' +
                         'To keep history, set the field to inactive instead.')) return;
            fetch('/api/customfields/' + f.id, { method: 'DELETE' }).then(loadCustomFields);
        }

        document.getElementById('addCustomFieldBtn').addEventListener('click', function () { openModal(null); });

        document.getElementById('cfSaveBtn').addEventListener('click', function () {
            var body = {
                id: editingId || 0,
                name: document.getElementById('cfName').value.trim(),
                fieldType: document.getElementById('cfType').value,
                required: document.getElementById('cfRequired').value === 'true',
                sortOrder: parseInt(document.getElementById('cfSortOrder').value) || 0,
                showOnTicket: document.getElementById('cfShowOnTicket').checked,
                active: document.getElementById('cfActive').checked,
                listValues: document.getElementById('cfListValues').value || null,
                minValue: document.getElementById('cfMinValue').value === '' ? null : parseFloat(document.getElementById('cfMinValue').value),
                maxValue: document.getElementById('cfMaxValue').value === '' ? null : parseFloat(document.getElementById('cfMaxValue').value),
                precision: document.getElementById('cfPrecision').value === '' ? null : parseInt(document.getElementById('cfPrecision').value),
                promptAtKiosk: document.getElementById('cfPromptAtKiosk').checked
            };
            fetch(editingId ? '/api/customfields/' + editingId : '/api/customfields', {
                method: editingId ? 'PUT' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            }).then(function (r) {
                if (!r.ok) return r.json().then(function (e) { throw new Error(e.error || 'Save failed.'); });
                bootstrap.Modal.getInstance(document.getElementById('customFieldModal')).hide();
                loadCustomFields();
            }).catch(function (err) {
                var el = document.getElementById('cfModalError');
                el.textContent = err.message;
                el.style.display = 'block';
            });
        });

        loadCustomFields();
    })();

    // Single source of truth for whether each "Allow Skip" checkbox is enabled.
    // A prompt set to Neither will never fire, so its skip flag is meaningless;
    // unchecked + disabled. Carrier/Truck additionally have skip locked off
    // whenever Retained Tare is on (handled here too).
    var SKIP_RULES = [
        { group: 'kioskCarrierDir',   skip: 'AllowSkipCarrier',     rtForcesOff: true  },
        { group: 'kioskTruckDir',     skip: 'AllowSkipTruckId',     rtForcesOff: true  },
        { group: 'kioskCommodityDir', skip: 'AllowSkipCommodity',   rtForcesOff: false },
        { group: 'kioskCustomerDir',  skip: 'AllowSkipCustomer',    rtForcesOff: false },
        { group: 'kioskLocationDir',  skip: 'AllowSkipLocation',    rtForcesOff: false },
        { group: 'kioskDestDir',      skip: 'AllowSkipDestination', rtForcesOff: false }
    ];
    function syncAllowSkipState() {
        var rtOn = isRetainedTareOn();
        SKIP_RULES.forEach(function (row) {
            var skip = document.getElementById(row.skip);
            if (!skip) return;
            var checkedRadio = document.querySelector('input[name="' + row.group + '"]:checked');
            var dir = checkedRadio ? checkedRadio.value : 'neither';
            var force = dir === 'neither' || (row.rtForcesOff && rtOn);
            if (force) {
                skip.checked = false;
                skip.disabled = true;
            } else {
                skip.disabled = false;
            }
        });
    }

    function applyRetainedTareLocks(on) {
        // Visual lock + force values for Carrier/Truck while Retained Tare is on:
        //   - Direction radios pinned to Inbound (Neither disabled too)
        //   - AllowSkip — handled by syncAllowSkipState below
        //   - "required" badges + tab notice visible
        // For the splittable prompts (Commodity / Customer / Location /
        // Destination), the Outbound radio is disabled — the auto-completed
        // weigh-out under Retained Tare never fires those prompts. Any
        // Outbound selection is bumped to Inbound so the prompt still happens
        // somewhere reasonable.
        if (on) {
            var carrierInbound = document.getElementById('carrierDirInbound');
            var truckInbound   = document.getElementById('truckDirInbound');
            if (carrierInbound && !carrierInbound.checked) { carrierInbound.checked = true; carrierInbound.dispatchEvent(new Event('change')); }
            if (truckInbound && !truckInbound.checked)     { truckInbound.checked = true;   truckInbound.dispatchEvent(new Event('change')); }
        }
        // Disable the "Neither" radio so it can't even be clicked while RT is on.
        ['carrierDirNone', 'truckDirNone'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.disabled = on;
        });
        // Outbound radios for splittable prompts: disable while RT is on; if
        // currently checked, push selection to Inbound.
        ['kioskCommodityDirOutbound', 'kioskCustomerDirOutbound', 'kioskLocationDirOutbound', 'kioskDestDirOutbound'].forEach(function (id) {
            var outRadio = document.getElementById(id);
            if (!outRadio) return;
            outRadio.disabled = on;
            if (on && outRadio.checked) {
                var inboundId = id.replace(/Outbound$/, 'Inbound');
                var inboundRadio = document.getElementById(inboundId);
                if (inboundRadio) { inboundRadio.checked = true; inboundRadio.dispatchEvent(new Event('change')); }
            }
        });
        ['PromptKioskCarrierLock', 'PromptKioskTruckIdLock'].forEach(function (id) {
            var el = document.getElementById(id);
            if (el) el.style.display = on ? 'inline' : 'none';
        });
        var notice = document.getElementById('retainedTareRequiresPrompts');
        if (notice) notice.style.display = on ? 'block' : 'none';
        syncAllowSkipState();
    }

    document.getElementById('UseRetainedTare').addEventListener('change', function () {
        var on = this.value === 'true';
        document.getElementById('retainedTareManageSection').style.display = on ? 'flex' : 'none';
        var autoClear = document.getElementById('autoClearStaleSection');
        if (autoClear) autoClear.style.display = on ? 'block' : 'none';
        applyRetainedTareLocks(on);
    });
    // Apply on initial load too — covers the case where the page renders with
    // Retained Tare already enabled.
    applyRetainedTareLocks(document.getElementById('UseRetainedTare').value === 'true');

    function isRetainedTareOn() {
        var sel = document.getElementById('UseRetainedTare');
        return sel && sel.value === 'true';
    }
    // Defense in depth: if a stale cached page somehow lets a user pick Neither
    // on Carrier/Truck, snap back and surface a Bootstrap notice.
    [['kioskCarrierDir', 'carrierDirInbound'], ['kioskTruckDir', 'truckDirInbound']].forEach(function (pair) {
        document.querySelectorAll('input[name="' + pair[0] + '"]').forEach(function (r) {
            r.addEventListener('change', function () {
                if (this.value === 'neither' && isRetainedTareOn()) {
                    var inboundRadio = document.getElementById(pair[1]);
                    if (inboundRadio) { inboundRadio.checked = true; inboundRadio.dispatchEvent(new Event('change')); }
                    showSetupAlert('Carrier and Truck ID prompts are required while Retained Tare is enabled. Turn off Retained Tare first to disable them.');
                }
            });
        });
    });

    document.getElementById('RemotePrintMode').addEventListener('change', function () {
        var el = document.getElementById('printerManageSection');
        el.style.display = this.value === 'RemotePrinter' ? 'flex' : 'none';
    });

    function checkQBService() {
        var btn = document.getElementById('btnCheckQBService');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>';
        var conn = new signalR.HubConnectionBuilder().withUrl('/scaleHub').build();
        conn.start().then(function () {
            return conn.invoke('CheckQBServiceConnected');
        }).then(function (connected) {
            conn.stop();
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-plug"></i> Check';
            var container = document.getElementById('qb-status-alert');
            if (!container) {
                container = document.createElement('div');
                container.id = 'qb-status-alert';
                btn.parentElement.parentElement.after(container);
            }
            if (connected) {
                container.innerHTML = '<div class="alert alert-success alert-dismissible fade show py-1 px-2 small mt-1" role="alert">' +
                    '<i class="fa fa-check-circle"></i> QuickBooks Sync Service is connected.' +
                    '<button type="button" class="btn-close btn-close-sm p-1" data-bs-dismiss="alert"></button></div>';
            } else {
                container.innerHTML = '<div class="alert alert-danger alert-dismissible fade show py-1 px-2 small mt-1" role="alert">' +
                    '<i class="fa fa-times-circle"></i> QuickBooks Sync Service is not connected. Please start the QBSyncService.' +
                    '<button type="button" class="btn-close btn-close-sm p-1" data-bs-dismiss="alert"></button></div>';
            }
        }).catch(function (err) {
            conn.stop();
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-plug"></i> Check';
        });
    }

    // --- Populate Scale dropdown via SignalR ---
    (function () {
        var savedScaleId = '@(Model.ScaleId ?? "")';
        var scaleSelect = document.getElementById('ScaleId');
        var scaleConn = new signalR.HubConnectionBuilder().withUrl('/scaleHub').build();

        scaleConn.on('ScaleServiceReady', function (data) {
            populateScales(data);
        });

        scaleConn.on('ScaleListReceived', function (data) {
            populateScales(data);
        });

        function populateScales(data) {
            var currentVal = scaleSelect.value || savedScaleId;
            var options = '<option value="">-- None --</option>';
            var scales = data.scales || [];
            scales.forEach(function (s) {
                var val = (data.serviceId || 'default') + ':' + s.scaleId;
                var label = s.displayName || s.scaleId;
                options += '<option value="' + val + '">' + label + '</option>';
            });
            scaleSelect.innerHTML = options;
            scaleSelect.value = currentVal;
        }

        scaleConn.start().then(function () {
            return scaleConn.invoke('RequestScaleList');
        }).catch(function (err) {
            console.log('Scale SignalR error:', err);
        });
    })();

    // --- Dynamic visibility toggles ---
    document.getElementById('UseLogin').addEventListener('change', function () {
        var useLogin = this.value === 'true';
        document.getElementById('kioskCodeSection').style.display = useLogin ? 'block' : 'none';
        document.getElementById('tabSecurityNav').style.display = useLogin ? 'block' : 'none';
    });

    var kioskCodeInput = document.querySelector('input[name="KioskCode"]');
    if (kioskCodeInput) {
        kioskCodeInput.addEventListener('input', function () {
            var pin = this.value || '12345';
            var pinDisplay = document.getElementById('kioskPinDisplay');
            var pinUrl = document.getElementById('kioskPinUrl');
            if (pinDisplay) pinDisplay.textContent = pin;
            if (pinUrl) pinUrl.textContent = pin;
        });
    }

    // API Definition PIN live update
    var apiPinInput = document.getElementById('ApiDefinitionPin');
    if (apiPinInput) {
        apiPinInput.addEventListener('input', function () {
            var pin = this.value || '12345';
            document.getElementById('apiPinUrl').textContent = pin;
            document.getElementById('swaggerLink').href = '/swagger?pin=' + encodeURIComponent(pin);
        });
    }

    document.getElementById('KioskCount').addEventListener('change', function () {
        var hasKiosk = parseInt(this.value) > 0;
        document.getElementById('tabKioskPromptsNav').style.display = hasKiosk ? 'block' : 'none';
        document.getElementById('kioskDarkModeSection').style.display = hasKiosk ? 'block' : 'none';
    });

    // ===== Kiosk Prompt radios =====
    // Carrier and Truck ID radios are 2-state (Neither / Inbound) — they only
    // gate a single underlying bool, so map directly to the hidden input.
    function bindBoolDirectionRadio(groupName, hiddenId) {
        document.querySelectorAll('input[name="' + groupName + '"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                document.getElementById(hiddenId).value = (this.value === 'inbound').toString().toLowerCase();
                if (groupName === 'kioskCarrierDir') {
                    // Truck ID row visibility tracks the carrier prompt.
                    document.getElementById('truckIdPromptSection').style.display =
                        this.value === 'inbound' ? 'table-row' : 'none';
                }
                syncAllowSkipState();
            });
        });
    }
    bindBoolDirectionRadio('kioskCarrierDir', 'PromptKioskCarrier');
    bindBoolDirectionRadio('kioskTruckDir',   'PromptKioskTruckId');

    // Splittable prompts (Commodity, Customer, Location, Destination) write
    // separate OnInbound / OnOutbound hidden bools.
    function bindSplitDirectionRadio(groupName, inHiddenId, outHiddenId) {
        document.querySelectorAll('input[name="' + groupName + '"]').forEach(function (radio) {
            radio.addEventListener('change', function () {
                document.getElementById(inHiddenId).value  = (this.value === 'inbound').toString().toLowerCase();
                document.getElementById(outHiddenId).value = (this.value === 'outbound').toString().toLowerCase();
                syncAllowSkipState();
            });
        });
    }
    bindSplitDirectionRadio('kioskCommodityDir', 'PromptKioskCommodityOnInbound',  'PromptKioskCommodityOnOutbound');
    bindSplitDirectionRadio('kioskCustomerDir',  'PromptKioskCustomerOnInbound',   'PromptKioskCustomerOnOutbound');
    bindSplitDirectionRadio('kioskLocationDir',  'PromptKioskLocationOnInbound',   'PromptKioskLocationOnOutbound');
    bindSplitDirectionRadio('kioskDestDir',      'PromptKioskDestinationOnInbound', 'PromptKioskDestinationOnOutbound');
    // Apply the rule on initial load (covers prompts already set to Neither).
    syncAllowSkipState();

    // --- Confirm modal ---
    var _confirmFormId = null;
    function showConfirmModal(title, message, formId, btnClass) {
        _confirmFormId = formId;
        document.getElementById('confirmModalTitle').textContent = 'Confirm Operation';
        document.getElementById('confirmModalBody').innerHTML = message.replace(/\n/g, '<br>');
        var btn = document.getElementById('confirmModalBtn');
        btn.className = 'btn btn-sm ' + btnClass;
        btn.textContent = title;
        new bootstrap.Modal(document.getElementById('confirmModal')).show();
    }
    function confirmModalSubmit() {
        if (_confirmFormId) {
            document.getElementById(_confirmFormId).submit();
        }
    }
</script>
}
