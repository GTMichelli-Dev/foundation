@model List<Foundation.Web.Models.Truck>
@{
    ViewData["Title"] = "Retained Tares";
    var withTare = Model.Count(t => t.RetainedTare.HasValue);
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">Retained Tares</h3>
    <a href="/Setup" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left"></i> Back to Setup</a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <p class="mb-1 small text-muted">
            When a truck has a retained tare, kiosk weigh-ins for that truck are auto-completed using the
            stored tare instead of leaving the ticket open for a second weigh. The tare refreshes
            automatically on every completed weigh-out. Use this page to inspect, edit, or clear stored
            tares — handy if a truck swaps trailers and the saved tare is no longer accurate.
        </p>
        <p class="mb-0 small">
            <strong>@withTare</strong> of <strong>@Model.Count</strong> trucks have a retained tare.
        </p>
    </div>
</div>

<div id="rtToastContainer" style="position:fixed;top:70px;right:20px;z-index:9999;min-width:300px;max-width:480px;"></div>

<div class="card">
    <div class="card-header py-2 d-flex justify-content-between align-items-center">
        <strong>Trucks</strong>
        <button type="button" class="btn btn-outline-danger btn-sm" id="btnClearAll"
                @(withTare == 0 ? "disabled" : "")>
            <i class="fa fa-eraser"></i> Clear All
        </button>
    </div>
    <div class="card-body p-0">
        <table class="table table-sm table-striped mb-0 align-middle">
            <thead>
                <tr>
                    <th>Truck ID</th>
                    <th>Carrier</th>
                    <th>Description</th>
                    <th class="text-end">Retained Tare</th>
                    <th>Updated</th>
                    <th style="width:220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-muted text-center py-4">No trucks configured.</td></tr>
            }
            @foreach (var truck in Model)
            {
                <tr data-truck-id="@truck.Id">
                    <td>@truck.TruckId</td>
                    <td>@truck.CarrierName</td>
                    <td class="small text-muted">@truck.Description</td>
                    <td class="text-end font-monospace tare-cell">
                        @if (truck.RetainedTare.HasValue)
                        {
                            @($"{truck.RetainedTare.Value:N0} lb")
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="small updated-cell">
                        @(truck.RetainedTareUpdated?.ToString("yyyy-MM-dd HH:mm") ?? "")
                    </td>
                    <td>
                        <button type="button" class="btn btn-outline-warning btn-sm me-1 btn-edit"
                                data-current="@(truck.RetainedTare?.ToString() ?? "")">
                            <i class="fa fa-edit"></i> Edit
                        </button>
                        <button type="button" class="btn btn-outline-danger btn-sm btn-clear"
                                @(truck.RetainedTare.HasValue ? "" : "disabled")>
                            <i class="fa fa-times"></i> Clear
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editTareModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Edit Retained Tare</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editTruckRowId" />
                <div class="mb-2 small text-muted" id="editTruckLabel"></div>
                <label class="form-label small mb-0">Retained Tare (lb)</label>
                <input type="number" class="form-control form-control-sm" id="editTareValue"
                       min="0" placeholder="Leave blank to clear" />
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="btnSaveTare">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function rtToast(kind, msg) {
        var html = '<div class="alert alert-' + kind + ' alert-dismissible fade show py-1 mb-2" role="alert">'
                 + msg
                 + '<button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button></div>';
        var $t = $(html).appendTo('#rtToastContainer');
        setTimeout(function () { $t.alert('close'); }, 3000);
    }

    function fmtNumber(n) { return n == null ? '—' : Number(n).toLocaleString(); }

    function applyRowUpdate($row, retainedTare, retainedTareUpdated) {
        var $tare = $row.find('.tare-cell');
        var $upd  = $row.find('.updated-cell');
        var $clear = $row.find('.btn-clear');
        var $edit  = $row.find('.btn-edit');
        if (retainedTare != null) {
            $tare.html(Number(retainedTare).toLocaleString() + ' lb');
            $clear.prop('disabled', false);
        } else {
            $tare.html('<span class="text-muted">—</span>');
            $clear.prop('disabled', true);
        }
        $upd.text(retainedTareUpdated
            ? new Date(retainedTareUpdated).toISOString().slice(0,16).replace('T', ' ')
            : '');
        $edit.attr('data-current', retainedTare != null ? String(retainedTare) : '');
    }

    $(document).on('click', '.btn-clear', function () {
        var $row = $(this).closest('tr');
        var id = $row.data('truck-id');
        if (!confirm('Clear retained tare for this truck?')) return;
        $.ajax({ url: '/api/retainedtares/' + id + '/clear', method: 'POST' })
            .done(function () {
                applyRowUpdate($row, null, null);
                rtToast('success', 'Cleared.');
            })
            .fail(function (xhr) { rtToast('danger', 'Failed: ' + xhr.status); });
    });

    $(document).on('click', '.btn-edit', function () {
        var $row = $(this).closest('tr');
        var id = $row.data('truck-id');
        var current = $(this).attr('data-current') || '';
        var label = $row.children().eq(0).text() + ' — ' + $row.children().eq(1).text();
        $('#editTruckRowId').val(id);
        $('#editTruckLabel').text(label);
        $('#editTareValue').val(current);
        new bootstrap.Modal('#editTareModal').show();
    });

    $('#btnSaveTare').on('click', function () {
        var id = $('#editTruckRowId').val();
        var raw = $('#editTareValue').val();
        var body = { retainedTare: raw === '' ? null : parseInt(raw, 10) };
        if (body.retainedTare !== null && (isNaN(body.retainedTare) || body.retainedTare < 0)) {
            rtToast('warning', 'Enter a non-negative number, or leave blank to clear.');
            return;
        }
        $.ajax({
            url: '/api/retainedtares/' + id,
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(body)
        }).done(function (result) {
            var $row = $('tr[data-truck-id="' + id + '"]');
            applyRowUpdate($row, result.retainedTare, result.retainedTareUpdated);
            bootstrap.Modal.getInstance(document.getElementById('editTareModal')).hide();
            rtToast('success', 'Saved.');
        }).fail(function (xhr) {
            var msg = 'Failed (' + xhr.status + ').';
            try { var b = JSON.parse(xhr.responseText); if (b.message) msg = b.message; } catch (e) {}
            rtToast('danger', msg);
        });
    });

    $('#btnClearAll').on('click', function () {
        if (!confirm('Clear retained tares for ALL trucks? This cannot be undone.')) return;
        $.ajax({ url: '/api/retainedtares/clear-all', method: 'POST' })
            .done(function (result) {
                $('tr[data-truck-id]').each(function () {
                    applyRowUpdate($(this), null, null);
                });
                $('#btnClearAll').prop('disabled', true);
                rtToast('success', 'Cleared ' + result.cleared + ' truck(s).');
            })
            .fail(function (xhr) { rtToast('danger', 'Failed: ' + xhr.status); });
    });
</script>
}
