@{
    ViewData["Title"] = "Reports";
    var savePicture = (bool)(ViewBag.SavePicture ?? false);
    var useQuickBooks = (bool)(ViewBag.UseQuickBooks ?? false);
    var useBinInventory = (bool)(ViewBag.UseBinInventory ?? false);
}

<style>
    .ticket-thumb {
        width: 40px; height: 40px; object-fit: cover; border-radius: 4px;
        cursor: pointer; transition: transform 0.2s ease;
    }
    .ticket-thumb:hover { transform: scale(2); z-index: 100; position: relative; }
    .notes-cell {
        white-space: normal !important;
        word-wrap: break-word;
        max-height: 60px;
        overflow: hidden;
    }
    .report-controls {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
    }
    .report-controls .ctrl-label {
        font-weight: 600;
        white-space: nowrap;
        font-size: 0.85em;
    }
</style>

<h3>Reports</h3>
<script>var companyName = '@Html.Raw(ViewBag.CompanyName)';</script>

@if (useBinInventory)
{
    <ul class="nav nav-pills mb-2">
        <li class="nav-item">
            <button type="button" class="nav-link active" id="tabBtnTransactions">Transactions</button>
        </li>
        <li class="nav-item">
            <button type="button" class="nav-link" id="tabBtnBinInventory">Bin Inventory</button>
        </li>
    </ul>
}

<!-- Image Lightbox Modal -->
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="imageModalTitle"></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body d-flex gap-3 p-3" style="background:#f8f9fa;">
                <div style="flex:1;min-width:0;text-align:center;background:#000;border-radius:4px;overflow:hidden;">
                    <img id="imageModalImg" src="" class="img-fluid" style="max-height:70vh;" />
                </div>
                <div id="imageModalInfo" style="min-width:250px;max-width:280px;font-family:'Courier New',monospace;font-size:13px;border:2px solid #000;padding:16px;background:#fff;border-radius:4px;align-self:flex-start;"></div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-sm btn-primary" onclick="downloadTicketImage(window._currentTicket, window._currentDirection)"><i class="fa fa-download"></i> Download</button>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
function showTicketImage(ticket, direction, data) {
    window._currentTicket = ticket;
    window._currentDirection = direction;
    var url = '/api/ticket/' + ticket + '/image?direction=' + direction;
    $('#imageModalTitle').text('Ticket #' + ticket + ' (' + (direction === 'in' ? 'Inbound' : 'Outbound') + ')');
    $('#imageModalImg').attr('src', url);

    var label = direction === 'in' ? 'Inbound Ticket' : 'Completed Ticket';
    var info = '<div style="text-align:center;font-weight:bold;letter-spacing:2px;text-transform:uppercase;border-bottom:2px solid #333;padding-bottom:4px;margin-bottom:8px;font-size:11px;">' + label + '</div>';
    function row(lbl, val) {
        return '<div style="display:flex;justify-content:space-between;padding:2px 0;"><span style="font-weight:bold;">' + lbl + '</span><span>' + (val || '-') + '</span></div>';
    }
    info += row('Ticket #:', ticket);
    if (data) {
        if (data.dateIn) info += row('Date In:', new Date(data.dateIn).toLocaleString());
        if (direction === 'out' && data.dateOut) info += row('Date Out:', new Date(data.dateOut).toLocaleString());
        info += row('Customer:', data.customer);
        info += row('Carrier:', data.carrier);
        info += row('Truck:', data.truckId);
        info += row('Commodity:', data.commodity);
        if (data.location) info += row('Location:', data.location);
        if (data.destination) info += row('Destination:', data.destination);
        if (data.bin) info += row('Bin:', data.bin);
        info += '<div style="border-top:1px dashed #000;border-bottom:1px dashed #000;margin:6px 0;padding:6px 0;">';
        if (direction === 'in') {
            info += '<div style="font-size:16px;font-weight:bold;display:flex;justify-content:space-between;"><span>Weight:</span><span>' + (data.inWeight || 0).toLocaleString() + ' lb</span></div>';
        } else {
            info += row('Gross:', (data.outWeight || 0).toLocaleString() + ' lb');
            info += row('Tare:', (data.inWeight || 0).toLocaleString() + ' lb');
            info += '<div style="font-size:16px;font-weight:bold;display:flex;justify-content:space-between;"><span>Net:</span><span>' + (data.netWeight || 0).toLocaleString() + ' lb</span></div>';
        }
        info += '</div>';
        if (data.notes) info += row('Notes:', data.notes);
    }
    $('#imageModalInfo').html(info);
    new bootstrap.Modal('#imageModal').show();
}
</script>

<div id="pane-transactions">
<div class="report-controls">
    <span class="ctrl-label">Report:</span>
    <div id="tplSelect"></div>
    <div id="tplSaveBtn"></div>
    <div id="tplSaveAsBtn"></div>
    <div id="tplDeleteBtn"></div>
    <span class="small text-muted">
        Arrange the grid (columns, order, grouping, filters, sorting), then Save As to keep it as a named report. Exports follow the loaded report.
    </span>
</div>
<div class="report-controls">
    <span class="ctrl-label">From:</span>
    <div id="startDate"></div>
    <span class="ctrl-label">To:</span>
    <div id="endDate"></div>
    <span class="ctrl-label ms-2">Group By:</span>
    <div id="groupByTag"></div>
    <div id="resetBtn" class="ms-2"></div>
</div>

<div id="voidWarning" class="alert alert-warning py-1 mb-2" style="display:none;" role="alert">
    <strong id="voidCount"></strong> voided ticket(s) are not included in this report.
    <a href="#" id="showVoidsLink" class="alert-link ms-2">View voided tickets</a>
</div>

<!-- Voided Tickets Modal -->
<div class="modal fade" id="voidsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Voided Tickets</h6>
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div id="voidsGrid"></div>
            </div>
        </div>
    </div>
</div>

<div id="reportGrid"></div>

<!-- Report-builder: name a saved report (Save As) -->
<div class="modal fade" id="tplNameModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">Save Report As</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-2">
                <label class="form-label mb-0 small">Report name</label>
                <input type="text" id="tplNameInput" class="form-control form-control-sm" maxlength="100"
                       placeholder="e.g. Daily Corn Loads by Customer" />
                <div id="tplNameError" class="small text-danger mt-1" style="display:none;"></div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="tplNameSaveBtn">Save</button>
            </div>
        </div>
    </div>
</div>
</div><!-- /pane-transactions -->

@if (useBinInventory)
{
<div id="pane-binInventory" style="display:none;">
    <div class="report-controls">
        <span class="ctrl-label">As Of:</span>
        <div id="binAsOfDate"></div>
        <div id="binAddAdjustmentBtn" class="ms-2"></div>
        <span class="ctrl-label ms-auto text-muted" style="font-weight:400;">
            Loads in add to a bin, loads out deduct; true-ups reconcile shrinkage. Expand a row for its history.
        </span>
    </div>
    <div id="binInventoryGrid"></div>
</div>

<!-- Bin adjustment / true-up modal -->
<div class="modal fade" id="binAdjModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="binAdjTitle">Bin Adjustment</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-2">
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="form-label mb-0 small">Bin</label>
                        <select id="binAdjBin" class="form-select form-select-sm"></select>
                    </div>
                    <div class="col-6">
                        <label class="form-label mb-0 small">Commodity</label>
                        <select id="binAdjCommodity" class="form-select form-select-sm"></select>
                    </div>
                </div>
                <div class="mb-2 small" id="binAdjCurrent" style="color: var(--bw-text-muted);"></div>
                <div class="mb-2">
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="binAdjMode" id="binAdjModeTrueUp" value="trueup" checked />
                        <label class="form-check-label small" for="binAdjModeTrueUp"><strong>True Up</strong> — set to measured total</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="binAdjMode" id="binAdjModeAdjust" value="adjust" />
                        <label class="form-check-label small" for="binAdjModeAdjust"><strong>Adjust</strong> — add/subtract an amount</label>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0 small" id="binAdjAmountLabel">Measured amount on hand (lbs)</label>
                    <input type="number" step="1" id="binAdjAmount" class="form-control form-control-sm" />
                    <div class="form-text small" id="binAdjAmountHint">
                        The difference from the computed balance is recorded as an adjustment.
                    </div>
                </div>
                <div class="mb-1">
                    <label class="form-label mb-0 small">Note</label>
                    <input type="text" maxlength="200" id="binAdjNote" class="form-control form-control-sm"
                           placeholder="e.g. Measured after drying — shrinkage" />
                </div>
                <div id="binAdjError" class="small text-danger mt-1" style="display:none;"></div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="binAdjSaveBtn">Save</button>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
<script src="~/js/ticket-image-download.js"></script>
<script src="~/js/signalr/signalr.min.js"></script>
<partial name="_FieldConfigJs" />
<script>
    $(function () {
        var useQuickBooks = @(useQuickBooks ? "true" : "false");
        var storageKey = 'report_dates';
        var cookieGroupBy = 'report_groupby';

        var defaultStart = new Date(new Date().setDate(new Date().getDate() - 30));
        var defaultEnd = new Date();

        var saved = sessionStorage.getItem(storageKey);
        if (saved) {
            try {
                var parsed = JSON.parse(saved);
                defaultStart = new Date(parsed.start);
                defaultEnd = new Date(parsed.end);
            } catch (e) { }
        }

        var startVal = defaultStart;
        var endVal = defaultEnd;

        // Cookie helpers
        function setCookie(name, value, days) {
            var d = new Date();
            d.setTime(d.getTime() + (days * 24 * 60 * 60 * 1000));
            document.cookie = name + '=' + encodeURIComponent(JSON.stringify(value)) + ';expires=' + d.toUTCString() + ';path=/';
        }
        function getCookie(name) {
            var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
            if (match) { try { return JSON.parse(decodeURIComponent(match[2])); } catch (e) {} }
            return null;
        }

        function saveDates() {
            sessionStorage.setItem(storageKey, JSON.stringify({
                start: startVal.toISOString(),
                end: endVal.toISOString()
            }));
        }

        // Groupable column options — hidden standard fields drop out, custom
        // fields (referenced by column name cf_{id}) are groupable too.
        var groupOptions = [
            { value: 'customer', text: 'Customer' },
            { value: 'carrier', text: 'Carrier' },
            { value: 'truckId', text: 'Truck ID' },
            { value: 'commodity', text: 'Commodity' },
            { value: 'location', text: 'Location' },
            { value: 'destination', text: 'Destination' },
            { value: 'bin', text: 'Bin' }
        ].filter(function (o) { return window.bwFieldConfig.hidden.indexOf(o.value) === -1; });
        window.bwFieldConfig.customFields.forEach(function (f) {
            groupOptions.push({ value: 'cf_' + f.id, text: f.name });
        });

        // Drop remembered group-by fields that no longer exist (hidden or deleted)
        var groupByFields = (getCookie(cookieGroupBy) || []).filter(function (g) {
            return groupOptions.some(function (o) { return o.value === g; });
        });

        function applyGrouping() {
            groupOptions.forEach(function (opt) {
                grid.columnOption(opt.value, 'groupIndex', undefined);
            });
            for (var i = 0; i < groupByFields.length; i++) {
                grid.columnOption(groupByFields[i], 'groupIndex', i);
            }
        }

        // --- Controls above grid ---
        var startDateBox = $('#startDate').dxDateBox({
            value: startVal, type: 'date', displayFormat: 'MM/dd/yyyy', width: 140,
            onValueChanged: function (e) { startVal = e.value; saveDates(); grid.refresh(); }
        }).dxDateBox('instance');

        var endDateBox = $('#endDate').dxDateBox({
            value: endVal, type: 'date', displayFormat: 'MM/dd/yyyy', width: 140,
            onValueChanged: function (e) { endVal = e.value; saveDates(); grid.refresh(); }
        }).dxDateBox('instance');

        var groupByTag = $('#groupByTag').dxTagBox({
            items: groupOptions, value: groupByFields,
            valueExpr: 'value', displayExpr: 'text',
            placeholder: 'Select...', width: 280,
            showSelectionControls: true, searchEnabled: true,
            onValueChanged: function (e) {
                groupByFields = e.value || [];
                setCookie(cookieGroupBy, groupByFields, 365);
                applyGrouping();
            }
        }).dxTagBox('instance');

        $('#resetBtn').dxButton({
            icon: 'revert', text: 'Reset',
            hint: 'Reset all filters, grouping, columns and dates',
            onClick: function () {
                startVal = new Date(new Date().setDate(new Date().getDate() - 30));
                endVal = new Date();
                startDateBox.option('value', startVal);
                endDateBox.option('value', endVal);
                saveDates();
                groupByFields = [];
                groupByTag.option('value', groupByFields);
                setCookie(cookieGroupBy, groupByFields, 365);
                grid.clearFilter();
                applyGrouping();
                // Clear saved grid state (column widths, visibility, filters, sort)
                // and reload so defaults from the columns config apply.
                try { localStorage.removeItem('reportGrid_v3'); } catch (e) { }
                grid.state(null);
                window.location.reload();
            }
        });

        // --- Data Grid ---
        var grid = $('#reportGrid').dxDataGrid({
            hoverStateEnabled: true,
            remoteOperations: false,
            dataSource: new DevExpress.data.CustomStore({
                key: 'ticket',
                load: function () {
                    var s = DevExpress.localization.formatDate(startVal, 'yyyy-MM-dd');
                    var e = DevExpress.localization.formatDate(endVal, 'yyyy-MM-dd');
                    return $.getJSON('/api/reports/transactions', { startDate: s, endDate: e }).then(function (resp) {
                        // Show/hide void warning
                        if (resp.voidCount > 0) {
                            $('#voidCount').text(resp.voidCount);
                            $('#voidWarning').show();
                        } else {
                            $('#voidWarning').hide();
                        }
                        return resp.data;
                    });
                }
            }),
            onContentReady: function (e) {
                if (e.component.__firstLoad !== true) {
                    e.component.__firstLoad = true;
                    applyGrouping();
                }
            },
            onToolbarPreparing: function (e) {
                function getFileName(ext) {
                    var s = DevExpress.localization.formatDate(startVal, 'yyyy-MM-dd');
                    var en = DevExpress.localization.formatDate(endVal, 'yyyy-MM-dd');
                    // Saved reports export under their own name.
                    var tpl = currentTemplateName();
                    var base = tpl
                        ? tpl.replace(/[^A-Za-z0-9 _-]+/g, '').trim().replace(/\s+/g, '_') || 'WeighReport'
                        : 'WeighReport';
                    return base + '_' + s + '_to_' + en + '.' + ext;
                }

                function formatNum(n) { return n == null ? '' : Number(n).toLocaleString('en-US'); }
                function formatTons(n) { return n == null ? '' : Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
                function formatDate(val) {
                    if (!val) return '';
                    var d = new Date(val);
                    return (d.getMonth() + 1).toString().padStart(2, '0') + '/' +
                           d.getDate().toString().padStart(2, '0') + '/' +
                           d.getFullYear() + ' ' +
                           ((d.getHours() % 12) || 12) + ':' +
                           d.getMinutes().toString().padStart(2, '0') + ' ' +
                           (d.getHours() >= 12 ? 'PM' : 'AM');
                }

                function exportPdf(orientation) {
                    var doc = new jspdf.jsPDF({ orientation: orientation, format: 'letter', unit: 'mm' });
                    var pageWidth = doc.internal.pageSize.getWidth();

                    // Header: Company name + date range
                    var sDate = DevExpress.localization.formatDate(startVal, 'MM/dd/yyyy');
                    var eDate = DevExpress.localization.formatDate(endVal, 'MM/dd/yyyy');
                    doc.setFontSize(12);
                    doc.setFont(undefined, 'bold');
                    doc.text(companyName, pageWidth / 2, 8, { align: 'center' });
                    doc.setFontSize(8);
                    doc.setFont(undefined, 'normal');
                    doc.text((currentTemplateName() || 'Weigh Report') + ': ' + sDate + ' to ' + eDate, pageWidth / 2, 13, { align: 'center' });

                    // Get visible columns and data. Custom-field columns have no
                    // dataField (they use calculateCellValue), so match those by
                    // their cf_ name.
                    var visibleCols = grid.getVisibleColumns().filter(function (c) {
                        return bwIsExportableCol(c) && c.groupIndex === undefined;
                    });
                    var headers = visibleCols.map(function (c) { return c.caption || c.dataField; });

                    // Find column indices for weight/tons fields
                    var netWeightIdx = -1, netTonsIdx = -1;
                    visibleCols.forEach(function (c, i) {
                        if (c.dataField === 'netWeight') netWeightIdx = i;
                        if (c.dataField === 'netTons') netTonsIdx = i;
                    });

                    // Helper: build a formatted data row with right-aligned numbers
                    function makeDataRow(row) {
                        return visibleCols.map(function (col) {
                            var val = bwColValue(col, row);
                            if (val == null) return '';
                            if (col.dataType === 'datetime' || col.dataType === 'date') return formatDate(val);
                            if (col.dataField === 'netTons') return { content: formatTons(val), styles: { halign: 'right' } };
                            if (col.dataType === 'number') return { content: formatNum(val), styles: { halign: 'right' } };
                            return String(val);
                        });
                    }

                    var dataSource = grid.getDataSource();
                    var items = dataSource.items();

                    // Grand totals
                    var grandLoads = 0, grandNetWeight = 0, grandNetTons = 0;

                    // Build body with group headers, group totals, and data rows
                    var body = [];

                    function makeTotalRow(label, loads, netWeight, netTons, bgColor, textColor) {
                        textColor = textColor || [0, 0, 0];
                        var row = [];
                        for (var i = 0; i < headers.length; i++) {
                            var content = '';
                            if (i === 0) content = label + ': ' + loads + ' loads';
                            if (i === netWeightIdx) content = formatNum(netWeight) + ' lbs';
                            if (i === netTonsIdx) content = formatTons(netTons) + ' tons';
                            row.push({ content: content, styles: { fontStyle: 'bold', fillColor: bgColor, textColor: textColor, halign: (i === netWeightIdx || i === netTonsIdx) ? 'right' : 'left' } });
                        }
                        return row;
                    }

                    function processItems(items) {
                        items.forEach(function (item) {
                            if (item.items || item.collapsedItems) {
                                var subItems = item.items || item.collapsedItems;
                                // Group header
                                body.push([{ content: item.key, colSpan: headers.length, styles: { fontStyle: 'bold', fillColor: [230, 236, 245], fontSize: 5.5 } }]);

                                // Check for nested groups
                                if (subItems && subItems.length > 0 && (subItems[0].items || subItems[0].collapsedItems)) {
                                    processItems(subItems);
                                } else {
                                    // Data rows
                                    var groupLoads = 0, groupNetWeight = 0, groupNetTons = 0;
                                    (subItems || []).forEach(function (row) {
                                        groupLoads++;
                                        grandLoads++;
                                        var nw = row.netWeight || 0;
                                        var nt = row.netTons || 0;
                                        groupNetWeight += nw;
                                        groupNetTons += nt;
                                        grandNetWeight += nw;
                                        grandNetTons += nt;

                                        body.push(makeDataRow(row));
                                    });
                                    // Group subtotal
                                    body.push(makeTotalRow(item.key, groupLoads, groupNetWeight, groupNetTons, [220, 230, 220]));
                                }
                            } else {
                                // Ungrouped data row
                                grandLoads++;
                                grandNetWeight += item.netWeight || 0;
                                grandNetTons += item.netTons || 0;
                                body.push(makeDataRow(item));
                            }
                        });
                    }

                    processItems(items);

                    // Grand total row
                    body.push(makeTotalRow('Grand Total', grandLoads, grandNetWeight, grandNetTons, [46, 163, 242], [255, 255, 255]));

                    doc.autoTable({
                        head: [headers],
                        body: body,
                        styles: { fontSize: 5, cellPadding: 0.8 },
                        headStyles: { fillColor: [46, 163, 242], fontSize: 5.5, cellPadding: 1 },
                        margin: { top: 16, right: 3, bottom: 10, left: 3 },
                        tableWidth: pageWidth - 6,
                        theme: 'grid',
                        didDrawPage: function (data) {
                            var pageHeight = doc.internal.pageSize.getHeight();
                            var totals = 'Loads: ' + grandLoads +
                                         '   |   Net: ' + formatNum(grandNetWeight) + ' lbs' +
                                         '   |   Net: ' + formatTons(grandNetTons) + ' tons';
                            doc.setFontSize(8);
                            doc.setFont(undefined, 'bold');
                            doc.text(totals, pageWidth / 2, pageHeight - 4, { align: 'center' });
                        }
                    });

                    doc.save(getFileName('pdf'));
                }

                e.toolbarOptions.items.push(
                    {
                        location: 'after',
                        widget: 'dxButton',
                        options: {
                            icon: 'exportpdf', text: 'PDF Landscape',
                            onClick: function () { exportPdf('landscape'); }
                        }
                    },
                    {
                        location: 'after',
                        widget: 'dxButton',
                        options: {
                            icon: 'exportpdf', text: 'PDF Portrait',
                            onClick: function () { exportPdf('portrait'); }
                        }
                    },
                    {
                        location: 'after',
                        widget: 'dxButton',
                        options: {
                            icon: 'xlsxfile', text: 'Excel',
                            onClick: function () {
                                var workbook = new ExcelJS.Workbook();
                                var worksheet = workbook.addWorksheet('WeighReport');
                                DevExpress.excelExporter.exportDataGrid({
                                    component: grid, worksheet: worksheet, autoFilterEnabled: true
                                }).then(function () {
                                    workbook.xlsx.writeBuffer().then(function (buffer) {
                                        saveAs(new Blob([buffer], { type: 'application/octet-stream' }), getFileName('xlsx'));
                                    });
                                });
                            }
                        }
                    },
                    {
                        location: 'after',
                        widget: 'dxButton',
                        options: {
                            icon: 'doc', text: 'CSV',
                            onClick: function () {
                                var cols = grid.getVisibleColumns().filter(bwIsExportableCol);
                                var csvHeaders = cols.map(function (c) { return '"' + (c.caption || c.dataField) + '"'; }).join(',');
                                var rows = [];
                                var allData = grid.getDataSource().items();
                                function extractRows(items) {
                                    items.forEach(function (item) {
                                        if (item.items || item.collapsedItems) {
                                            extractRows(item.items || item.collapsedItems);
                                        } else {
                                            var row = cols.map(function (col) {
                                                var val = bwColValue(col, item);
                                                if (val == null) return '""';
                                                if (col.dataType === 'datetime' || col.dataType === 'date') return '"' + formatDate(val) + '"';
                                                if (col.dataType === 'number') return val;
                                                return '"' + String(val).replace(/"/g, '""') + '"';
                                            });
                                            rows.push(row.join(','));
                                        }
                                    });
                                }
                                extractRows(allData);
                                var csv = csvHeaders + '\n' + rows.join('\n');
                                var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
                                saveAs(blob, getFileName('csv'));
                            }
                        }
                    },
                    {
                        location: 'after',
                        widget: 'dxButton',
                        options: {
                            icon: 'variable', text: 'JSON',
                            onClick: function () {
                                var cols = grid.getVisibleColumns().filter(bwIsExportableCol);
                                var jsonData = [];
                                var allData = grid.getDataSource().items();
                                function extractRows(items) {
                                    items.forEach(function (item) {
                                        if (item.items || item.collapsedItems) {
                                            extractRows(item.items || item.collapsedItems);
                                        } else {
                                            var obj = {};
                                            cols.forEach(function (col) {
                                                var key = col.dataField || col.caption || col.name;
                                                var val = bwColValue(col, item);
                                                obj[key] = val != null ? val : null;
                                            });
                                            jsonData.push(obj);
                                        }
                                    });
                                }
                                extractRows(allData);
                                var json = JSON.stringify(jsonData, null, 2);
                                var blob = new Blob([json], { type: 'application/json;charset=utf-8;' });
                                saveAs(blob, getFileName('json'));
                            }
                        }
                    }
                );

                if (useQuickBooks) {
                    e.toolbarOptions.items.push({
                        location: 'after',
                        widget: 'dxButton',
                        options: {
                            icon: 'upload', text: 'Send to QuickBooks',
                            type: 'success',
                            onClick: function () { sendToQuickBooks(); }
                        }
                    });
                }
            },
            columnChooser: { enabled: true, mode: 'select' },
            columns: (function () {
                var savePic = @(savePicture ? "true" : "false");
                var cols = [
                    { dataField: 'ticket', caption: '#', width: 150, sortOrder: 'desc', sortIndex: 0,
                      calculateSortValue: function (data) { return parseInt(data.ticket, 10) || 0; } },
                    { dataField: 'dateOut', caption: 'Date Out', dataType: 'datetime', format: 'MM/dd/yyyy hh:mm a', width: 155 },
                    { dataField: 'dateIn', caption: 'Date In', dataType: 'datetime', format: 'MM/dd/yyyy hh:mm a', width: 155 },
                    { dataField: 'customer', caption: 'Customer' },
                    { dataField: 'carrier', caption: 'Carrier' },
                    { dataField: 'truckId', caption: 'Truck ID' },
                    { dataField: 'commodity', caption: 'Commodity' },
                    { dataField: 'location', caption: 'Location' },
                    { dataField: 'destination', caption: 'Destination' },
                    { dataField: 'bin', caption: 'Bin' },
                    { dataField: 'inWeight', caption: 'In (lbs)', dataType: 'number', format: '#,##0', width: 150 },
                    { dataField: 'outWeight', caption: 'Out (lbs)', dataType: 'number', format: '#,##0', width: 150 },
                    { dataField: 'netWeight', caption: 'Net (lbs)', dataType: 'number', format: '#,##0', width: 150, allowHiding: false, showInColumnChooser: false },
                    { dataField: 'netTons', caption: 'Net (tons)', dataType: 'number', format: '#,##0.00', width: 150 },
                    { dataField: 'notes', caption: 'Notes', cssClass: 'notes-cell' }
                ];
                cols = bwApplyFieldConfig(cols);
                if (savePic) {
                    cols.push({
                        caption: 'In Photo', width: 55, minWidth: 55, allowFiltering: false, allowSorting: false, allowExporting: false,
                        cellTemplate: function (container, options) {
                            if (options.data.hasInImage) {
                                $('<img>').addClass('ticket-thumb')
                                    .attr('src', '/api/ticket/' + options.data.ticket + '/image?direction=in')
                                    .on('click', function () { showTicketImage(options.data.ticket, 'in', options.data); })
                                    .appendTo(container);
                            }
                        }
                    });
                    cols.push({
                        caption: 'Out Photo', width: 55, minWidth: 55, allowFiltering: false, allowSorting: false, allowExporting: false,
                        cellTemplate: function (container, options) {
                            if (options.data.hasOutImage) {
                                $('<img>').addClass('ticket-thumb')
                                    .attr('src', '/api/ticket/' + options.data.ticket + '/image?direction=out')
                                    .on('click', function () { showTicketImage(options.data.ticket, 'out', options.data); })
                                    .appendTo(container);
                            }
                        }
                    });
                }
                if (useQuickBooks) {
                    cols.push({
                        dataField: 'sentToQuickBooks', caption: 'Sent to QuickBooks',
                        dataType: 'boolean', width: 150, allowFiltering: true, allowSorting: true
                    });
