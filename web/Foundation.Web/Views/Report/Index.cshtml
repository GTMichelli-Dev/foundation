        }).dxDataGrid('instance');

        // ===== REPORT BUILDER (saved templates) =====
        // The whole custom report IS the grid state (columns, order, widths,
        // grouping, sorting, filters). Save it under a name, reload it any
        // time; the exports above automatically follow whatever is loaded.
        var templates = [];
        var currentTemplateId = parseInt(localStorage.getItem('report_templateId')) || 0;

        function currentTemplateName() {
            var t = templates.find(function (x) { return x.id === currentTemplateId; });
            return t ? t.name : null;
        }

        function tplItems() {
            return [{ id: 0, name: '— Standard Report —' }].concat(templates);
        }

        function gridStateJson() {
            var state = grid.state() || {};
            delete state.pageIndex;     // transient — not part of the layout
            delete state.focusedRowKey;
            return JSON.stringify(state);
        }

        // Reflect the grid's group indexes back into the Group By tag box
        // after a template loads (its onValueChanged re-applies them — same
        // values, so it's a no-op).
        function syncGroupTagsFromGrid() {
            var pairs = [];
            groupOptions.forEach(function (o) {
                var gi = grid.columnOption(o.value, 'groupIndex');
                if (gi !== undefined && gi !== null && gi >= 0) pairs.push({ f: o.value, gi: gi });
            });
            pairs.sort(function (a, b) { return a.gi - b.gi; });
            groupByFields = pairs.map(function (p) { return p.f; });
            setCookie(cookieGroupBy, groupByFields, 365);
            groupByTag.option('value', groupByFields);
        }

        function applyTemplate(id) {
            if (id === 0) {
                grid.state(null); // standard layout from the column config
                syncGroupTagsFromGrid();
                return;
            }
            $.getJSON('/api/reports/templates/' + id).done(function (t) {
                var state = {};
                try { state = JSON.parse(t.stateJson || '{}'); } catch (e) { }
                delete state.pageIndex;
                grid.state(state);
                syncGroupTagsFromGrid();
            }).fail(function () {
                showAlert('<i class="fa fa-times-circle"></i> Could not load that report.', 'danger');
            });
        }

        var tplSelect = $('#tplSelect').dxSelectBox({
            items: tplItems(),
            valueExpr: 'id',
            displayExpr: 'name',
            value: currentTemplateId,
            width: 240,
            onValueChanged: function (e) {
                if (e.value === null || e.value === undefined) return;
                currentTemplateId = e.value;
                localStorage.setItem('report_templateId', String(currentTemplateId));
                syncTplButtons();
                // Only a user-initiated pick loads the layout — on page load the
                // grid already restored the operator's last working view.
                if (e.event) applyTemplate(currentTemplateId);
            }
        }).dxSelectBox('instance');

        var tplSaveBtn = $('#tplSaveBtn').dxButton({
            icon: 'save', text: 'Save',
            hint: 'Save the current layout to the selected report',
            onClick: function () {
                if (currentTemplateId === 0) return;
                var name = currentTemplateName();
                $.ajax({
                    url: '/api/reports/templates/' + currentTemplateId,
                    method: 'PUT',
                    contentType: 'application/json',
                    data: JSON.stringify({ name: name, stateJson: gridStateJson() })
                }).done(function () {
                    showAlert('<i class="fa fa-check-circle"></i> Report "' + $('<span>').text(name).html() + '" saved.', 'success');
                }).fail(function (xhr) {
                    var msg = 'Save failed.'; try { msg = JSON.parse(xhr.responseText).message || msg; } catch (e) { }
                    showAlert('<i class="fa fa-times-circle"></i> ' + msg, 'danger');
                });
            }
        }).dxButton('instance');

        $('#tplSaveAsBtn').dxButton({
            icon: 'plus', text: 'Save As',
            hint: 'Save the current layout as a new report',
            onClick: function () {
                $('#tplNameInput').val('');
                $('#tplNameError').hide();
                new bootstrap.Modal('#tplNameModal').show();
                setTimeout(function () { $('#tplNameInput').trigger('focus'); }, 400);
            }
        });

        var tplDeleteBtn = $('#tplDeleteBtn').dxButton({
            icon: 'trash',
            hint: 'Delete the selected report',
            onClick: function () {
                if (currentTemplateId === 0) return;
                if (!confirm('Delete the report "' + currentTemplateName() + '"?')) return;
                $.ajax({ url: '/api/reports/templates/' + currentTemplateId, method: 'DELETE' })
                    .done(function () { loadTemplates(0); }); // keep the current layout on screen
            }
        }).dxButton('instance');

        function syncTplButtons() {
            var std = currentTemplateId === 0;
            tplSaveBtn.option('disabled', std);
            tplDeleteBtn.option('disabled', std);
        }

        var tplLoadSeq = 0;
        function loadTemplates(selectId) {
            var seq = ++tplLoadSeq;
            return $.getJSON('/api/reports/templates').done(function (list) {
                if (seq !== tplLoadSeq) return; // a newer load superseded this one
                templates = list || [];
                if (selectId !== undefined) currentTemplateId = selectId;
                if (!tplItems().some(function (t) { return t.id === currentTemplateId; })) currentTemplateId = 0;
                localStorage.setItem('report_templateId', String(currentTemplateId));
                tplSelect.option('items', tplItems());
                tplSelect.option('value', currentTemplateId);
                syncTplButtons();
            });
        }

        $('#tplNameSaveBtn').on('click', function () {
            var name = $('#tplNameInput').val().trim();
            if (!name) { $('#tplNameError').text('Enter a name for the report.').show(); return; }
            $.ajax({
                url: '/api/reports/templates',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ name: name, stateJson: gridStateJson() })
            }).done(function (t) {
                bootstrap.Modal.getInstance(document.getElementById('tplNameModal')).hide();
                showAlert('<i class="fa fa-check-circle"></i> Report "' + $('<span>').text(t.name).html() + '" created.', 'success');
                loadTemplates(t.id);
            }).fail(function (xhr) {
                var msg = 'Save failed.'; try { msg = JSON.parse(xhr.responseText).message || msg; } catch (e) { }
                $('#tplNameError').text(msg).show();
            });
        });
        $('#tplNameInput').on('keypress', function (e) {
            if (e.which === 13) { e.preventDefault(); $('#tplNameSaveBtn').click(); }
        });

        loadTemplates();
        syncTplButtons();

        // Voided tickets popup
        $('#showVoidsLink').on('click', function (e) {
            e.preventDefault();
            var s = DevExpress.localization.formatDate(startVal, 'yyyy-MM-dd');
            var en = DevExpress.localization.formatDate(endVal, 'yyyy-MM-dd');

            $('#voidsGrid').dxDataGrid({
                dataSource: { store: { type: 'array', key: 'ticket', data: [] }, sort: { field: 'dateOut', desc: true } },
                columns: [
                    { dataField: 'ticket', caption: '#', width: 60,
                      calculateSortValue: function (data) { return parseInt(data.ticket, 10) || 0; } },
                    { dataField: 'customer', caption: 'Customer' },
                    { dataField: 'carrier', caption: 'Carrier' },
                    { dataField: 'truckId', caption: 'Truck ID' },
                    { dataField: 'commodity', caption: 'Commodity' },
                    { dataField: 'inWeight', caption: 'In (lbs)', dataType: 'number', format: '#,##0', width: 90 },
                    { dataField: 'outWeight', caption: 'Out (lbs)', dataType: 'number', format: '#,##0', width: 90 },
                    { dataField: 'netWeight', caption: 'Net (lbs)', dataType: 'number', format: '#,##0', width: 90 },
                    { dataField: 'dateOut', caption: 'Date Out', dataType: 'datetime', format: 'MM/dd/yyyy hh:mm a', width: 155 },
                    { dataField: 'notes', caption: 'Notes' }
                ].filter(function (c) { return !c.dataField || window.bwFieldConfig.hidden.indexOf(c.dataField) === -1; }),
                showBorders: true,
                columnAutoWidth: true,
                paging: { pageSize: 20 }
            });

            $.getJSON('/api/reports/voided', { startDate: s, endDate: en }, function (data) {
                $('#voidsGrid').dxDataGrid('instance').option('dataSource', data);
            });

            new bootstrap.Modal('#voidsModal').show();
        });

        // ===== QUICKBOOKS SEND =====
        var qbConnection = null;
        var qbErrorReceived = false;

        function showAlert(message, type, autoDismiss) {
            type = type || 'info';
            var alertId = 'qb-alert-' + Date.now();
            var colors = {
                danger:  { bg: '#f8d7da', border: '#f5c2c7', text: '#842029' },
                success: { bg: '#d1e7dd', border: '#badbcc', text: '#0f5132' },
                warning: { bg: '#fff3cd', border: '#ffecb5', text: '#664d03' },
                info:    { bg: '#cff4fc', border: '#b6effb', text: '#055160' }
            };
            var c = colors[type] || colors.info;
            var html = '<div id="' + alertId + '" data-alert-type="' + type + '" style="' +
                'padding:12px 40px 12px 16px;margin-bottom:8px;border:1px solid ' + c.border + ';border-radius:6px;' +
                'background-color:' + c.bg + ';color:' + c.text + ';position:relative;">' +
                message +
                '<button type="button" onclick="this.parentElement.remove()" style="position:absolute;top:8px;right:12px;background:none;border:none;font-size:18px;cursor:pointer;color:' + c.text + ';">&times;</button>' +
                '</div>';
            var $container = $('#qb-alert-container');
            if ($container.length === 0) {
                $container = $('<div id="qb-alert-container" style="position:fixed;top:70px;right:20px;z-index:9999;min-width:350px;max-width:500px;"></div>');
                $('body').append($container);
            }
            $container.append(html);
            if (autoDismiss !== false) {
                setTimeout(function () { $('#' + alertId).fadeOut(300, function () { $(this).remove(); }); }, 5000);
            }
        }

        function sendToQuickBooks() {
            if (!qbConnection || qbConnection.state !== 'Connected') {
                showAlert('<i class="fa fa-exclamation-triangle"></i> Not connected to server. Try refreshing the page.', 'danger');
                return;
            }
            qbConnection.invoke('CheckQBServiceConnected').then(function (connected) {
                if (!connected) {
                    showAlert('<i class="fa fa-exclamation-triangle"></i> QuickBooks Sync Service is not connected. Please start the QBSyncService and try again.', 'danger');
                    return;
                }
                pickSendMode();
            }).catch(function (err) {
                showAlert('<i class="fa fa-times-circle"></i> Error checking QB service: ' + err, 'danger');
            });
        }

        function pickSendMode() {
            var $modal = $('<div class="modal fade" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">' +
                '<div class="modal-header"><h5 class="modal-title">Send to QuickBooks</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>' +
                '<div class="modal-body"><p>How should the unsent tickets in the current date range be sent?</p>' +
                '<div class="form-check"><input class="form-check-input" type="radio" name="qbMode" id="qbModeTxn" value="transaction" checked>' +
                '<label class="form-check-label" for="qbModeTxn"><strong>By Transaction</strong> &mdash; one invoice per ticket</label></div>' +
                '<div class="form-check"><input class="form-check-input" type="radio" name="qbMode" id="qbModeCom" value="commodity">' +
                '<label class="form-check-label" for="qbModeCom"><strong>Group by Commodity</strong> &mdash; one invoice per Customer + Commodity (totaled)</label></div>' +
                '<div class="alert alert-info mt-3 mb-0 py-2"><i class="fa fa-info-circle"></i> Voided tickets are never included in QuickBooks exports.</div>' +
                '</div>' +
                '<div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>' +
                '<button type="button" class="btn btn-success" id="qbModeContinue">Continue</button></div>' +
                '</div></div></div>');
            $('body').append($modal);
            var modal = new bootstrap.Modal($modal[0]);
            modal.show();
            $modal.find('#qbModeContinue').on('click', function () {
                var mode = $modal.find('input[name="qbMode"]:checked').val();
                modal.hide();
                buildAndSend(mode);
            });
            $modal.on('hidden.bs.modal', function () { $modal.remove(); });
        }

        function flattenItems(items) {
            var rows = [];
            (items || []).forEach(function (it) {
                if (it.items || it.collapsedItems) {
                    rows = rows.concat(flattenItems(it.items || it.collapsedItems));
                } else {
                    rows.push(it);
                }
            });
            return rows;
        }

        function buildAndSend(mode) {
            // Voided tickets are filtered out by the report API, but exclude
            // them defensively here too so a future API change can't slip a
            // voided record into a QuickBooks invoice.
            var rows = flattenItems(grid.getDataSource().items()).filter(function (r) { return !r.void; });
            var unsent = rows.filter(function (r) { return !r.sentToQuickBooks; });
            var alreadySent = rows.filter(function (r) { return r.sentToQuickBooks; });

            if (rows.length === 0) {
                showAlert('No tickets in the current view.', 'info');
                return;
            }

            if (alreadySent.length > 0) {
                var msg = '<strong>' + alreadySent.length + '</strong> ticket(s) in the current view have already been sent to QuickBooks.';
                if (unsent.length > 0) {
                    msg += '<br><br>Send only the <strong>' + unsent.length + '</strong> unsent ticket(s), or include the already-sent ones too (this will create duplicate invoices in QuickBooks)?';
                } else {
                    msg += '<br><br>All visible tickets have already been sent. Resend them anyway? This will create duplicate invoices in QuickBooks.';
                }
                var $w = $('<div class="modal fade" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">' +
                    '<div class="modal-header"><h5 class="modal-title">Already Sent to QuickBooks</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>' +
                    '<div class="modal-body"><p>' + msg + '</p></div>' +
                    '<div class="modal-footer">' +
                    '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="qbWarnCancel">Cancel</button>' +
                    (unsent.length > 0 ? '<button type="button" class="btn btn-primary" id="qbWarnUnsentOnly">Send Unsent Only</button>' : '') +
                    '<button type="button" class="btn btn-warning" id="qbWarnAll">Resend All</button>' +
                    '</div></div></div></div>');
                $('body').append($w);
                var wm = new bootstrap.Modal($w[0]);
                wm.show();
                $w.find('#qbWarnUnsentOnly').on('click', function () { wm.hide(); doSend(mode, unsent); });
                $w.find('#qbWarnAll').on('click', function () { wm.hide(); doSend(mode, rows); });
                $w.on('hidden.bs.modal', function () { $w.remove(); });
                return;
            }

            doSend(mode, unsent);
        }

        function doSend(mode, records) {
            if (records.length === 0) {
                showAlert('No tickets to send.', 'info');
                return;
            }

            // QuickBooks requires both Customer and Item — skip rows missing either,
            // and tell the user upfront so they can fix the underlying data.
            var skipped = records.filter(function (r) {
                return !(r.customer && String(r.customer).trim()) ||
                       !(r.commodity && String(r.commodity).trim());
            });
            var sendable = records.filter(function (r) {
                return (r.customer && String(r.customer).trim()) &&
                       (r.commodity && String(r.commodity).trim());
            });
            if (sendable.length === 0) {
                showAlert('<i class="fa fa-exclamation-triangle"></i> None of the selected tickets have both a Customer and a Commodity set. QuickBooks cannot create invoices for these.', 'danger', false);
                return;
            }

            // Truncate RefNumber to QB Desktop's 11-char limit. Customer/Commodity
            // length isn't enforced here — QB will reject names that don't exist.
            function refFor(ticket) { return String(ticket).substring(0, 11); }

            var payload;
            var summary;
            if (mode === 'commodity') {
                var groups = {};
                sendable.forEach(function (r) {
                    var cust = r.customer;
                    var com = r.commodity;
                    var key = cust + '||' + com;
                    if (!groups[key]) {
                        groups[key] = { customer: cust, commodity: com, netWeight: 0, tickets: [], latestDate: null };
                    }
                    groups[key].netWeight += Math.abs(r.netWeight || 0);
                    groups[key].tickets.push(String(r.ticket));
                    var d = r.dateOut ? new Date(r.dateOut) : null;
                    if (d && (!groups[key].latestDate || d > groups[key].latestDate)) groups[key].latestDate = d;
                });
                payload = Object.keys(groups).map(function (k) {
                    var g = groups[k];
                    // QB RefNumber max 11 chars: 'G' + first ticket, truncated.
                    return {
                        ticket: refFor('G' + g.tickets[0]),
                        customer: g.customer,
                        commodity: g.commodity,
                        netWeight: g.netWeight,
                        dateOut: g.latestDate ? g.latestDate.toISOString() : null,
                        notes: 'Grouped: ' + g.tickets.length + ' ticket(s) #' + g.tickets.join(', '),
                        underlyingTickets: g.tickets
                    };
                });
                summary = payload.length + ' grouped invoice(s) covering ' + sendable.length + ' ticket(s)';
            } else {
                payload = sendable.map(function (r) {
                    return {
                        ticket: refFor(r.ticket),
                        customer: r.customer,
                        commodity: r.commodity,
                        netWeight: Math.abs(r.netWeight || 0),
                        dateOut: r.dateOut,
                        notes: r.notes
                    };
                });
                summary = sendable.length + ' invoice(s)';
            }

            var skipNotice = '';
            if (skipped.length > 0) {
                var skippedTickets = skipped.map(function (r) { return '#' + r.ticket; }).slice(0, 10).join(', ')
                    + (skipped.length > 10 ? ', …' : '');
                skipNotice =
                    '<div class="alert alert-warning mt-3 mb-0 py-2"><i class="fa fa-exclamation-triangle"></i> ' +
                    '<strong>' + skipped.length + '</strong> ticket(s) will be skipped — they have no Customer or Commodity set: ' +
                    '<span style="font-family:monospace;">' + skippedTickets + '</span></div>';
            }

            var $confirm = $('<div class="modal fade" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">' +
                '<div class="modal-header"><h5 class="modal-title">Confirm Send</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>' +
                '<div class="modal-body"><p>Send <strong>' + summary + '</strong> to QuickBooks?</p>' + skipNotice + '</div>' +
                '<div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>' +
                '<button type="button" class="btn btn-success" id="qbConfirmSend">Send</button></div>' +
                '</div></div></div>');
            $('body').append($confirm);
            var confirmModal = new bootstrap.Modal($confirm[0]);
            confirmModal.show();
            $confirm.find('#qbConfirmSend').on('click', function () {
                confirmModal.hide();
                showAlert('<i class="fa fa-hourglass-half"></i> Sending ' + summary + ' to QuickBooks...', 'warning', false);
                qbConnection.invoke('SendTicketsToQB', payload).catch(function (err) {
                    showAlert('<i class="fa fa-times-circle"></i> Failed to send to QuickBooks: ' + err, 'danger');
                });
            });
            $confirm.on('hidden.bs.modal', function () { $confirm.remove(); });
        }

        if (useQuickBooks && typeof signalR !== 'undefined') {
            qbConnection = new signalR.HubConnectionBuilder()
                .withUrl('/scaleHub')
                .withAutomaticReconnect()
                .build();
            qbConnection.on('QBSyncStatus', function (message) {
                if (!qbErrorReceived) showAlert('<i class="fa fa-info-circle"></i> ' + message, 'info');
            });
            qbConnection.on('QBSyncComplete', function (message) {
                qbErrorReceived = false;
                $('#qb-alert-container > div').not('[data-alert-type="danger"]').remove();
                var lower = (message || '').toLowerCase();
                // The worker phrases summaries explicitly; check for "failed" and "of" together.
                var isFailure = lower.indexOf('failed to') >= 0 || /\b0 of \d+\b/.test(lower);
                var isPartial = lower.indexOf('failed:') >= 0 && !isFailure;
                var type = isFailure ? 'danger' : (isPartial ? 'warning' : 'success');
                var icon = isFailure ? 'times-circle' : (isPartial ? 'exclamation-triangle' : 'check-circle');
                // Preserve newlines from the multi-line summary.
                var html = '<i class="fa fa-' + icon + '"></i> <span style="white-space:pre-line;">' +
                    $('<div>').text(message).html() + '</span>';
                showAlert(html, type, isFailure || isPartial ? false : true);
                grid.refresh();
            });
            qbConnection.on('QBNotRunning', function (message) {
                qbErrorReceived = true;
                $('#qb-alert-container > div').not('[data-alert-type="danger"]').remove();
                showAlert('<i class="fa fa-exclamation-triangle"></i> ' + message, 'danger', false);
                setTimeout(function () { qbErrorReceived = false; }, 15000);
            });
            qbConnection.start().catch(function (err) { console.error('SignalR error:', err); });
        }
    });
</script>
@if (useBinInventory)
{
<text>
<script>
    // ===== BIN INVENTORY TAB =====
    $(function () {
        var binGrid = null;          // created lazily on first tab switch
        var binAsOf = new Date();    // inclusive as-of date (display TZ)
        var binRowsCache = [];       // last-loaded rows, for the modal's current-balance line
        var binsList = [];           // active bin names (modal dropdown)
        var commoditiesList = [];    // active commodity names (modal dropdown)

        function showPane(which) {
            $('#pane-transactions').toggle(which === 'transactions');
            $('#pane-binInventory').toggle(which === 'bin');
            $('#tabBtnTransactions').toggleClass('active', which === 'transactions');
            $('#tabBtnBinInventory').toggleClass('active', which === 'bin');
            if (which === 'bin' && !binGrid) initBinInventory();
        }
        $('#tabBtnTransactions').on('click', function () { showPane('transactions'); });
        $('#tabBtnBinInventory').on('click', function () { showPane('bin'); });

        function fmtLbs(n) { return (n == null ? 0 : Number(n)).toLocaleString('en-US'); }
        function asOfParam() { return DevExpress.localization.formatDate(binAsOf, 'yyyy-MM-dd'); }

        function initBinInventory() {
            $.getJSON('/api/masterdata/bins').done(function (data) {
                binsList = data.filter(function (b) { return b.active; }).map(function (b) { return b.binName; });
            });
            $.getJSON('/api/masterdata/commodities').done(function (data) {
                commoditiesList = data.filter(function (c) { return c.active; }).map(function (c) { return c.commodityName; });
            });

            $('#binAsOfDate').dxDateBox({
                value: binAsOf, type: 'date', displayFormat: 'MM/dd/yyyy', width: 140,
                onValueChanged: function (e) { binAsOf = e.value; binGrid.refresh(); }
            });

            $('#binAddAdjustmentBtn').dxButton({
                icon: 'edit', text: 'True Up / Adjust',
                hint: 'Record a measured total or a +/- correction for a bin',
                onClick: function () { openBinAdjModal(null); }
            });

            binGrid = $('#binInventoryGrid').dxDataGrid({
                hoverStateEnabled: true,
                dataSource: new DevExpress.data.CustomStore({
                    key: '__key',
                    load: function () {
                        return $.getJSON('/api/reports/bin-inventory', { asOfDate: asOfParam() }).then(function (rows) {
                            rows.forEach(function (r) { r.__key = r.bin + '||' + (r.commodity || ''); });
                            binRowsCache = rows;
                            return rows;
                        });
                    }
                }),
                columns: [
                    { dataField: 'bin', caption: 'Bin', sortOrder: 'asc', sortIndex: 0 },
                    { dataField: 'commodity', caption: 'Commodity', sortOrder: 'asc', sortIndex: 1,
                      calculateDisplayValue: function (r) { return r.commodity || '—'; } },
                    { dataField: 'loadsIn', caption: 'Loads In', dataType: 'number', width: 100 },
                    { dataField: 'lbsIn', caption: 'In (lbs)', dataType: 'number', format: '#,##0', width: 120 },
                    { dataField: 'loadsOut', caption: 'Loads Out', dataType: 'number', width: 100 },
                    { dataField: 'lbsOut', caption: 'Out (lbs)', dataType: 'number', format: '#,##0', width: 120 },
                    { dataField: 'adjustmentLbs', caption: 'Adjustments (lbs)', dataType: 'number', format: '#,##0', width: 140 },
                    { dataField: 'onHandLbs', caption: 'On Hand (lbs)', dataType: 'number', format: '#,##0', width: 140,
                      cssClass: 'fw-bold',
                      cellTemplate: function (container, options) {
                          $('<span>').text(fmtLbs(options.value))
                              .css(options.value < 0 ? { color: '#c53030', fontWeight: 'bold' } : { fontWeight: 'bold' })
                              .appendTo(container);
                      } },
                    { dataField: 'onHandTons', caption: 'On Hand (tons)', dataType: 'number', format: '#,##0.00', width: 130 },
                    {
                        caption: '', width: 110, allowFiltering: false, allowSorting: false, allowExporting: false,
                        cellTemplate: function (container, options) {
                            $('<button type="button" class="grid-action-btn btn btn-sm btn-outline-primary py-0">True Up</button>')
                                .on('click', function () { openBinAdjModal(options.data); })
                                .appendTo(container);
                        }
                    }
                ],
                summary: {
                    totalItems: [
                        { column: 'lbsIn', summaryType: 'sum', valueFormat: '#,##0', displayFormat: 'In: {0} lbs' },
                        { column: 'lbsOut', summaryType: 'sum', valueFormat: '#,##0', displayFormat: 'Out: {0} lbs' },
                        { column: 'onHandLbs', summaryType: 'sum', valueFormat: '#,##0', displayFormat: 'On hand: {0} lbs' }
                    ]
                },
                masterDetail: {
                    enabled: true,
                    template: function (container, options) {
                        var row = options.data;
                        $('<div>').dxDataGrid({
                            dataSource: new DevExpress.data.CustomStore({
                                loadMode: 'raw',
                                load: function () {
                                    return $.getJSON('/api/reports/bin-inventory/detail', {
                                        bin: row.bin, commodity: row.commodity || '', asOfDate: asOfParam()
                                    });
                                }
                            }),
                            showBorders: true,
                            columnAutoWidth: true,
                            paging: { pageSize: 10 },
                            columns: [
                                { dataField: 'date', caption: 'Date', dataType: 'datetime', format: 'MM/dd/yyyy hh:mm a', width: 160, sortOrder: 'desc' },
                                { dataField: 'type', caption: 'Type', width: 110 },
                                { dataField: 'reference', caption: 'Reference' },
                                { dataField: 'lbs', caption: 'Change (lbs)', dataType: 'number', width: 130,
                                  cellTemplate: function (c, o) {
                                      var v = o.value || 0;
                                      $('<span>').text((v > 0 ? '+' : '') + fmtLbs(v))
                                          .css({ color: v < 0 ? '#c53030' : '#2f855a', fontWeight: 'bold' })
                                          .appendTo(c);
                                  } },
                                {
                                    caption: '', width: 90, allowFiltering: false, allowSorting: false,
                                    cellTemplate: function (c, o) {
                                        // Only manual adjustments can be removed here — tickets
                                        // are corrected on the Completed page.
                                        if (o.data.adjustmentId == null) return;
                                        $('<button type="button" class="btn btn-sm btn-outline-danger py-0">Remove</button>')
                                            .on('click', function () {
                                                if (!confirm('Remove this adjustment?')) return;
                                                $.ajax({ url: '/api/reports/bin-adjustments/' + o.data.adjustmentId, method: 'DELETE' })
                                                    .done(function () {
                                                        o.component.refresh();
                                                        binGrid.refresh();
                                                    });
                                            })
                                            .appendTo(c);
                                    }
                                }
                            ]
                        }).appendTo(container);
                    }
                },
                showBorders: true,
                filterRow: { visible: true },
                headerFilter: { visible: true },
                allowColumnReordering: true,
                allowColumnResizing: true,
                columnAutoWidth: true,
                paging: { pageSize: 50 },
                export: { enabled: false }
            }).dxDataGrid('instance');
        }

        // ===== True Up / Adjust modal =====
        function currentBalanceFor(bin, commodity) {
            var row = binRowsCache.find(function (r) {
                return r.bin === bin && (r.commodity || '') === (commodity || '');
            });
            return row ? row.onHandLbs : 0;
        }

        function fillSelect($sel, items, selected, emptyLabel) {
            $sel.empty();
            if (emptyLabel !== undefined) $sel.append($('<option>').val('').text(emptyLabel));
            // Keep a value that's no longer in master data selectable so a
            // retired bin/commodity row can still be trued up.
            var all = items.slice();
            if (selected && all.indexOf(selected) === -1) all.unshift(selected);
            all.forEach(function (name) {
                $sel.append($('<option>').val(name).text(name).prop('selected', name === selected));
            });
        }

        function syncBinAdjModal() {
            var mode = $('input[name="binAdjMode"]:checked').val();
            $('#binAdjAmountLabel').text(mode === 'trueup' ? 'Measured amount on hand (lbs)' : 'Adjustment amount (lbs, +/-)');
            $('#binAdjAmountHint').text(mode === 'trueup'
                ? 'The difference from the computed balance is recorded as an adjustment.'
                : 'Positive adds to the bin, negative deducts (e.g. -1500 for shrinkage).');
            var bin = $('#binAdjBin').val();
            var commodity = $('#binAdjCommodity').val();
            $('#binAdjCurrent').text(bin
                ? 'Computed balance for ' + bin + (commodity ? ' / ' + commodity : '') + ': ' + fmtLbs(currentBalanceFor(bin, commodity)) + ' lbs'
                : '');
        }

        function openBinAdjModal(row) {
            fillSelect($('#binAdjBin'), binsList, row ? row.bin : null);
            fillSelect($('#binAdjCommodity'), commoditiesList, row ? (row.commodity || '') : '', '— None —');
            $('#binAdjModeTrueUp').prop('checked', true);
            $('#binAdjAmount').val('');
            $('#binAdjNote').val('');
            $('#binAdjError').hide();
            $('#binAdjTitle').text(row ? ('True Up — ' + row.bin) : 'Bin Adjustment');
            syncBinAdjModal();
            new bootstrap.Modal('#binAdjModal').show();
        }

        $('input[name="binAdjMode"], #binAdjBin, #binAdjCommodity').on('change', syncBinAdjModal);

        $('#binAdjSaveBtn').on('click', function () {
            var bin = $('#binAdjBin').val();
            var amountRaw = $('#binAdjAmount').val();
            var amount = parseInt(amountRaw, 10);
            var mode = $('input[name="binAdjMode"]:checked').val();
            var $err = $('#binAdjError');
            if (!bin) { $err.text('Pick a bin.').show(); return; }
            if (amountRaw === '' || isNaN(amount)) { $err.text('Enter an amount in pounds.').show(); return; }
            if (mode === 'adjust' && amount === 0) { $err.text('An adjustment of 0 lbs does nothing.').show(); return; }
            var $btn = $(this).prop('disabled', true);
            $.ajax({
                url: '/api/reports/bin-adjustments',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    bin: bin,
                    commodity: $('#binAdjCommodity').val() || null,
                    mode: mode,
                    amountLbs: amount,
                    note: $('#binAdjNote').val() || null
                })
            }).done(function () {
                bootstrap.Modal.getInstance(document.getElementById('binAdjModal')).hide();
                if (binGrid) binGrid.refresh();
            }).fail(function (xhr) {
                var msg = 'Save failed.';
                try { msg = JSON.parse(xhr.responseText).message || msg; } catch (e) { }
                $err.text(msg).show();
            }).always(function () {
                $btn.prop('disabled', false);
            });
        });
    });
</script>
</text>
}
