                return cols;
            })(),
            summary: {
                totalItems: [
                    { column: 'ticket', summaryType: 'count', displayFormat: 'Loads: {0}' },
                    { column: 'netWeight', summaryType: 'sum', valueFormat: '#,##0', displayFormat: 'Total: {0} lbs' },
                    { column: 'netTons', summaryType: 'sum', valueFormat: '#,##0.00', displayFormat: 'Total: {0} tons' }
                ],
                groupItems: [
                    { column: 'ticket', summaryType: 'count', displayFormat: '{0} loads' },
                    { column: 'netWeight', summaryType: 'sum', valueFormat: '#,##0', displayFormat: '{0} lbs' },
                    { column: 'netTons', summaryType: 'sum', valueFormat: '#,##0.00', displayFormat: '{0} tons' }
                ]
            },
            showBorders: true,
            filterRow: { visible: true },
            headerFilter: { visible: true },
            filterPanel: { visible: true },
            searchPanel: { visible: true, width: 200 },
            sorting: { mode: 'multiple' },
            allowColumnReordering: true,
            allowColumnResizing: true,
            columnResizingMode: 'widget',
            columnAutoWidth: true,
            columnMinWidth: 150,
            columnChooser: { enabled: true, mode: 'select' },
            stateStoring: {
                enabled: true,
