@{
    ViewData["Title"] = "Scale Management";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0">Scale Management</h3>
    <div class="d-flex align-items-center gap-2">
        <!-- Live status of the device-definitions cache served by the
             connected Scale Reader Service. Updated by ScaleBrandsReceived.
             Clicking the pill triggers the same refresh as the button. -->
        <span id="brandsSourceStatus"
              role="button"
              tabindex="0"
              class="badge bg-secondary"
              title="Where the latest scale brand/model list came from. Click to refresh."
              style="cursor:pointer;"
              onclick="refreshScaleBrands()"
              onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();refreshScaleBrands();}">
            <i class="fa fa-spinner fa-spin me-1"></i>Definitions: loading…
        </span>
        <button id="refreshBrandsBtn"
                type="button"
                class="btn btn-outline-primary btn-sm"
                onclick="refreshScaleBrands()"
                title="Re-fetch scale brand/model definitions from the device-definitions repo">
            <i class="fa fa-cloud-download-alt"></i> Refresh Definitions
        </button>
        <a href="/Setup" class="btn btn-outline-secondary btn-sm"><i class="fa fa-arrow-left"></i> Back to Setup</a>
    </div>
</div>

<!-- Site Scales (named scales, grain-management style) -->
<div class="card mb-3">
    <div class="card-header py-2 d-flex justify-content-between align-items-center">
        <strong>Site Scales</strong>
        <button type="button" class="btn btn-outline-primary btn-sm py-0" onclick="addSiteScale()"><i class="fa fa-plus"></i> Add Scale</button>
    </div>
    <div class="card-body py-2">
        <p class="small text-muted mb-2">
            Named scales the operators pick on the weigh forms and kiosks;
            tickets record the scale name with each weighment. Link each scale
            to a hardware feed from a connected reader service below — a scale
            with no feed is driven by the simulator in Demo Mode. Changes save
            immediately.
        </p>
        <table class="table table-sm align-middle mb-0" id="siteScalesTable">
            <thead>
                <tr class="small text-muted">
                    <th>Name</th><th>Hardware Feed</th>
                    <th style="width:90px;">Order</th>
                    <th style="width:70px;" class="text-center">Active</th>
                    <th style="width:70px;"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <div id="siteScaleStatus" class="small mt-1">&nbsp;</div>
    </div>
</div>

<!-- Status bar -->
<div id="serviceStatusBar" class="alert alert-warning py-2 mb-3 d-flex align-items-center">
    <i class="fa fa-spinner fa-spin me-2"></i> Checking scale services...
</div>

<!-- Toast container -->
<div id="scaleToastContainer" style="position:fixed;top:70px;right:20px;z-index:9999;min-width:350px;max-width:500px;"></div>

<!-- Services container -->
<div id="servicesContainer"></div>

<!-- No services message -->
<div id="noServicesMessage" class="text-center text-muted py-5" style="display:none;">
    <i class="fa fa-balance-scale fa-3x mb-3 d-block"></i>
    <h5>No Scale Services Connected</h5>
    <p>Start a Scale Reader Service and point it to this server's SignalR hub.</p>
</div>

<!-- Add/Edit Scale Modal -->
<div class="modal fade" id="scaleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="scaleModalTitle">Add Scale</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="scaleModalServiceId" />
                <input type="hidden" id="scaleModalMode" value="add" />
                <input type="hidden" id="scaleModalOriginalId" />
                <div class="mb-2">
                    <label class="form-label mb-0 small">Scale ID</label>
                    <input type="text" class="form-control form-control-sm" id="scaleScaleId" placeholder="e.g. truck-scale-1" />
                </div>
                <div class="mb-2">
                    <label class="form-label mb-0 small">Display Name</label>
                    <input type="text" class="form-control form-control-sm" id="scaleDisplayName" placeholder="e.g. Truck Scale 1" />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-12">
                        <label class="form-label mb-0 small">Brand / Model</label>
                        <select class="form-select form-select-sm" id="scaleBrand">
                            <option value="Generic SMA">Generic SMA</option>
                        </select>
                    </div>
                </div>

                <!-- TCP fields -->
                <div id="scaleTcpFields">
                    <div class="row g-2 mb-2">
                        <div class="col-8">
                            <label class="form-label mb-0 small">IP Address</label>
                            <input type="text" class="form-control form-control-sm" id="scaleIp" placeholder="Enter IP address" />
                        </div>
                        <div class="col-4">
                            <label class="form-label mb-0 small">Port</label>
                            <input type="number" class="form-control form-control-sm" id="scalePort" value="10001" min="1" max="65535" />
                        </div>
                    </div>
                </div>

                <!-- Serial fields -->
                <div id="scaleSerialFields" style="display:none;">
                    <div class="row g-2 mb-2">
                        <div class="col-12">
                            <label class="form-label mb-0 small">Serial Port</label>
                            <input type="text" class="form-control form-control-sm" id="scaleSerialPortName" placeholder="COM1 (Windows) or /dev/ttyUSB0 (Linux)" />
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-3">
                            <label class="form-label mb-0 small">Baud</label>
                            <input type="number" class="form-control form-control-sm" id="scaleBaudRate" value="9600" min="300" max="921600" />
                        </div>
                        <div class="col-3">
                            <label class="form-label mb-0 small">Data Bits</label>
                            <select class="form-select form-select-sm" id="scaleDataBits">
                                <option value="7">7</option>
                                <option value="8" selected>8</option>
                            </select>
                        </div>
                        <div class="col-3">
                            <label class="form-label mb-0 small">Parity</label>
                            <select class="form-select form-select-sm" id="scaleParity">
                                <option value="None" selected>None</option>
                                <option value="Even">Even</option>
                                <option value="Odd">Odd</option>
                                <option value="Mark">Mark</option>
                                <option value="Space">Space</option>
                            </select>
                        </div>
                        <div class="col-3">
                            <label class="form-label mb-0 small">Stop Bits</label>
                            <select class="form-select form-select-sm" id="scaleStopBits">
                                <option value="1" selected>1</option>
                                <option value="2">2</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label mb-0 small">Request Command (optional override)</label>
                    <input type="text" class="form-control form-control-sm" id="scaleRequestCommand" placeholder="W\r\n (leave blank for brand default; ignored for streaming protocols)" />
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-4">
                        <label class="form-label mb-0 small">Poll Interval (ms)</label>
                        <input type="number" class="form-control form-control-sm" id="scalePollingInterval" value="750" min="100" max="10000" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Timeout (ms)</label>
                        <input type="number" class="form-control form-control-sm" id="scaleTimeout" value="1000" min="100" max="10000" />
                    </div>
                    <div class="col-4">
                        <label class="form-label mb-0 small">Active</label>
                        <select class="form-select form-select-sm" id="scaleActive">
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                    </div>
                </div>
                <div id="brandNotes" class="small text-muted" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" onclick="saveScale()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Live Weight Modal -->
<div class="modal fade" id="liveWeightModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">Live Weight — <span id="liveWeightScaleName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div style="background-color:#000;border-radius:16px;padding:20px 40px;max-width:500px;margin:0 auto;">
                    <div id="liveWeightDisplay" style="font-family:'Courier New',monospace;font-size:clamp(2.5rem,5vw,4rem);font-weight:bold;color:#0f0;text-align:right;letter-spacing:4px;white-space:nowrap;">
                        <span id="liveWeightValue">0</span>
                        <span style="font-size:2rem;color:#0a0;margin-left:10px;" id="liveWeightUnit">lb</span>
                    </div>
                    <div id="liveWeightStatus" style="font-size:1.2rem;font-weight:bold;text-align:center;letter-spacing:2px;min-height:1.4em;margin-top:8px;"></div>
                </div>
                <div class="mt-3 text-start">
                    <a class="small text-muted" data-bs-toggle="collapse" href="#rawDiag" role="button"><i class="fa fa-terminal"></i> Diagnostic</a>
                    <div class="collapse mt-1" id="rawDiag">
                        <div class="bg-dark text-light p-2 rounded" style="font-family:'Courier New',monospace;font-size:12px;">
                            <div>Raw: <span id="diagRawText" style="color:#0f0;">--</span></div>
                            <div>Hex: <span id="diagRawHex" style="color:#888;">--</span></div>
                            <div>Parsed: <span id="diagParsed" style="color:#ff0;">--</span></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/signalr/signalr.min.js"></script>
<script>
    var connectedServices = {};
    var scaleBrands = [];
    var savedScaleId = '@(ViewBag.ScaleId ?? "")';
    var liveWeightScaleId = null;

    function escHtml(s) { return s ? s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : ''; }
    function escAttr(s) { return s ? s.replace(/'/g,"\\'").replace(/"/g,'&quot;') : ''; }

    // ===== SIGNALR =====
    var connection = new signalR.HubConnectionBuilder().withUrl('/scaleHub').build();

    connection.on('ScaleServiceReady', function (data) {
        connectedServices[data.serviceId] = data;
        renderServices();
        updateStatusBar();
    });

    connection.on('ScaleListReceived', function (data) {
        connectedServices[data.serviceId] = data;
        renderServices();
        updateStatusBar();
    });

    connection.on('ScaleServiceStatusChanged', function (serviceIds) {
        // Remove disconnected services
        Object.keys(connectedServices).forEach(function (sid) {
            if (serviceIds.indexOf(sid) < 0) delete connectedServices[sid];
        });
        updateStatusBar();
        renderServices();
    });

    connection.on('ScaleWeight', function (data) {
        // Update live weight modal if open for this scale
        if (liveWeightScaleId && data.scaleId === liveWeightScaleId) {
            var weightVal = document.getElementById('liveWeightValue');
            var weightUnit = document.getElementById('liveWeightUnit');
            var status = document.getElementById('liveWeightStatus');
            if (data.ok) {
                weightVal.textContent = data.weight.toLocaleString();
                weightVal.style.color = data.motion ? '#ffc107' : '#0f0';
                weightUnit.style.color = data.motion ? '#cc9900' : '#0a0';

                // Use the service-supplied status when it's more specific than the
                // generic "Ok" / "Motion" defaults (e.g. "Below Zero", ">0<").
                var statusText, statusColor;
                if (data.status && data.status !== 'Ok' && data.status !== 'Motion') {
                    statusText = String(data.status).toUpperCase();
                    statusColor = '#0dcaf0'; // info cyan
                } else if (data.motion) {
                    statusText = 'MOTION';
                    statusColor = '#ffc107';
                } else {
                    statusText = 'STABLE';
                    statusColor = '#0a0';
                }
                status.innerHTML = '<span style="color:' + statusColor + ';">' + escHtml(statusText) + '</span>';
            } else {
                weightVal.textContent = '---';
                weightVal.style.color = '#f00';
                weightUnit.style.color = '#a00';
                var errText = (data.status ? String(data.status).toUpperCase() : 'ERROR');
                status.innerHTML = '<span style="color:#f00;">' + escHtml(errText) + '</span>';
            }
            // Update diagnostic raw response
            var rawText = document.getElementById('diagRawText');
            var rawHex = document.getElementById('diagRawHex');
            var parsed = document.getElementById('diagParsed');
            if (rawText) rawText.textContent = data.rawResponse || '--';
            if (rawHex) rawHex.textContent = data.rawHex || '--';
            if (parsed) parsed.textContent = 'weight=' + data.weight + ' motion=' + data.motion + ' ok=' + data.ok + ' status=' + data.status;
        }
    });

    connection.on('ScaleCrudResult', function (data) {
        showToast(data.success ? 'success' : 'danger', data.message || (data.success ? 'Done' : 'Failed'));
        if (data.success) {
            connection.invoke('RequestScaleList').catch(function () {});
        }
    });

    // Tracks the manual-refresh state so the watchdog timer can show a
    // helpful toast if no scale service responds (e.g. none connected).
    var pendingManualRefresh = null;

    connection.on('ScaleBrandsReceived', function (payload) {
        // Newer scale-reader-service wraps the list as { brands, source, error };
        // older versions send the array directly — handle both.
        var list, source, error;
        if (Array.isArray(payload)) { list = payload; source = 'unknown'; error = null; }
        else if (payload && Array.isArray(payload.brands)) {
            list = payload.brands; source = payload.source; error = payload.error;
        } else { list = []; source = 'unknown'; error = null; }
        scaleBrands = list;
        populateScaleBrandDropdown();
        updateBrandsSourceStatus(source, error, list.length);
        // Re-enable the Refresh button if it was disabled during a manual refresh.
        var btn = document.getElementById('refreshBrandsBtn');
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-cloud-download-alt"></i> Refresh Definitions'; }
        // If the operator clicked Refresh, surface the outcome explicitly —
        // the green pill alone is too easy to miss.
        if (pendingManualRefresh) {
            clearTimeout(pendingManualRefresh);
            pendingManualRefresh = null;
            if (source === 'remote') {
                showToast('success', 'Definitions refreshed — ' + list.length + ' brand(s) loaded from device-definitions.');
            } else if (source === 'local') {
                showToast('warning', 'Could not refresh from device-definitions — using cached copy (' + list.length + ' brand(s))'
                    + (error ? ': ' + error : '.'));
            } else {
                showToast('info', list.length + ' brand(s) loaded (older Scale Reader Service did not report a source).');
            }
        } else if (source === 'local' && error) {
            // Auto-refresh on page load: only warn (don't spam a success toast).
            showToast('warning', 'Using cached scale brands — could not refresh from device-definitions: ' + error);
        }
    });

    // Remembered so the watchdog reset path can restore the previous label
    // (otherwise the pill flips to "unknown" after a timeout even though
    // the last successful fetch was 'remote' or 'local').
    var lastBrandsSource = null;

    // Reflect the result of the most recent RequestScaleBrands round-trip
    // in the header pill so operators can tell at a glance whether the
    // brand list is live or stale.
    function updateBrandsSourceStatus(source, error, count) {
        var el = document.getElementById('brandsSourceStatus');
        if (!el) return;
        var when = new Date().toLocaleTimeString();
        if (source === 'remote') {
            el.className = 'badge bg-success';
            el.innerHTML = '<i class="fa fa-cloud me-1"></i>Definitions: live (' + count + ') · ' + when;
            el.title = 'Latest list fetched from the device-definitions repo at ' + when + '. Click to refresh.';
        } else if (source === 'local') {
            el.className = 'badge bg-warning text-dark';
            el.innerHTML = '<i class="fa fa-hdd me-1"></i>Definitions: cached (' + count + ') · ' + when;
            el.title = 'Scale Reader Service could not reach the device-definitions repo and is serving its on-disk cache. Click to retry.'
                + (error ? ' Error: ' + error : '');
        } else {
            el.className = 'badge bg-secondary';
            el.innerHTML = '<i class="fa fa-question-circle me-1"></i>Definitions: ' + count + ' · ' + when;
            el.title = 'Connected Scale Reader Service did not report a source — probably an older build. Click to refresh.';
        }
        if (source === 'remote' || source === 'local') lastBrandsSource = source;
    }

    // Reset the header pill and the refresh button to their idle state.
    // Used by the watchdog when the request times out and by the SignalR
    // catch handler when the invoke itself fails.
    function resetBrandsRefreshUI() {
        var btn = document.getElementById('refreshBrandsBtn');
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-cloud-download-alt"></i> Refresh Definitions'; }
        // Best-effort: replay the last known status. If we never had one,
        // updateBrandsSourceStatus with 'unknown' + 0 leaves a sensible label.
        updateBrandsSourceStatus(lastBrandsSource || 'unknown', null, scaleBrands.length);
    }

    // Manual refresh — re-invokes the same SignalR call that runs on page
    // load. The Scale Reader Service handles RequestScaleBrands by calling
    // BrandsCache.RefreshAsync(), which re-fetches the JSON from GitHub.
    // Watchdog: if no ScaleBrandsReceived comes back within 10 s (typically
    // because no Scale Reader Service is connected), warn the operator and
    // restore the UI so it doesn't spin forever.
    window.refreshScaleBrands = function () {
        var btn = document.getElementById('refreshBrandsBtn');
        if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Refreshing…'; }
        var pill = document.getElementById('brandsSourceStatus');
        if (pill) {
            pill.className = 'badge bg-secondary';
            pill.innerHTML = '<i class="fa fa-spinner fa-spin me-1"></i>Definitions: refreshing…';
        }
        if (pendingManualRefresh) { clearTimeout(pendingManualRefresh); }
        pendingManualRefresh = setTimeout(function () {
            pendingManualRefresh = null;
            var connected = Object.keys(connectedServices).length;
            if (connected === 0) {
                showToast('danger', 'No Scale Reader Service is connected — start a service and point it at this server\'s SignalR hub, then try again.');
            } else {
                showToast('warning', 'No response from the Scale Reader Service after 10 s. Check the service log and try again.');
            }
            resetBrandsRefreshUI();
        }, 10000);
        connection.invoke('RequestScaleBrands').catch(function (err) {
            if (pendingManualRefresh) { clearTimeout(pendingManualRefresh); pendingManualRefresh = null; }
            showToast('danger', 'Refresh failed: ' + err);
            resetBrandsRefreshUI();
        });
    };

    connection.start().then(function () {
        connection.invoke('RequestScaleList').catch(function () {});
        connection.invoke('RequestScaleBrands').catch(function () {});
    });

    // ===== STATUS BAR =====
    function updateStatusBar() {
        var bar = document.getElementById('serviceStatusBar');
        var noMsg = document.getElementById('noServicesMessage');
        var count = Object.keys(connectedServices).length;
        if (count > 0) {
            bar.className = 'alert alert-success py-2 mb-3 d-flex align-items-center';
            bar.innerHTML = '<i class="fa fa-check-circle me-2"></i> <strong>' + count + ' Scale Service(s) Connected</strong>';
            noMsg.style.display = 'none';
        } else {
            bar.className = 'alert alert-warning py-2 mb-3 d-flex align-items-center';
            bar.innerHTML = '<i class="fa fa-exclamation-triangle me-2"></i> <strong class="text-danger">No Scale Services Connected</strong>' +
                '— Start a Scale Reader Service and point it to this server\'s SignalR hub.';
            noMsg.style.display = 'block';
        }
    }
    setTimeout(function () { if (Object.keys(connectedServices).length === 0) updateStatusBar(); }, 3000);

    // ===== RENDER SERVICES =====
    function renderServices() {
        var container = document.getElementById('servicesContainer');
        var html = '';
        updateAssignmentDropdown();

        Object.keys(connectedServices).forEach(function (serviceId) {
            var svc = connectedServices[serviceId];
            var cams = svc.scales || [];

            html += '<div class="card mb-3"><div class="card-header py-2 d-flex justify-content-between align-items-center">';
            html += '<div><span class="badge bg-success me-2">Connected</span> <strong>' + escHtml(serviceId) + '</strong>';
            html += ' <span class="text-muted">(' + cams.length + ' scale' + (cams.length !== 1 ? 's' : '') + ')</span></div>';
            html += '<button class="btn btn-outline-primary btn-sm" onclick="addScale(\'' + escAttr(serviceId) + '\')"><i class="fa fa-plus"></i> Add Scale</button>';
            html += '</div><div class="card-body p-0"><table class="table table-sm table-striped mb-0">';
            html += '<thead><tr><th>Scale ID</th><th>Display Name</th><th>Brand</th><th>IP : Port</th>';
            html += '<th>Active</th><th style="width:200px;">Actions</th></tr></thead><tbody>';

            cams.forEach(function (s) {
                html += '<tr>';
                html += '<td>' + escHtml(s.scaleId) + '</td>';
                html += '<td>' + escHtml(s.displayName) + '</td>';
                html += '<td>' + escHtml(s.scaleBrand) + '</td>';
                html += '<td>' + escHtml(s.ipAddress) + ':' + s.port + '</td>';
                html += '<td>' + (s.active ? '<span class="text-success fw-bold">&#10003;</span>' : '<span class="text-muted">&#10007;</span>') + '</td>';
                html += '<td>';
                html += '<button class="btn btn-outline-info btn-sm me-1" onclick="showLiveWeight(\'' + escAttr(serviceId) + '\',\'' + escAttr(s.scaleId) + '\',\'' + escAttr(s.displayName) + '\')"><i class="fa fa-tachometer"></i> Live</button>';
                html += '<button class="btn btn-outline-warning btn-sm me-1" onclick="editScale(\'' + escAttr(serviceId) + '\',\'' + escAttr(s.scaleId) + '\')">Edit</button>';
                html += '<button class="btn btn-outline-danger btn-sm" onclick="deleteScale(\'' + escAttr(serviceId) + '\',\'' + escAttr(s.scaleId) + '\')">Delete</button>';
                html += '</td></tr>';
            });

            html += '</tbody></table></div></div>';
        });

        container.innerHTML = html;
    }

    // ===== SITE SCALES (named scales the forms and kiosks pick from) =====
    var siteScales = [];
    var siteScaleStatusTimer = null;

    function siteScaleStatus(msg, isError) {
        var el = document.getElementById('siteScaleStatus');
        clearTimeout(siteScaleStatusTimer);
        el.innerHTML = '<span class="' + (isError ? 'text-danger' : 'text-success') + '">' + escHtml(msg) + '</span>';
        if (!isError) siteScaleStatusTimer = setTimeout(function () { el.innerHTML = '&nbsp;'; }, 2000);
    }

    function loadSiteScales() {
        fetch('/api/scales').then(function (r) { return r.json(); }).then(function (list) {
            siteScales = list;
            renderSiteScales();
        });
    }

    function hardwareOptionsHtml(current) {
        var options = '<option value="">— Simulator / none —</option>';
        var found = false;
        Object.keys(connectedServices).forEach(function (sid) {
            (connectedServices[sid].scales || []).forEach(function (s) {
                if (!s.active) return;
                var val = sid + ':' + s.scaleId;
                if (val === current) found = true;
                var label = s.displayName || s.scaleId;
                if (Object.keys(connectedServices).length > 1) label += ' (' + sid + ')';
                options += '<option value="' + escAttr(val) + '"' + (val === current ? ' selected' : '') + '>' + escHtml(label) + '</option>';
            });
        });
        // Keep an assignment visible even while its reader service is offline.
        if (current && !found)
            options += '<option value="' + escAttr(current) + '" selected>' + escHtml(current) + ' (offline)</option>';
        return options;
    }

    function renderSiteScales() {
        var tbody = document.querySelector('#siteScalesTable tbody');
        var html = '';
        siteScales.forEach(function (s) {
            html += '<tr data-id="' + s.id + '">'
                + '<td><input class="form-control form-control-sm ss-name" maxlength="50" value="' + escHtml(s.name) + '"></td>'
                + '<td><select class="form-select form-select-sm ss-hw">' + hardwareOptionsHtml(s.hardwareId || '') + '</select></td>'
                + '<td><input type="number" step="1" class="form-control form-control-sm ss-order" value="' + s.sortOrder + '"></td>'
                + '<td class="text-center"><input type="checkbox" class="form-check-input ss-active"' + (s.active ? ' checked' : '') + '></td>'
                + '<td class="text-end"><button type="button" class="btn btn-outline-danger btn-sm py-0" onclick="deleteSiteScale(' + s.id + ')">Delete</button></td>'
                + '</tr>';
        });
        tbody.innerHTML = html;
        tbody.querySelectorAll('input, select').forEach(function (el) {
            el.addEventListener('change', function () { saveSiteScaleRow(el.closest('tr')); });
        });
    }

    function saveSiteScaleRow(tr) {
        var id = parseInt(tr.dataset.id);
        var body = {
            id: id,
            name: tr.querySelector('.ss-name').value.trim(),
            hardwareId: tr.querySelector('.ss-hw').value || null,
            sortOrder: parseInt(tr.querySelector('.ss-order').value) || 0,
            active: tr.querySelector('.ss-active').checked
        };
        fetch('/api/scales/' + id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        }).then(function (r) {
            if (!r.ok) return r.json().then(function (e) { throw new Error(e.error || 'Save failed.'); });
            siteScaleStatus('Saved ✓', false);
            loadSiteScales();
        }).catch(function (e) {
            siteScaleStatus(e.message, true);
            loadSiteScales(); // revert the row to server state
        });
    }

    function addSiteScale() {
        var n = siteScales.length + 1;
        var name = 'Scale ' + n;
        while (siteScales.some(function (s) { return s.name === name; })) { n++; name = 'Scale ' + n; }
        var maxOrder = siteScales.reduce(function (m, s) { return Math.max(m, s.sortOrder); }, 0);
        fetch('/api/scales', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, hardwareId: null, sortOrder: maxOrder + 10, active: true })
        }).then(function (r) {
            if (!r.ok) return r.json().then(function (e) { throw new Error(e.error || 'Add failed.'); });
            loadSiteScales();
        }).catch(function (e) { siteScaleStatus(e.message, true); });
    }

    function deleteSiteScale(id) {
        if (!confirm('Delete this scale? Existing tickets keep the recorded scale name.')) return;
        fetch('/api/scales/' + id, { method: 'DELETE' }).then(function (r) {
            if (!r.ok) return r.json().then(function (e) { throw new Error(e.error || 'Delete failed.'); });
            loadSiteScales();
        }).catch(function (e) { siteScaleStatus(e.message, true); });
    }

    loadSiteScales();

    // Reader-service lists changed — refresh the hardware-feed dropdowns.
    function updateAssignmentDropdown() {
        renderSiteScales();
    }

    // ===== BRAND DROPDOWN =====
    function brandKey(b) { return b.model ? (b.brand + ' — ' + b.model) : b.brand; }
    function brandLabel(b) {
        var label = brandKey(b);
        if (b.type) label += ' (' + b.type + ')';
        return label;
    }

    function populateScaleBrandDropdown() {
        var sel = document.getElementById('scaleBrand');
        var currentVal = sel.value;
        sel.innerHTML = '';
        scaleBrands.forEach(function (b) {
            var opt = document.createElement('option');
            opt.value = brandKey(b);
            opt.textContent = brandLabel(b);
            sel.appendChild(opt);
        });
        if (currentVal && Array.from(sel.options).some(function (o) { return o.value === currentVal; })) {
            sel.value = currentVal;
        }
        toggleScaleBrandFields(false);
    }

    function findBrandDef(key) {
        return scaleBrands.find(function (b) { return brandKey(b) === key; });
    }

    function toggleScaleBrandFields(applyDefaults) {
        var key = document.getElementById('scaleBrand').value;
        var def = findBrandDef(key);
        var type = def && def.type ? def.type : 'TCP';
        var isSerial = type === 'Serial';

        document.getElementById('scaleTcpFields').style.display = isSerial ? 'none' : '';
        document.getElementById('scaleSerialFields').style.display = isSerial ? '' : 'none';

        var notesEl = document.getElementById('brandNotes');
        if (def && def.notes) {
            notesEl.textContent = def.notes;
            notesEl.style.display = '';
        } else {
            notesEl.style.display = 'none';
        }

        if (applyDefaults && def) {
            if (isSerial) {
                if (def.baudRate)  document.getElementById('scaleBaudRate').value  = def.baudRate;
                if (def.dataBits)  document.getElementById('scaleDataBits').value  = def.dataBits;
                if (def.parity)    document.getElementById('scaleParity').value    = def.parity;
                if (def.stopBits)  document.getElementById('scaleStopBits').value  = def.stopBits;
            } else {
                if (def.defaultPort) document.getElementById('scalePort').value = def.defaultPort;
            }
            if (def.demandCommand) {
                document.getElementById('scaleRequestCommand').placeholder =
                    def.demandCommand + ' (leave blank for brand default)';
            } else {
                document.getElementById('scaleRequestCommand').placeholder =
                    'W\\r\\n (leave blank for brand default; ignored for streaming protocols)';
            }
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('scaleBrand').addEventListener('change', function () { toggleScaleBrandFields(true); });
    });

    // ===== SCALE CRUD =====
    function addScale(serviceId) {
        if (scaleBrands.length === 0) connection.invoke('RequestScaleBrands').catch(function () {});

        document.getElementById('scaleModalServiceId').value = serviceId;
        document.getElementById('scaleModalMode').value = 'add';
        document.getElementById('scaleModalOriginalId').value = '';
        document.getElementById('scaleModalTitle').textContent = 'Add Scale';
        document.getElementById('scaleScaleId').value = '';
        document.getElementById('scaleScaleId').readOnly = false;
        document.getElementById('scaleDisplayName').value = '';
        document.getElementById('scaleBrand').value = scaleBrands.length > 0 ? brandKey(scaleBrands[0]) : 'Generic SMA';
        document.getElementById('scaleIp').value = '';
        document.getElementById('scalePort').value = '10001';
        document.getElementById('scaleSerialPortName').value = '';
        document.getElementById('scaleBaudRate').value = '9600';
        document.getElementById('scaleDataBits').value = '8';
        document.getElementById('scaleParity').value = 'None';
        document.getElementById('scaleStopBits').value = '1';
        document.getElementById('scaleRequestCommand').value = '';
        document.getElementById('scalePollingInterval').value = '750';
        document.getElementById('scaleTimeout').value = '1000';
        document.getElementById('scaleActive').value = 'true';
        toggleScaleBrandFields(true);
        new bootstrap.Modal('#scaleModal').show();
    }

    function editScale(serviceId, scaleId) {
        if (scaleBrands.length === 0) connection.invoke('RequestScaleBrands').catch(function () {});

        var svc = connectedServices[serviceId];
        if (!svc) return;
        var scale = (svc.scales || []).find(function (s) { return s.scaleId === scaleId; });
        if (!scale) return;

        document.getElementById('scaleModalServiceId').value = serviceId;
        document.getElementById('scaleModalMode').value = 'edit';
        document.getElementById('scaleModalOriginalId').value = scaleId;
        document.getElementById('scaleModalTitle').textContent = 'Edit Scale';
        document.getElementById('scaleScaleId').value = scale.scaleId;
        document.getElementById('scaleScaleId').readOnly = true;
        document.getElementById('scaleDisplayName').value = scale.displayName || '';
        document.getElementById('scaleBrand').value = scale.scaleBrand || 'Generic SMA';
        document.getElementById('scaleIp').value = scale.ipAddress || '';
        document.getElementById('scalePort').value = scale.port || 10001;
        document.getElementById('scaleSerialPortName').value = scale.serialPortName || '';
        document.getElementById('scaleBaudRate').value = scale.baudRate || 9600;
        document.getElementById('scaleDataBits').value = scale.dataBits || 8;
        document.getElementById('scaleParity').value = scale.parity || 'None';
        document.getElementById('scaleStopBits').value = scale.stopBits || 1;
        document.getElementById('scaleRequestCommand').value = scale.requestCommand || '';
        document.getElementById('scalePollingInterval').value = scale.pollingIntervalMs || 750;
        document.getElementById('scaleTimeout').value = scale.timeoutMs || 1000;
        document.getElementById('scaleActive').value = scale.active ? 'true' : 'false';
        toggleScaleBrandFields(false); // honor existing values, just show/hide field groups
        new bootstrap.Modal('#scaleModal').show();
    }

    function saveScale() {
        var mode = document.getElementById('scaleModalMode').value;
        var serviceId = document.getElementById('scaleModalServiceId').value;

        var brandKeyVal = document.getElementById('scaleBrand').value;
        var def = findBrandDef(brandKeyVal);
        var connectionType = (def && def.type === 'Serial') ? 'Serial' : 'TCP';
        var protocol = def && def.protocol ? def.protocol : 'SMA';

        var data = {
            scaleId: document.getElementById('scaleScaleId').value.trim(),
            displayName: document.getElementById('scaleDisplayName').value.trim(),
            scaleBrand: brandKeyVal,
            connectionType: connectionType,
            protocol: protocol,
            ipAddress: document.getElementById('scaleIp').value.trim(),
            port: parseInt(document.getElementById('scalePort').value) || 10001,
            serialPortName: document.getElementById('scaleSerialPortName').value.trim() || null,
            baudRate: parseInt(document.getElementById('scaleBaudRate').value) || 9600,
            dataBits: parseInt(document.getElementById('scaleDataBits').value) || 8,
            parity: document.getElementById('scaleParity').value,
            stopBits: parseInt(document.getElementById('scaleStopBits').value) || 1,
            requestCommand: document.getElementById('scaleRequestCommand').value.trim() || null,
            pollingIntervalMs: parseInt(document.getElementById('scalePollingInterval').value) || 750,
            timeoutMs: parseInt(document.getElementById('scaleTimeout').value) || 1000,
            active: document.getElementById('scaleActive').value === 'true'
        };

        if (!data.scaleId) { alert('Scale ID is required'); return; }
        if (connectionType === 'Serial' && !data.serialPortName) {
            alert('Serial Port is required for serial-connected scales (e.g. COM1, /dev/ttyUSB0)');
            return;
        }

        var method = mode === 'edit' ? 'UpdateScaleOnService' : 'AddScaleToService';
        var args = mode === 'edit'
            ? [serviceId, document.getElementById('scaleModalOriginalId').value, data]
            : [serviceId, data];

        connection.invoke.apply(connection, [method].concat(args)).then(function () {
            bootstrap.Modal.getInstance(document.getElementById('scaleModal')).hide();
        }).catch(function (err) {
            showToast('danger', 'Error: ' + err);
        });
    }

    function deleteScale(serviceId, scaleId) {
        if (!confirm('Delete scale "' + scaleId + '"?')) return;
        connection.invoke('DeleteScaleFromService', serviceId, scaleId).catch(function (err) {
            showToast('danger', 'Error: ' + err);
        });
    }

    // ===== LIVE WEIGHT =====
    function showLiveWeight(serviceId, scaleId, displayName) {
        liveWeightScaleId = scaleId;
        document.getElementById('liveWeightScaleName').textContent = displayName || scaleId;
        document.getElementById('liveWeightValue').textContent = '0';
        document.getElementById('liveWeightValue').style.color = '#0f0';
        document.getElementById('liveWeightUnit').style.color = '#0a0';
        document.getElementById('liveWeightStatus').innerHTML = '<span style="color:#888;">Waiting...</span>';
        document.getElementById('diagRawText').textContent = '--';
        document.getElementById('diagRawHex').textContent = '--';
        document.getElementById('diagParsed').textContent = '--';
        new bootstrap.Modal('#liveWeightModal').show();

        document.getElementById('liveWeightModal').addEventListener('hidden.bs.modal', function () {
            liveWeightScaleId = null;
        }, { once: true });
    }

    // ===== TOAST =====
    function showToast(type, message) {
        var container = document.getElementById('scaleToastContainer');
        var colors = {
            success: { bg: '#d1e7dd', border: '#badbcc', text: '#0f5132' },
            danger: { bg: '#f8d7da', border: '#f5c2c7', text: '#842029' },
            info: { bg: '#cff4fc', border: '#b6effb', text: '#055160' }
        };
        var c = colors[type] || colors.info;
        var html = '<div role="alert" style="padding:12px 40px 12px 16px;margin-bottom:8px;border:1px solid ' + c.border +
            ';border-radius:6px;background:' + c.bg + ';color:' + c.text + ';position:relative;">' +
            message + '<button type="button" onclick="this.parentElement.remove()" style="position:absolute;top:8px;right:12px;background:none;border:none;font-size:18px;cursor:pointer;color:' + c.text + ';">&times;</button></div>';
        container.innerHTML = html;
        if (type !== 'danger') setTimeout(function () { container.innerHTML = ''; }, 5000);
    }
</script>
}
