@* Renders the admin-defined custom ticket fields (Setup → Fields) as form
   inputs. Controllers populate ViewBag.CustomFields (active definitions) and
   ViewBag.CustomValues (fieldId -> stored value for the ticket being edited).
   Inputs post as cf_{fieldId}; TransactionController.SaveCustomFieldValues
   reads them back. *@
@{
    var cfFields = ViewBag.CustomFields as List<Foundation.Web.Models.CustomField> ?? new List<Foundation.Web.Models.CustomField>();
    var cfValues = ViewBag.CustomValues as Dictionary<int, string> ?? new Dictionary<int, string>();
}
@foreach (var f in cfFields)
{
    var val = cfValues.TryGetValue(f.Id, out var v) ? v : "";
    <div class="mb-3">
        <label class="form-label">
            @f.Name
            @if (f.Required)
            {
                <span class="text-danger" title="Required">*</span>
            }
        </label>
        @if (f.FieldType == "Integer")
        {
            <input type="number" step="1" name="cf_@f.Id" class="form-control custom-field-input"
                   min="@(f.MinValue?.ToString() ?? "")" max="@(f.MaxValue?.ToString() ?? "")"
                   value="@val" required="@(f.Required ? "required" : null)" />
        }
        else if (f.FieldType == "Real")
        {
            var step = f.Precision.HasValue ? Math.Pow(10, -f.Precision.Value).ToString("0.######") : "any";
            <input type="number" step="@step" name="cf_@f.Id" class="form-control custom-field-input"
                   min="@(f.MinValue?.ToString() ?? "")" max="@(f.MaxValue?.ToString() ?? "")"
                   value="@val" required="@(f.Required ? "required" : null)" />
        }
        else if (f.GetListValues().Count > 0)
        {
            @* List-backed text field: dropdown of admin-defined choices. A
               historical value no longer in the list is kept selectable so
               editing an old ticket doesn't silently lose it. *@
            var choices = f.GetListValues();
            <select name="cf_@f.Id" class="form-select custom-field-input"
                    required="@(f.Required ? "required" : null)">
                <option value=""></option>
                @if (!string.IsNullOrEmpty(val) && !choices.Contains(val))
                {
                    <option value="@val" selected>@val (retired)</option>
                }
                @foreach (var choice in choices)
                {
                    <option value="@choice" selected="@(choice == val ? "selected" : null)">@choice</option>
                }
            </select>
        }
        else
        {
            <input type="text" maxlength="200" name="cf_@f.Id" class="form-control custom-field-input"
                   value="@val" required="@(f.Required ? "required" : null)" />
        }
    </div>
}
