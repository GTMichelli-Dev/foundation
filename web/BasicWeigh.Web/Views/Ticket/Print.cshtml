@model BasicWeigh.Web.Models.Transaction
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Ticket @Model.Ticket</title>
    <style>
        body {
            font-family: 'Courier New', monospace;
            max-width: 400px;
            margin: 20px auto;
            font-size: 14px;
        }
        .ticket {
            border: 2px solid #000;
            padding: 20px;
        }
        .ticket-header {
            text-align: center;
            margin-bottom: 15px;
            border-bottom: 1px dashed #000;
            padding-bottom: 10px;
        }
        .ticket-icon {
            width: 48px;
            height: 48px;
            margin-bottom: 8px;
        }
        .ticket-header div {
            font-size: 16px;
            font-weight: bold;
        }
        .ticket-row {
            display: flex;
            justify-content: space-between;
            padding: 3px 0;
        }
        .ticket-row .label {
            font-weight: bold;
            min-width: 120px;
        }
        .ticket-weights {
            border-top: 1px dashed #000;
            border-bottom: 1px dashed #000;
            margin: 10px 0;
            padding: 10px 0;
        }
        .ticket-weights .ticket-row {
            font-size: 16px;
        }
        .net-weight {
            font-size: 20px;
            font-weight: bold;
        }
        .print-btn {
            text-align: center;
            margin-top: 20px;
        }
        @@media print {
            .print-btn { display: none; }
            body { margin: 0; }
        }
    </style>
</head>
<body>
    <div class="ticket">
        <div class="ticket-header">
            <img src="/api/setup/icon" alt="" class="ticket-icon" />
            @if (!string.IsNullOrEmpty(ViewBag.Header1)) { <div>@ViewBag.Header1</div> }
            @if (!string.IsNullOrEmpty(ViewBag.Header2)) { <div>@ViewBag.Header2</div> }
            @if (!string.IsNullOrEmpty(ViewBag.Header3)) { <div>@ViewBag.Header3</div> }
            @if (!string.IsNullOrEmpty(ViewBag.Header4)) { <div>@ViewBag.Header4</div> }
        </div>

        <div class="ticket-row">
            <span class="label">Ticket #:</span>
            <span>@Model.Ticket</span>
        </div>

        <div class="ticket-row">
            <span class="label">Date In:</span>
            <span>@Model.DateIn.ToString("MM/dd/yyyy hh:mm tt")</span>
        </div>

        @if (Model.DateOut.HasValue)
        {
            <div class="ticket-row">
                <span class="label">Date Out:</span>
                <span>@Model.DateOut.Value.ToString("MM/dd/yyyy hh:mm tt")</span>
            </div>
        }

        <div class="ticket-row">
            <span class="label">Customer:</span>
            <span>@Model.Customer</span>
        </div>

        <div class="ticket-row">
            <span class="label">Carrier:</span>
            <span>@Model.Carrier</span>
        </div>

        <div class="ticket-row">
            <span class="label">Truck ID:</span>
            <span>@Model.TruckId</span>
        </div>

        <div class="ticket-row">
            <span class="label">Commodity:</span>
            <span>@Model.Commodity</span>
        </div>

        <div class="ticket-row">
            <span class="label">Location:</span>
            <span>@Model.Location</span>
        </div>

        <div class="ticket-row">
            <span class="label">Destination:</span>
            <span>@Model.Destination</span>
        </div>

        <div class="ticket-weights">
            <div class="ticket-row">
                <span class="label">Gross Weight:</span>
                <span>@Model.GrossWeight.ToString("#,##0") lb</span>
            </div>
            <div class="ticket-row">
                <span class="label">Tare Weight:</span>
                <span>@Model.TareWeight.ToString("#,##0") lb</span>
            </div>
            <div class="ticket-row net-weight">
                <span class="label">Net Weight:</span>
                <span>@Model.NetWeight.ToString("#,##0") lb</span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="ticket-row">
                <span class="label">Notes:</span>
                <span>@Model.Notes</span>
            </div>
        }

        @if (Model.Void)
        {
            <div style="text-align: center; color: red; font-size: 24px; font-weight: bold; margin-top: 10px;">
                *** VOID ***
            </div>
        }
    </div>

    <div class="print-btn">
        <button onclick="window.print()" style="padding: 10px 30px; font-size: 16px; cursor: pointer;">Print Ticket</button>
    </div>
</body>
</html>
