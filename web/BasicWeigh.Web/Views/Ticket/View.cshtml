@model DevExpress.XtraReports.UI.XtraReport
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ticket Preview - Basic Weigh</title>

    <!-- CSS -->
    <link href="~/css/devextreme/bootstrap.css" rel="stylesheet" />
    <link href="~/css/devextreme/dx.light.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/reporting/dx-analytics.common.css" />
    <link rel="stylesheet" href="~/css/reporting/dx-analytics.light.css" />
    <link rel="stylesheet" href="~/css/reporting/dx-webdocumentviewer.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Scripts: loaded in head so they're ready before the inline init code -->
    <script src="~/js/devextreme/jquery.js"></script>
    <script src="~/js/reporting/knockout-latest.js"></script>
    <script src="~/js/devextreme/dx.all.js"></script>
    <script src="~/js/devextreme-license.js"></script>
    <script src="~/js/reporting/dx-analytics-core.js"></script>
    <script src="~/js/reporting/dx-webdocumentviewer.min.js"></script>
</head>
<body>
    <nav class="navbar navbar-expand-sm mb-3" style="background: #fff; border-bottom: 3px solid #2ea3f2; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
        <div class="container-fluid">
            <a class="navbar-brand" href="/" style="color: #2ea3f2; font-size: 1.3rem;"><strong>Basic Weigh</strong></a>
            <span class="navbar-text ms-2" style="font-weight: 600;">Ticket Preview</span>
            <a href="/Transaction/CompletedTrucks" class="btn btn-outline-secondary btn-sm ms-auto">Back to Completed Trucks</a>
        </div>
    </nav>

    <div class="container-fluid" style="height: calc(100vh - 70px);">
        @(Html.DevExpress().WebDocumentViewer("ticketViewer")
            .Height("100%")
            .Bind(Model))
    </div>
</body>
</html>
