@model BasicWeigh.Web.Models.Transaction
@{
    ViewData["Title"] = "Edit Ticket " + Model.Ticket;
}

<h3>Edit Ticket @Model.Ticket</h3>

<form asp-action="Edit" asp-route-id="@Model.Ticket" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Ticket" />

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Ticket Number</label>
                        <input type="text" class="form-control" value="@Model.Ticket" readonly />
                    </div>

                    <div class="mb-3">
                        <label asp-for="InWeight" class="form-label"></label>
                        <input asp-for="InWeight" class="form-control" type="number" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="OutWeight" class="form-label"></label>
                        <input asp-for="OutWeight" class="form-control" type="number" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="DateIn" class="form-label"></label>
                        <input asp-for="DateIn" class="form-control" type="datetime-local" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="DateOut" class="form-label"></label>
                        <input asp-for="DateOut" class="form-control" type="datetime-local" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Customer" class="form-label"></label>
                        <select asp-for="Customer" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var c in (List<BasicWeigh.Web.Models.Customer>)ViewBag.Customers)
                            {
                                <option value="@c.CustomerName">@c.CustomerName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Carrier" class="form-label"></label>
                        <select asp-for="Carrier" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var name in (List<string>)ViewBag.CarrierOptions)
                            {
                                <option value="@name">@name</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="TruckId" class="form-label"></label>
                        <div class="input-group">
                            <select asp-for="TruckId" id="truckSelect" class="form-select">
                                <option value="">-- Select Carrier First --</option>
                            </select>
                            <button type="button" class="btn btn-outline-primary" id="addTruckBtn" disabled title="Add New Truck">+</button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Commodity" class="form-label"></label>
                        <select asp-for="Commodity" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var c in (List<BasicWeigh.Web.Models.Commodity>)ViewBag.Commodities)
                            {
                                <option value="@c.CommodityName">@c.CommodityName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label"></label>
                        <select asp-for="Location" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var l in (List<BasicWeigh.Web.Models.Location>)ViewBag.Locations)
                            {
                                <option value="@l.LocationName">@l.LocationName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Destination" class="form-label"></label>
                        <select asp-for="Destination" class="form-select">
                            <option value="">-- Select --</option>
                            @foreach (var d in (List<BasicWeigh.Web.Models.Destination>)ViewBag.Destinations)
                            {
                                <option value="@d.DestinationName">@d.DestinationName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Void" class="form-check-input" type="checkbox" />
                        <label asp-for="Void" class="form-check-label"></label>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary btn-lg me-2">Save Changes</button>
                        <a asp-action="CompletedTrucks" class="btn btn-secondary btn-lg">Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Add Truck Modal -->
<div class="modal fade" id="addTruckModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Truck</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Carrier</label>
                    <input type="text" id="modalCarrier" class="form-control" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label">Truck ID</label>
                    <input type="text" id="modalTruckId" class="form-control" maxlength="50" required />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTruckBtn">Add Truck</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        var customerSelect = $('select[name="Customer"]');
        var carrierSelect = $('select[name="Carrier"]');
        var truckSelect = $('#truckSelect');
        var addTruckBtn = $('#addTruckBtn');
        var initialTruckId = '@(Model.TruckId ?? "")';

        customerSelect.on('change', function () {
            if (!carrierSelect.val() && $(this).val()) {
                carrierSelect.val($(this).val());
                carrierSelect.trigger('change');
            }
        });

        function loadTrucks(carrier, selectTruckId) {
            if (!carrier) {
                truckSelect.html('<option value="">-- Select Carrier First --</option>').prop('disabled', true);
                addTruckBtn.prop('disabled', true);
                return;
            }
            $.getJSON('/api/masterdata/trucks/' + encodeURIComponent(carrier), function (trucks) {
                truckSelect.html('<option value="">-- Select --</option>');
                trucks.forEach(function (t) {
                    truckSelect.append($('<option>').val(t.truckId).text(t.truckId));
                });
                truckSelect.prop('disabled', false);
                addTruckBtn.prop('disabled', false);
                if (selectTruckId) truckSelect.val(selectTruckId);
            });
        }

        carrierSelect.on('change', function () { loadTrucks($(this).val()); });

        // Load trucks for existing carrier on page load
        if (carrierSelect.val()) {
            loadTrucks(carrierSelect.val(), initialTruckId);
        }

        addTruckBtn.on('click', function () {
            $('#modalCarrier').val(carrierSelect.val());
            $('#modalTruckId').val('');
            new bootstrap.Modal('#addTruckModal').show();
            setTimeout(function () { $('#modalTruckId').focus(); }, 500);
        });

        $('#saveTruckBtn').on('click', function () {
            var carrier = $('#modalCarrier').val();
            var truckId = $('#modalTruckId').val().trim();
            if (!truckId) return;
            $.ajax({
                url: '/api/masterdata/trucks',
                method: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ truckId: truckId, carrierName: carrier }),
                success: function () {
                    bootstrap.Modal.getInstance('#addTruckModal').hide();
                    loadTrucks(carrier, truckId);
                }
            });
        });

        $('#modalTruckId').on('keypress', function (e) {
            if (e.which === 13) { e.preventDefault(); $('#saveTruckBtn').click(); }
        });
    });
</script>
}
