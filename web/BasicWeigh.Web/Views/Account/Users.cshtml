@model List<BasicWeigh.Web.Models.AppUser>
@{
    ViewData["Title"] = "User Management";
}

<h3 class="mb-2">User Management</h3>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-dismissible fade show py-1 mb-2" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show py-1 mb-2" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
    </div>
}

<div class="mb-2">
    <a asp-action="CreateUser" class="btn btn-primary btn-sm">+ Add User</a>
    <a asp-controller="Setup" asp-action="Index" class="btn btn-secondary btn-sm">Back to Setup</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead>
                <tr style="background: var(--bw-surface-alt);">
                    <th>Username</th>
                    <th>Display Name</th>
                    <th>Role</th>
                    <th>Active</th>
                    <th>Must Change Password</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>@user.DisplayName</td>
                        <td>
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            else if (user.Role == "Manager")
                            {
                                <span class="badge bg-warning text-dark">Manager</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">User</span>
                            }
                        </td>
                        <td>
                            @if (user.Active)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                        <td>
                            @if (user.MustChangePassword)
                            {
                                <span class="badge bg-warning text-dark">Yes</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                                <form asp-action="ResetPassword" asp-route-id="@user.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Reset password for \'@user.Username\' to default?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-warning btn-sm">Reset PW</button>
                                </form>
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete user \'@user.Username\'? This cannot be undone.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header py-1" style="background: var(--bw-surface-alt); color: var(--bw-text);">
        <strong>Roles</strong>
    </div>
    <div class="card-body py-2 small">
        <table class="table table-sm mb-0">
            <tr><td><span class="badge bg-info text-dark">User</span></td><td>Weigh trucks in and out</td></tr>
            <tr><td><span class="badge bg-warning text-dark">Manager</span></td><td>Weigh trucks + edit master data tables (customers, carriers, etc.)</td></tr>
            <tr><td><span class="badge bg-danger">Admin</span></td><td>Full access including Setup page and user management</td></tr>
        </table>
        <p class="mt-2 mb-0 text-muted">When an admin resets a password, it is set to <code>michelli</code> and the user must change it on next login.</p>
    </div>
</div>
