@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .weight-display {
        background-color: #000;
        color: #0f0;
        font-family: 'Courier New', monospace;
        font-size: 5rem;
        font-weight: bold;
        text-align: right;
        padding: 20px 40px;
        border-radius: 8px;
        margin-bottom: 30px;
        letter-spacing: 4px;
    }
    .weight-unit {
        font-size: 2rem;
        color: #0a0;
        margin-left: 10px;
    }
    .motion-indicator {
        font-size: 1rem;
        color: #ff0;
        display: none;
    }
    .motion-indicator.active {
        display: inline;
    }
    .dashboard-btn {
        font-size: 1.3rem;
        padding: 30px 20px;
        width: 100%;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="row justify-content-center mb-4">
    <div class="col-md-8">
        <div class="weight-display" id="weightDisplay">
            <span id="motionIndicator" class="motion-indicator">MOTION</span>
            <span id="weightValue">0</span>
            <span class="weight-unit">lb</span>
        </div>
    </div>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Transaction" asp-action="WeighIn" class="btn btn-success dashboard-btn">
            Weigh In
        </a>
    </div>
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Transaction" asp-action="InboundTrucks" class="btn btn-primary dashboard-btn">
            Inbound Trucks
        </a>
    </div>
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Transaction" asp-action="CompletedTrucks" class="btn btn-info dashboard-btn text-white">
            Completed Trucks
        </a>
    </div>
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Transaction" asp-action="BasicTicket" class="btn btn-warning dashboard-btn">
            Basic Ticket
        </a>
    </div>
    <div class="col-md-4 col-lg-3">
        <a asp-controller="Report" asp-action="Index" class="btn btn-secondary dashboard-btn">
            Reports
        </a>
    </div>
    <div class="col-md-4 col-lg-3">
        <a asp-controller="MasterData" asp-action="Index" class="btn btn-dark dashboard-btn">
            Edit Tables
        </a>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        function pollWeight() {
            $.getJSON('/api/scale/weight', function (data) {
                $('#weightValue').text(data.weight);
                if (data.motion) {
                    $('#motionIndicator').addClass('active');
                } else {
                    $('#motionIndicator').removeClass('active');
                }
            });
        }
        setInterval(pollWeight, 500);
        pollWeight();
    });
</script>
}
